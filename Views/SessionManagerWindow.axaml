<atom:Window xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:atom="https://atomui.net"
             xmlns:antdicons="https://atomui.net/icons/antdesign"
             xmlns:vm="using:CxShell.ViewModels"
             xmlns:views="using:CxShell.Views"
             x:Class="CxShell.Views.SessionManagerWindow"
             x:DataType="vm:SessionTreeViewModel"
             Title="{Binding SessionManagerTitle}"
             Width="820"
             Height="680"
             MinWidth="640"
             MinHeight="300"
             WindowStartupLocation="CenterOwner"
             ShowInTaskbar="False"
             Background="{atom:SharedTokenResource ColorBgLayout}">

    <Grid RowDefinitions="*,Auto">
        <views:SessionTreeView Grid.Row="0" DataContext="{Binding}"/>

        <Border Grid.Row="1"
                BorderBrush="{atom:SharedTokenResource ColorSplit}"
                BorderThickness="0,1,0,0"
                Padding="20,12">
            <Grid ColumnDefinitions="*,Auto">
                <atom:CheckBox Grid.Column="0"
                               Content="{Binding ShowOnStartupText}"
                               IsChecked="{Binding ShowSessionManagerOnStartup, Mode=TwoWay}"
                               VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Spacing="8">
                <atom:Button x:Name="ConnectButton"
                             ButtonType="Primary"
                             Icon="{antdicons:AntDesignIconProvider Kind=LinkOutlined}"
                             Content="{Binding ConnectText}"
                             IsEnabled="{Binding CanUseSelectedSession}"
                             Click="OnConnectClick"/>
                <atom:Button Icon="{antdicons:AntDesignIconProvider Kind=CloseOutlined}"
                             Content="{Binding CloseText}"
                             Click="OnCloseClick"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</atom:Window>
