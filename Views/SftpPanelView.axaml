<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:atom="https://atomui.net"
             xmlns:vm="using:CxShell.ViewModels"
             xmlns:models="using:CxShell.Models"
             x:Class="CxShell.Views.SftpPanelView"
             x:DataType="vm:SftpViewModel">

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*" Background="{atom:SharedTokenResource ColorBgLayout}">

        <Border Grid.Row="0"
                Background="{atom:SharedTokenResource ColorBgContainer}"
                Padding="10,8">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            Spacing="6">
                    <TextBlock Text="📁"
                               FontSize="14"
                               VerticalAlignment="Center"
                               Foreground="{atom:SharedTokenResource ColorText}"/>
                    <TextBlock Text="{Binding ProtocolLabel}"
                               FontSize="13"
                               FontWeight="Bold"
                               Foreground="{atom:SharedTokenResource ColorText}"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="6">
                    <TextBlock Text="{Binding HostLabel}"
                               FontSize="11"
                               Foreground="{atom:SharedTokenResource ColorTextTertiary}"
                               VerticalAlignment="Center"/>
                    <Ellipse Width="8"
                             Height="8"
                             VerticalAlignment="Center"
                             Fill="{Binding IsConnected, Converter={x:Static vm:SftpStatusColorConverter.Instance}}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="{atom:SharedTokenResource ColorBgLayout}"
                Padding="6,4"
                BorderBrush="{atom:SharedTokenResource ColorSplit}"
                BorderThickness="0,0,0,1">
            <Grid>
                <atom:LineEdit
                               x:Name="RemotePathInput"
                               Text="{Binding PathInput, Mode=TwoWay}"
                               PlaceholderText="/home/user"
                               IsAllowClear="False"
                               IsEnabled="{Binding IsConnected}"
                               FontSize="12"
                               Height="32"
                               HorizontalAlignment="Stretch"
                               KeyDown="OnRemotePathInputKeyDown"/>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Background="{atom:SharedTokenResource ColorBgContainer}"
                Padding="6,4"
                BorderBrush="{atom:SharedTokenResource ColorSplit}"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal"
                        Spacing="2">
                <atom:Button Background="{atom:SharedTokenResource ColorFillTertiary}"
                             BorderThickness="0"
                             Padding="8,5"
                             Command="{Binding NavigateHomeCommand}"
                             CornerRadius="4">
                    <TextBlock Text="🏠"
                               FontSize="14"
                               Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                </atom:Button>
                <atom:Button Background="{atom:SharedTokenResource ColorFillTertiary}"
                             BorderThickness="0"
                             Padding="8,5"
                             Command="{Binding NavigateUpCommand}"
                             CornerRadius="4">
                    <TextBlock Text="↑"
                               FontSize="14"
                               Foreground="{atom:SharedTokenResource ColorTextSecondary}"
                               FontWeight="Bold"/>
                </atom:Button>
                <atom:Button Background="{atom:SharedTokenResource ColorFillTertiary}"
                             BorderThickness="0"
                             Padding="8,5"
                             Command="{Binding RefreshCommand}"
                             CornerRadius="4">
                    <TextBlock Text="↻"
                               FontSize="14"
                               Foreground="{atom:SharedTokenResource ColorTextSecondary}"
                               FontWeight="Bold"/>
                </atom:Button>
                <Border Width="1"
                        Background="{atom:SharedTokenResource ColorBorder}"
                        Margin="4,4"/>
                <atom:Button Background="{atom:SharedTokenResource ColorSuccessBg}"
                             BorderThickness="0"
                             Padding="8,5"
                             Command="{Binding UploadCommand}"
                             IsEnabled="{Binding IsConnected}"
                             CornerRadius="4">
                    <TextBlock Text="{Binding UploadText}"
                               FontSize="12"
                               Foreground="{atom:SharedTokenResource ColorSuccess}"
                               FontWeight="Bold"/>
                </atom:Button>
                <atom:Button Background="{atom:SharedTokenResource ColorInfoBg}"
                             BorderThickness="0"
                             Padding="8,5"
                             Command="{Binding DownloadCommand}"
                             IsEnabled="{Binding IsConnected}"
                             CornerRadius="4">
                    <TextBlock Text="{Binding DownloadText}"
                               FontSize="12"
                               Foreground="{atom:SharedTokenResource ColorInfo}"
                               FontWeight="Bold"/>
                </atom:Button>
                <atom:Button Background="{atom:SharedTokenResource ColorWarningBg}"
                             BorderThickness="0"
                             Padding="8,5"
                             Command="{Binding CreateDirectoryCommand}"
                             IsEnabled="{Binding IsConnected}"
                             CornerRadius="4">
                    <TextBlock Text="{Binding NewDirectoryText}"
                               FontSize="12"
                               Foreground="{atom:SharedTokenResource ColorWarning}"
                               FontWeight="Bold"/>
                </atom:Button>
                <atom:Button Background="{atom:SharedTokenResource ColorErrorBg}"
                             BorderThickness="0"
                             Padding="8,5"
                             Command="{Binding DeleteCommand}"
                             IsEnabled="{Binding HasSelectedFiles}"
                             CornerRadius="4">
                    <TextBlock Text="{Binding DeleteText}"
                               FontSize="12"
                               Foreground="{atom:SharedTokenResource ColorError}"
                               FontWeight="Bold"/>
                </atom:Button>
            </StackPanel>
        </Border>

        <Border Grid.Row="3"
                Background="{atom:SharedTokenResource ColorErrorBg}"
                Padding="8,4"
                IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{atom:SharedTokenResource ColorErrorText}"
                       FontSize="11"
                       TextWrapping="Wrap"/>
        </Border>

        <Grid Grid.Row="4"
              RowDefinitions="Auto,*"
              Background="Transparent"
              DragDrop.AllowDrop="{Binding IsConnected}"
              DragDrop.DragOver="OnFileListDragOver"
              DragDrop.Drop="OnFileListDrop">
            <Border Grid.Row="0"
                    Background="{atom:SharedTokenResource ColorBgContainer}"
                    BorderBrush="{atom:SharedTokenResource ColorSplit}"
                    BorderThickness="0,0,0,1"
                    Padding="6,4"
                    IsVisible="{Binding IsCreatingDirectory}">
                <Grid ColumnDefinitions="Auto,*"
                      ColumnSpacing="6">
                    <TextBlock Grid.Column="0"
                               Text="+"
                               FontSize="15"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                    <atom:TextBox Grid.Column="1"
                                  x:Name="NewDirInput"
                                  Text="{Binding NewDirectoryName, Mode=TwoWay}"
                                  FontSize="12"
                                  BorderThickness="0,0,0,1"
                                  Padding="2,2"
                                  VerticalAlignment="Center"
                                  KeyDown="OnNewDirInputKeyDown"
                                  LostFocus="OnNewDirInputLostFocus"/>
                </Grid>
            </Border>

            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8"
                        Grid.RowSpan="2"
                        IsVisible="{Binding !IsConnected}">
                <TextBlock Text="📁"
                           FontSize="32"
                           HorizontalAlignment="Center"
                           Opacity="0.3"/>
                <TextBlock Text="{Binding ConnectHintText}"
                           FontSize="12"
                           Foreground="{atom:SharedTokenResource ColorTextTertiary}"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <atom:Spin Grid.Row="1"
                       IsVisible="{Binding IsConnected}"
                       IsSpinning="{Binding IsLoading}"
                       IsTipVisible="{Binding IsLoading}"
                       Tip="{Binding LoadingText}"
                       SizeType="Middle"
                       IsMaskBackgroundEnabled="False"
                       IsMaskBlurEnabled="False"
                       HorizontalAlignment="Stretch"
                       VerticalAlignment="Stretch">
                <atom:DataGrid x:Name="FileGrid"
                               ItemsSource="{Binding Files}"
                               SelectedItem="{Binding SelectedFile, Mode=TwoWay}"
                               AutoGenerateColumns="False"
                               IsReadOnly="True"
                               SelectionMode="Extended"
                               SizeType="Middle"
                               GridLinesVisibility="All"
                               CanUserResizeColumns="True"
                               CanUserSortColumns="True"
                               IsHideOnSinglePage="True"
                               HeadersVisibility="Column"
                               SelectionChanged="OnFileGridSelectionChanged"
                               PointerMoved="OnFileGridPointerMoved"
                               PointerReleased="OnFileGridPointerReleased"
                               KeyDown="OnFileGridKeyDown">
                    <atom:DataGrid.Columns>
                        <atom:DataGridTemplateColumn Header="{Binding NameText}"
                                                     SortMemberPath="Name"
                                                     Width="1*"
                                                     MinWidth="100"
                                                     CanUserResize="True">
                            <atom:DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="models:SftpFileItem">
                                    <Grid ColumnDefinitions="Auto,*">
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Icon}"
                                                   FontSize="13"
                                                   VerticalAlignment="Center"
                                                   Foreground="{atom:SharedTokenResource ColorTextSecondary}"
                                                   Margin="0,0,6,0"/>
                                        <Grid Grid.Column="1">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontSize="12"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"
                                                       IsVisible="{Binding !IsRenaming}"
                                                       Foreground="{Binding IsDirectory, Converter={x:Static vm:SftpDirColorConverter.Instance}}"/>
                                            <atom:TextBox Text="{Binding RenamingText, Mode=TwoWay}"
                                                          FontSize="12"
                                                          BorderThickness="0,0,0,1"
                                                          Padding="2,1"
                                                          VerticalAlignment="Center"
                                                          IsVisible="{Binding IsRenaming}"
                                                          Tag="{Binding}"
                                                          KeyDown="OnRenameInputKeyDown"
                                                          LostFocus="OnRenameInputLostFocus"/>
                                        </Grid>
                                    </Grid>
                                </DataTemplate>
                            </atom:DataGridTemplateColumn.CellTemplate>
                        </atom:DataGridTemplateColumn>
                        <atom:DataGridTextColumn Header="{Binding SizeText}"
                                                 Binding="{Binding SizeDisplay}"
                                                 SortMemberPath="Size"
                                                 Width="0.8*"
                                                 MinWidth="82"
                                                 CanUserResize="True"/>
                        <atom:DataGridTextColumn Header="{Binding ModifiedText}"
                                                 Binding="{Binding DateDisplay}"
                                                 SortMemberPath="LastModified"
                                                 Width="*"
                                                 MinWidth="118"
                                                 CanUserResize="True"/>
                    </atom:DataGrid.Columns>
                </atom:DataGrid>
            </atom:Spin>
        </Grid>

    </Grid>
</UserControl>
