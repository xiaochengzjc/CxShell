<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:atom="https://atomui.net"
             xmlns:vm="using:ChiXueSsh.ViewModels"
             xmlns:controls="using:ChiXueSsh.Controls"
             x:Class="ChiXueSsh.Views.TerminalView"
             x:DataType="vm:TerminalViewModel">
    <Grid>
        <!-- 连接中提示 -->
        <atom:TextBlock Text="正在连接..."
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Opacity="0.5" FontSize="16"
                        IsVisible="{Binding !IsConnected}"/>

        <!-- 终端控件 -->
        <controls:TerminalControl x:Name="Terminal"
                                  Cursor="Ibeam"
                                  TerminalBuffer="{Binding Buffer}"/>

        <Popup x:Name="TerminalContextMenuPopup"
               Placement="Pointer"
               IsLightDismissEnabled="True">
            <Border Background="{atom:SharedTokenResource ColorBgElevated}"
                    BorderBrush="{atom:SharedTokenResource ColorBorder}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="0,4"
                    MinWidth="120">
                <StackPanel Spacing="0">
                    <atom:Button x:Name="MenuCopyBtn" Content="复制"
                                 Background="Transparent" BorderThickness="0"
                                 HorizontalAlignment="Stretch"
                                 HorizontalContentAlignment="Left"
                                 Padding="16,6" FontSize="13"
                                 Foreground="{atom:SharedTokenResource ColorText}"/>
                    <atom:Button x:Name="MenuPasteBtn" Content="粘贴"
                                 Background="Transparent" BorderThickness="0"
                                 HorizontalAlignment="Stretch"
                                 HorizontalContentAlignment="Left"
                                 Padding="16,6" FontSize="13"
                                 Foreground="{atom:SharedTokenResource ColorText}"/>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</UserControl>
