<atom:Window xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:atom="https://atomui.net"
             xmlns:edit="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
             xmlns:vm="using:CxShell.ViewModels"
             x:Class="CxShell.Views.RemoteFileEditorWindow"
             x:DataType="vm:RemoteFileEditorViewModel"
             Title="{Binding WindowTitle}"
             Width="920"
             Height="700"
             MinWidth="620"
             MinHeight="420"
             WindowStartupLocation="CenterOwner"
             Background="{atom:SharedTokenResource ColorBgLayout}">

    <Grid RowDefinitions="Auto,*,Auto">
        <Border Grid.Row="0"
                Background="{atom:SharedTokenResource ColorBgContainer}"
                BorderBrush="{atom:SharedTokenResource ColorSplit}"
                BorderThickness="0,0,0,1"
                Padding="12,8">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <StackPanel Spacing="2">
                    <TextBlock Text="{Binding FileName}"
                               FontWeight="SemiBold"
                               Foreground="{atom:SharedTokenResource ColorText}"/>
                    <TextBlock Text="{Binding RemotePath}"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis"
                               Foreground="{atom:SharedTokenResource ColorTextTertiary}"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center">
                    <atom:Button Content="保存"
                                 Command="{Binding SaveCommand}"
                                 IsEnabled="{Binding !IsSaving}"/>
                    <atom:Button Content="关闭"
                                 Click="OnCloseClick"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="{atom:SharedTokenResource ColorBgContainer}"
                Padding="0">
            <edit:TextEditor x:Name="Editor"
                             ShowLineNumbers="True"
                             FontFamily="Consolas"
                             FontSize="13"
                             WordWrap="False"
                             HorizontalScrollBarVisibility="Auto"
                             VerticalScrollBarVisibility="Auto"/>
        </Border>

        <Border Grid.Row="2"
                Background="{atom:SharedTokenResource ColorBgContainer}"
                BorderBrush="{atom:SharedTokenResource ColorSplit}"
                BorderThickness="0,1,0,0"
                Padding="12,6">
            <TextBlock Text="{Binding StatusText}"
                       FontSize="12"
                       Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
        </Border>
    </Grid>
</atom:Window>
