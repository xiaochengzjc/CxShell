<atom:Window xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:atom="https://atomui.net"
             xmlns:antdicons="https://atomui.net/icons/antdesign"
             xmlns:models="using:ChiXueSsh.Models"
             xmlns:vm="using:ChiXueSsh.ViewModels"
             xmlns:views="using:ChiXueSsh.Views"
             x:Class="ChiXueSsh.Views.MainWindow"
             x:DataType="vm:MainWindowViewModel"
             Title="Cx-Ssh - SSH Client"
             Icon="/Assets/ChiXueSshLogo.png"
             Width="1200"
             Height="800"
             MinWidth="600"
             MinHeight="400"
             WindowState="Normal"
             WindowStartupLocation="CenterScreen">

    <atom:Window.LogoTemplate>
        <DataTemplate>
            <Image Source="/Assets/ChiXueSshLogo.png"/>
        </DataTemplate>
    </atom:Window.LogoTemplate>

    <atom:Window.Styles>
        <Style Selector="atom|Button.quick-session-bar-button">
            <Setter Property="Background" Value="{atom:SharedTokenResource ColorBgLayout}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="atom|Button.quick-session-bar-button:pointerover">
            <Setter Property="Background" Value="{atom:SharedTokenResource ColorFillSecondary}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="atom|Button.quick-session-bar-button:pressed">
            <Setter Property="Background" Value="{atom:SharedTokenResource ColorFill}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="atom|Button.quick-session-bar-button:disabled">
            <Setter Property="Background" Value="{atom:SharedTokenResource ColorBgLayout}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
    </atom:Window.Styles>



    <DockPanel>
        <!-- 工具栏 -->
        <Border DockPanel.Dock="Top" Padding="8,4"
                IsVisible="{Binding IsMainChromeVisible}"
                Background="{atom:SharedTokenResource ColorBgContainer}">
            <StackPanel Orientation="Horizontal" Spacing="4">
                <atom:Button Command="{Binding NewSessionCommand}"
                             ButtonType="Default">
                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <atom:TextBlock Text="+" FontSize="16" FontWeight="Bold" Width="18"
                                        TextAlignment="Center" VerticalAlignment="Center"/>
                        <atom:TextBlock Text="新建会话" VerticalAlignment="Center"/>
                    </StackPanel>
                </atom:Button>
                <atom:Button Command="{Binding ShowSessionManagerCommand}"
                             ButtonType="Default">
                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <atom:TextBlock Text="☰" FontSize="16" Width="18"
                                        TextAlignment="Center" VerticalAlignment="Center"/>
                        <atom:TextBlock Text="会话管理" VerticalAlignment="Center"/>
                    </StackPanel>
                </atom:Button>
                <Border Width="1" Background="{atom:SharedTokenResource ColorSplit}" Margin="8,4" Opacity="0.6"/>
                <atom:Button Command="{Binding CurrentConnectCommand}"
                             ButtonType="Default"
                             ToolTip.Tip="连接当前会话">
                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <atom:TextBlock Text="▶" FontSize="12" Width="18"
                                        TextAlignment="Center" VerticalAlignment="Center"/>
                        <atom:TextBlock Text="连接" VerticalAlignment="Center"/>
                    </StackPanel>
                </atom:Button>
                <atom:Button Command="{Binding CurrentDisconnectCommand}"
                             ButtonType="Default"
                             ToolTip.Tip="断开当前会话">
                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <atom:TextBlock Text="■" FontSize="11" Width="18"
                                        TextAlignment="Center" VerticalAlignment="Center"/>
                        <atom:TextBlock Text="断开" VerticalAlignment="Center"/>
                    </StackPanel>
                </atom:Button>
                <Border Width="1" Background="{atom:SharedTokenResource ColorSplit}" Margin="8,4" Opacity="0.6"/>
                <atom:Button Command="{Binding ToggleSftpCommand}"
                             ButtonType="Default">
                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <atom:TextBlock Text="⇅" FontSize="14" Width="18"
                                        TextAlignment="Center" VerticalAlignment="Center"/>
                        <atom:TextBlock Text="SFTP" VerticalAlignment="Center"/>
                    </StackPanel>
                </atom:Button>
                <atom:Button Command="{Binding ToggleMonitorCommand}"
                             ButtonType="Default">
                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <atom:TextBlock Text="▦" FontSize="14" Width="18"
                                        TextAlignment="Center" VerticalAlignment="Center"/>
                        <atom:TextBlock Text="监控" VerticalAlignment="Center"/>
                    </StackPanel>
                </atom:Button>
                <!-- 主题切换 -->
                <Border Width="1" Background="{atom:SharedTokenResource ColorSplit}" Margin="8,4" Opacity="0.6"/>
                <atom:Button ButtonType="Default" Command="{Binding ToggleThemeCommand}"
                             ToolTip.Tip="切换亮色/暗色主题">
                    <atom:TextBlock Text="{Binding ThemeIcon}" FontSize="14"
                                    TextAlignment="Center" VerticalAlignment="Center"/>
                </atom:Button>
                <atom:Button ButtonType="Default" Command="{Binding ToggleTerminalFullScreenCommand}"
                             ToolTip.Tip="全屏显示当前终端">
                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <atom:TextBlock Text="⛶" FontSize="14" Width="18"
                                        TextAlignment="Center" VerticalAlignment="Center"/>
                        <atom:TextBlock Text="全屏" VerticalAlignment="Center"/>
                    </StackPanel>
                </atom:Button>
            </StackPanel>
        </Border>

        <!-- 状态栏 -->
        <Border DockPanel.Dock="Top"
                Height="44"
                Padding="8,5"
                ClipToBounds="False"
                IsVisible="{Binding IsMainChromeVisible}"
                Background="{atom:SharedTokenResource ColorBgLayout}"
                BorderBrush="{atom:SharedTokenResource ColorSplit}"
                BorderThickness="0,1,0,1">
            <DockPanel LastChildFill="True"
                       ClipToBounds="False"
                       VerticalAlignment="Center">
                <atom:Button DockPanel.Dock="Left"
                             Classes="quick-session-bar-button"
                              Width="32"
                              Height="32"
                              Padding="0"
                              ButtonType="Default"
                              Shape="Default"
                              SizeType="Small"
                              Icon="{antdicons:AntDesignIconProvider PlusOutlined}"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             HorizontalContentAlignment="Center"
                             VerticalContentAlignment="Center"
                             Command="{Binding AddCurrentSessionToQuickBarCommand}"
                             ToolTip.Tip="将当前会话加入快捷标签栏"/>
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled"
                              Height="34"
                              Margin="6,0,0,0"
                              ClipToBounds="False"
                              VerticalAlignment="Center">
                    <ItemsControl ItemsSource="{Binding QuickSessions}"
                                  Height="34"
                                  ClipToBounds="False"
                                  VerticalAlignment="Center">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="models:SessionInfo">
                                <atom:Button ButtonType="Default"
                                             Classes="quick-session-bar-button"
                                             SizeType="Middle"
                                             Height="30"
                                             MinHeight="30"
                                             Icon="{antdicons:AntDesignIconProvider CloudServerOutlined}"
                                             Content="{Binding Name}"
                                             Padding="10,0"
                                             Margin="0,2,4,2"
                                             Cursor="Hand"
                                             VerticalAlignment="Center"
                                             HorizontalContentAlignment="Center"
                                             VerticalContentAlignment="Center"
                                             Command="{Binding $parent[Window].DataContext.ConnectQuickSessionCommand, x:CompileBindings=False}"
                                             CommandParameter="{Binding}"
                                             PointerPressed="OnQuickSessionTagPointerPressed"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <Border DockPanel.Dock="Bottom" Padding="8,4"
                IsVisible="{Binding IsMainChromeVisible}"
                Background="{atom:SharedTokenResource ColorBgContainer}"
                BorderBrush="{atom:SharedTokenResource ColorSplit}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" Spacing="16">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Ellipse Width="8" Height="8"
                             Fill="{Binding ConnectionStatusColor}"/>
                    <atom:TextBlock Text="{Binding ConnectionStatusText}"/>
                </StackPanel>
                <atom:TextBlock Text="{Binding ConnectedHostInfo}" Opacity="0.8"/>
                <atom:TextBlock Text="{Binding TerminalSizeText}" Opacity="0.8"/>
            </StackPanel>
        </Border>

        <!-- 主内容区域 -->
        <Grid ColumnDefinitions="Auto,*,Auto">

            <!-- Col 0: 左侧 SFTP 面板 -->
            <Grid Grid.Column="0" ColumnDefinitions="*,3"
                  IsVisible="{Binding IsSftpPanelVisible}">
                <views:SftpPanelView Grid.Column="0"
                                     DataContext="{Binding Sftp, x:CompileBindings=False}"
                                     Width="300"/>
                <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch"
                              Background="{atom:SharedTokenResource ColorSplit}"/>
            </Grid>

            <!-- Col 1: 终端区域（始终深色）-->
            <Grid Grid.Column="1" Background="#141414">
                <!-- 无标签时显示欢迎页 -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            Spacing="12"
                            IsVisible="{Binding !HasTabs}">
                    <atom:TextBlock Text="Cx-Ssh" FontSize="32" FontWeight="Bold"
                                   HorizontalAlignment="Center" Opacity="0.3"
                                   Foreground="{atom:SharedTokenResource ColorTextLightSolid}"/>
                    <atom:TextBlock Text="点击「会话管理」选择会话并连接，或点击「新建会话」开始"
                                   HorizontalAlignment="Center" Opacity="0.5"
                                   Foreground="{atom:SharedTokenResource ColorTextLightSolid}"/>
                    <atom:TextBlock Text="基于 AtomUI 开发"
                                   HorizontalAlignment="Center" Opacity="0.25"
                                   Foreground="{atom:SharedTokenResource ColorTextLightSolid}"
                                   FontSize="11"/>
                </StackPanel>

                <!-- 有标签时显示多标签布局 -->
                <Grid IsVisible="{Binding HasTabs}" RowDefinitions="Auto,*">
                    <!-- Tab 标题栏 -->
                    <Border Grid.Row="0"
                            IsVisible="{Binding IsTabHeaderVisible}"
                            Background="{atom:SharedTokenResource ColorBgLayout}"
                            BorderBrush="{atom:SharedTokenResource ColorBorder}" BorderThickness="0,0,0,1">
                        <ItemsControl ItemsSource="{Binding Tabs}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:TerminalTabViewModel">
                                    <atom:Button Background="Transparent" BorderThickness="0"
                                                 Padding="0"
                                                 Command="{Binding $parent[Window].DataContext.SelectTabCommand, x:CompileBindings=False}"
                                                 CommandParameter="{Binding}">
                                        <Border Padding="12,6"
                                                BorderThickness="1,1,1,0"
                                                Margin="2,2,0,0">
                                            <Border.Background>
                                                <SolidColorBrush Color="{Binding IsSelected, Converter={x:Static vm:TabSelectedBgConverter.Instance}}"/>
                                            </Border.Background>
                                            <Border.BorderBrush>
                                                <SolidColorBrush Color="{Binding IsSelected, Converter={x:Static vm:TabSelectedBorderConverter.Instance}}"/>
                                            </Border.BorderBrush>
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <atom:TextBlock Text="{Binding Title}" FontSize="12"
                                                               VerticalAlignment="Center"
                                                               Foreground="{Binding IsSelected, Converter={x:Static vm:TabSelectedFgConverter.Instance}}"/>
                                                <atom:Button Command="{Binding CloseTabCommand}"
                                                             Padding="2,0" FontSize="10"
                                                             Background="Transparent" BorderThickness="0"
                                                             Opacity="0.5">
                                                    <atom:TextBlock Text="✕" FontSize="10"/>
                                                </atom:Button>
                                            </StackPanel>
                                        </Border>
                                    </atom:Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                    <!-- 当前 Tab 的终端内容 -->
                    <views:TerminalView Grid.Row="1"
                                        x:Name="ActiveTerminalView"
                                        DataContext="{Binding SelectedTab.Terminal, x:CompileBindings=False}"/>
                    <Grid Grid.RowSpan="2"
                          IsVisible="{Binding IsTerminalFullScreen}"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Top"
                          Height="44"
                          Background="Transparent"
                          PointerEntered="FullScreenHintArea_OnPointerEntered"
                          PointerExited="FullScreenHintArea_OnPointerExited">
                        <Border Height="3"
                                Width="180"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Top"
                                Background="#64D8FF"
                                BoxShadow="0 0 12 0 #9964D8FF"/>
                        <Border IsVisible="{Binding IsFullScreenHintVisible}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Top"
                                Margin="0,8,0,0"
                                Padding="14,6"
                                CornerRadius="6"
                                Background="#CC1F2933"
                                BorderBrush="#4464D8FF"
                                BorderThickness="1">
                            <atom:TextBlock Text="ESC 返回"
                                            Foreground="White"
                                            FontSize="13"/>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>

            <!-- Col 2: 右侧分割线 + 监控面板（整体隐藏时不占宽度，Terminal 自动扩展） -->
            <StackPanel Grid.Column="2" Orientation="Horizontal"
                        IsVisible="{Binding IsMonitorPanelVisible}">
                <GridSplitter Width="3" HorizontalAlignment="Left"
                              Background="{atom:SharedTokenResource ColorSplit}"/>
                <views:ServerMonitorView DataContext="{Binding Monitor, x:CompileBindings=False}"
                                         Width="280"/>
            </StackPanel>
        <Popup x:Name="QuickSessionContextMenuPopup"
               Placement="Pointer"
               IsLightDismissEnabled="True">
            <Border Background="{atom:SharedTokenResource ColorBgElevated}"
                    BorderBrush="{atom:SharedTokenResource ColorBorder}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="0,4"
                    MinWidth="120">
                <StackPanel Spacing="0">
                    <atom:Button x:Name="QuickSessionPropertiesBtn"
                                 Content="属性"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 HorizontalAlignment="Stretch"
                                 HorizontalContentAlignment="Left"
                                 Padding="16,6"
                                 FontSize="13"
                                 Foreground="{atom:SharedTokenResource ColorText}"/>
                    <Border Height="1" Background="{atom:SharedTokenResource ColorSplit}" Margin="8,4"/>
                    <atom:Button x:Name="QuickSessionDeleteBtn"
                                 Content="删除"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 HorizontalAlignment="Stretch"
                                 HorizontalContentAlignment="Left"
                                 Padding="16,6"
                                 FontSize="13"
                                 Foreground="{atom:SharedTokenResource ColorError}"/>
                </StackPanel>
            </Border>
        </Popup>
        </Grid>


    </DockPanel>
</atom:Window>
