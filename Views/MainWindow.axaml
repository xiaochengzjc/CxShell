<atom:Window xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:atom="https://atomui.net"
             xmlns:vm="using:ChiXueSsh.ViewModels"
             xmlns:views="using:ChiXueSsh.Views"
             x:Class="ChiXueSsh.Views.MainWindow"
             x:DataType="vm:MainWindowViewModel"
             Title="ChiXueSsh - SSH Client"
             Width="1200"
             Height="800"
             MinWidth="600"
             MinHeight="400"
             WindowState="Normal"
             WindowStartupLocation="CenterScreen">

    <!-- AtomUI Token 覆盖（解决闪白 + 标题栏图标颜色） -->
    <atom:Window.Resources>
        <!-- 窗口初始背景 & 系统栏颜色，防止打开时闪白 -->
        <SolidColorBrush x:Key="{x:Static atom:WindowTokenKind.DefaultBackground}"
                         Color="#0D0D0D"/>
        <SolidColorBrush x:Key="{x:Static atom:WindowTokenKind.SystemBarColor}"
                         Color="#0D0D0D"/>
        <!-- 标题栏按钮图标颜色 -->
        <SolidColorBrush x:Key="{x:Static atom:WindowTitleBarTokenKind.ActiveColor}"
                         Color="#E0E0E0"/>
        <SolidColorBrush x:Key="{x:Static atom:WindowTitleBarTokenKind.InactiveColor}"
                         Color="#555555"/>
    </atom:Window.Resources>

    <DockPanel>
        <!-- 工具栏 -->
        <Border DockPanel.Dock="Top" Padding="8,4" Background="#111111">
            <StackPanel Orientation="Horizontal" Spacing="4">
                <atom:Button Command="{Binding NewSessionCommand}"
                             Background="#1A1A1A" BorderThickness="1" BorderBrush="#333333">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <atom:TextBlock Text="+" FontSize="16" FontWeight="Bold" Foreground="#E0E0E0"/>
                        <atom:TextBlock Text="新建会话" Foreground="#E0E0E0"/>
                    </StackPanel>
                </atom:Button>
                <atom:Button Command="{Binding ShowSessionManagerCommand}"
                             Background="#1A1A1A" BorderThickness="1" BorderBrush="#333333">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <atom:TextBlock Text="☰" FontSize="16" Foreground="#E0E0E0"/>
                        <atom:TextBlock Text="会话管理" Foreground="#E0E0E0"/>
                    </StackPanel>
                </atom:Button>
                <Border Width="1" Background="#444444" Margin="8,4" Opacity="0.6"/>
                <atom:Button Command="{Binding ToggleSftpCommand}"
                             Background="#1A1A1A" BorderThickness="1" BorderBrush="#333333">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <atom:TextBlock Text="⇅" FontSize="14" Foreground="#E0E0E0"/>
                        <atom:TextBlock Text="SFTP" Foreground="#E0E0E0"/>
                    </StackPanel>
                </atom:Button>
                <atom:Button Command="{Binding ToggleMonitorCommand}"
                             Background="#1A1A1A" BorderThickness="1" BorderBrush="#333333">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <atom:TextBlock Text="▦" FontSize="14" Foreground="#E0E0E0"/>
                        <atom:TextBlock Text="监控" Foreground="#E0E0E0"/>
                    </StackPanel>
                </atom:Button>
            </StackPanel>
        </Border>

        <!-- 状态栏 -->
        <Border DockPanel.Dock="Bottom" Padding="8,4"
                Background="#111111" BorderBrush="#222222" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" Spacing="16">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Ellipse Width="8" Height="8"
                             Fill="{Binding ConnectionStatusColor}"/>
                    <atom:TextBlock Text="{Binding ConnectionStatusText}" Foreground="#AAAAAA"/>
                </StackPanel>
                <atom:TextBlock Text="{Binding ConnectedHostInfo}" Foreground="#888888" Opacity="0.8"/>
                <atom:TextBlock Text="{Binding TerminalSizeText}" Foreground="#888888" Opacity="0.8"/>
            </StackPanel>
        </Border>

        <!-- 主内容区域 -->
        <Grid ColumnDefinitions="Auto,*,Auto">

            <!-- Col 0: 左侧 SFTP 面板 -->
            <Grid Grid.Column="0" ColumnDefinitions="*,3"
                  IsVisible="{Binding IsSftpVisible}">
                <views:SftpPanelView Grid.Column="0"
                                     DataContext="{Binding Sftp, x:CompileBindings=False}"
                                     Width="300"/>
                <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch"
                              Background="#222222"/>
            </Grid>

            <!-- Col 1: 终端区域 -->
            <Grid Grid.Column="1" Background="#141414">
                <!-- 无标签时显示欢迎页 -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            Spacing="12"
                            IsVisible="{Binding !HasTabs}">
                    <atom:TextBlock Text="ChiXueSsh" FontSize="32" FontWeight="Bold"
                                   HorizontalAlignment="Center" Opacity="0.3" Foreground="#FFFFFF"/>
                    <atom:TextBlock Text="点击「会话管理」选择会话并连接，或点击「新建会话」开始"
                                   HorizontalAlignment="Center" Opacity="0.5" Foreground="#FFFFFF"/>
                    <atom:TextBlock Text="基于 AtomUI 开发"
                                   HorizontalAlignment="Center" Opacity="0.25" Foreground="#FFFFFF"
                                   FontSize="11"/>
                </StackPanel>

                <!-- 有标签时显示多标签布局 -->
                <Grid IsVisible="{Binding HasTabs}" RowDefinitions="Auto,*">
                    <!-- Tab 标题栏 -->
                    <Border Grid.Row="0" Background="#0D0D0D"
                            BorderBrush="#333333" BorderThickness="0,0,0,1">
                        <ItemsControl ItemsSource="{Binding Tabs}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:TerminalTabViewModel">
                                    <atom:Button Background="Transparent" BorderThickness="0"
                                                 Padding="0"
                                                 Command="{Binding $parent[Window].DataContext.SelectTabCommand, x:CompileBindings=False}"
                                                 CommandParameter="{Binding}">
                                        <Border Padding="12,6"
                                                BorderThickness="1,1,1,0"
                                                Margin="2,2,0,0">
                                            <Border.Background>
                                                <SolidColorBrush Color="{Binding IsSelected, Converter={x:Static vm:TabSelectedBgConverter.Instance}}"/>
                                            </Border.Background>
                                            <Border.BorderBrush>
                                                <SolidColorBrush Color="{Binding IsSelected, Converter={x:Static vm:TabSelectedBorderConverter.Instance}}"/>
                                            </Border.BorderBrush>
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <atom:TextBlock Text="{Binding Title}" FontSize="12"
                                                               VerticalAlignment="Center"
                                                               Foreground="{Binding IsSelected, Converter={x:Static vm:TabSelectedFgConverter.Instance}}"/>
                                                <atom:Button Command="{Binding CloseTabCommand}"
                                                             Padding="2,0" FontSize="10"
                                                             Background="Transparent" BorderThickness="0"
                                                             Opacity="0.5">
                                                    <atom:TextBlock Text="✕" FontSize="10" Foreground="#AAAAAA"/>
                                                </atom:Button>
                                            </StackPanel>
                                        </Border>
                                    </atom:Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                    <!-- 当前 Tab 的终端内容 -->
                    <views:TerminalView Grid.Row="1"
                                        x:Name="ActiveTerminalView"
                                        DataContext="{Binding SelectedTab.Terminal, x:CompileBindings=False}"/>
                </Grid>
            </Grid>

            <!-- Col 2: 右侧分割线 + 监控面板（整体隐藏时不占宽度，Terminal 自动扩展） -->
            <StackPanel Grid.Column="2" Orientation="Horizontal"
                        IsVisible="{Binding IsMonitorVisible}">
                <GridSplitter Width="3" HorizontalAlignment="Left" Background="#222222"/>
                <views:ServerMonitorView DataContext="{Binding Monitor, x:CompileBindings=False}"
                                         Width="280"/>
            </StackPanel>
        </Grid>
    </DockPanel>
</atom:Window>
