<atom:Window xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:services="using:CxShell.Services"
             xmlns:atom="https://atomui.net"
             xmlns:antdicons="https://atomui.net/icons/antdesign"
             xmlns:models="using:CxShell.Models"
             xmlns:controls="using:CxShell.Controls"
             xmlns:vm="using:CxShell.ViewModels"
             xmlns:views="using:CxShell.Views"
             x:Class="CxShell.Views.MainWindow"
             x:DataType="vm:MainWindowViewModel"
             Title="CxShell"
             Icon="/Assets/CxShellLogo.png"
             Width="1200"
             Height="800"
             MinWidth="600"
             MinHeight="400"
             WindowState="Normal"
             WindowStartupLocation="CenterScreen">

    <atom:Window.LogoTemplate>
        <DataTemplate>
            <Image Source="/Assets/CxShellLogo.png"/>
        </DataTemplate>
    </atom:Window.LogoTemplate>

    <atom:Window.Styles>
        <Style Selector="atom|Button.quick-session-bar-button">
            <Setter Property="Background" Value="{atom:SharedTokenResource ColorBgLayout}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="atom|Button.quick-session-bar-button:pointerover">
            <Setter Property="Background" Value="{atom:SharedTokenResource ColorFillSecondary}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="atom|Button.quick-session-bar-button:pressed">
            <Setter Property="Background" Value="{atom:SharedTokenResource ColorFill}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="atom|Button.quick-session-bar-button:disabled">
            <Setter Property="Background" Value="{atom:SharedTokenResource ColorBgLayout}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="Button.tab-close-button">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="MinWidth" Value="18"/>
            <Setter Property="MinHeight" Value="18"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Opacity" Value="0.6"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.tab-close-button:pointerover">
            <Setter Property="Background" Value="{atom:SharedTokenResource ColorFillSecondary}"/>
            <Setter Property="Opacity" Value="0.9"/>
        </Style>
        <Style Selector="Button.tab-close-button:pressed">
            <Setter Property="Background" Value="{atom:SharedTokenResource ColorFill}"/>
        </Style>
    </atom:Window.Styles>

    <atom:Window.Resources>
        <DataTemplate x:Key="ArrangedTabPaneTemplate" DataType="vm:TerminalTabGroupViewModel">
            <Border Margin="1"
                    Background="{atom:SharedTokenResource ColorBgLayout}"
                    BorderBrush="{atom:SharedTokenResource ColorSplit}"
                    BorderThickness="1"
                    ClipToBounds="True"
                    PointerPressed="OnTabGroupPanePointerPressed">
                <Grid RowDefinitions="32,*">
                    <Border Grid.Row="0"
                            Background="{atom:SharedTokenResource ColorBgLayout}"
                            BorderBrush="{atom:SharedTokenResource ColorBorder}"
                            BorderThickness="0,0,0,1">
                        <ItemsControl ItemsSource="{Binding Tabs}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:TerminalTabViewModel">
                                    <atom:Button Background="Transparent"
                                                 BorderThickness="0"
                                                 Padding="0"
                                                 Command="{Binding $parent[Window].DataContext.SelectTabCommand, x:CompileBindings=False}"
                                                 CommandParameter="{Binding}">
                                        <Border Padding="10,5"
                                                MinWidth="110"
                                                BorderThickness="1,1,1,0"
                                                Margin="2,2,0,0"
                                                PointerPressed="OnTabHeaderPointerPressed"
                                                Background="{Binding TabBackgroundBrush}">
                                            <Border.BorderBrush>
                                                <SolidColorBrush Color="{Binding IsSelected, Converter={x:Static vm:TabSelectedBorderConverter.Instance}}"/>
                                            </Border.BorderBrush>
                                            <DockPanel LastChildFill="True">
                                                <Button DockPanel.Dock="Right"
                                                        Classes="tab-close-button"
                                                        Command="{Binding CloseTabCommand}">
                                                    <Grid Width="10"
                                                          Height="10"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center">
                                                        <Path Data="M 2,2 L 8,8 M 8,2 L 2,8"
                                                              Stroke="{atom:SharedTokenResource ColorTextSecondary}"
                                                              StrokeThickness="1.4"
                                                              StrokeLineCap="Round"/>
                                                    </Grid>
                                                </Button>
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <Ellipse Width="8"
                                                             Height="8"
                                                             Fill="{Binding ConnectionIndicatorBrush}"
                                                             VerticalAlignment="Center"
                                                             atom:ToolTip.Tip="{Binding ConnectionIndicatorText}"/>
                                                    <atom:TextBlock Text="{Binding Title}"
                                                                    FontSize="12"
                                                                    MaxWidth="180"
                                                                    VerticalAlignment="Center"
                                                                    TextTrimming="CharacterEllipsis"
                                                                    Foreground="{Binding IsSelected, Converter={x:Static vm:TabSelectedFgConverter.Instance}}"/>
                                                </StackPanel>
                                            </DockPanel>
                                        </Border>
                                    </atom:Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                    <Grid Grid.Row="1" Background="#141414">
                        <Grid IsVisible="{Binding IsSelectedTerminalSession}">
                            <views:TerminalView DataContext="{Binding SelectedTab.Terminal, x:CompileBindings=False}"/>
                        </Grid>
                        <Grid IsVisible="{Binding IsSelectedVncSession}">
                            <views:VncView DataContext="{Binding SelectedTab.Vnc, x:CompileBindings=False}"/>
                        </Grid>
                        <Grid IsVisible="{Binding IsSelectedRdpSession}">
                            <views:RdpView DataContext="{Binding SelectedTab.Rdp, x:CompileBindings=False}"/>
                        </Grid>
                        <Grid IsVisible="{Binding IsSelectedFileTransferSession}">
                            <views:SftpPanelView DataContext="{Binding SelectedTab.FileTransfer, x:CompileBindings=False}"/>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>
    </atom:Window.Resources>



    <Grid RowDefinitions="Auto,Auto,*,Auto">
        <!-- 工具栏 -->
        <Border Grid.Row="0" Padding="8,4"
                IsVisible="{Binding IsMainChromeVisible}"
                Background="{atom:SharedTokenResource ColorBgContainer}">
            <StackPanel Orientation="Horizontal" Spacing="4">
                <atom:Button Command="{Binding NewSessionCommand}"
                             ButtonType="Default"
                             atom:ToolTip.Tip="{Binding NewSessionToolTip}"
                             atom:ToolTip.Placement="Bottom">
                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <atom:TextBlock Text="+" FontSize="16" FontWeight="Bold" Width="18"
                                        TextAlignment="Center" VerticalAlignment="Center"/>
                        <atom:TextBlock Text="{Binding NewSessionText}" VerticalAlignment="Center"/>
                    </StackPanel>
                </atom:Button>
                <atom:Button Command="{Binding ShowSessionManagerCommand}"
                             ButtonType="Default"
                             atom:ToolTip.Tip="{Binding SessionManagerToolTip}"
                             atom:ToolTip.Placement="Bottom">
                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <atom:TextBlock Text="☰" FontSize="16" Width="18"
                                        TextAlignment="Center" VerticalAlignment="Center"/>
                        <atom:TextBlock Text="{Binding SessionManagerText}" VerticalAlignment="Center"/>
                    </StackPanel>
                </atom:Button>
                <Border Width="1" Background="{atom:SharedTokenResource ColorSplit}" Margin="8,4" Opacity="0.6"/>
                <atom:Button Command="{Binding CurrentConnectCommand}"
                             ButtonType="Default"
                             atom:ToolTip.Tip="{Binding ConnectToolTip}"
                             atom:ToolTip.Placement="Bottom">
                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <atom:TextBlock Text="▶" FontSize="12" Width="18"
                                        TextAlignment="Center" VerticalAlignment="Center"/>
                        <atom:TextBlock Text="{Binding ConnectText}" VerticalAlignment="Center"/>
                    </StackPanel>
                </atom:Button>
                <atom:Button Command="{Binding CurrentDisconnectCommand}"
                             ButtonType="Default"
                             atom:ToolTip.Tip="{Binding DisconnectToolTip}"
                             atom:ToolTip.Placement="Bottom">
                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <atom:TextBlock Text="■" FontSize="11" Width="18"
                                        TextAlignment="Center" VerticalAlignment="Center"/>
                        <atom:TextBlock Text="{Binding DisconnectText}" VerticalAlignment="Center"/>
                    </StackPanel>
                </atom:Button>
                <Border Width="1" Background="{atom:SharedTokenResource ColorSplit}" Margin="8,4" Opacity="0.6"/>
                <atom:Button Command="{Binding ToggleSftpCommand}"
                             ButtonType="Default"
                             atom:ToolTip.Tip="{Binding SftpToolTip}"
                             atom:ToolTip.Placement="Bottom">
                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <atom:TextBlock Text="⇅" FontSize="14" Width="18"
                                        TextAlignment="Center" VerticalAlignment="Center"/>
                        <atom:TextBlock Text="SFTP" VerticalAlignment="Center"/>
                    </StackPanel>
                </atom:Button>
                <atom:Button Command="{Binding ToggleMonitorCommand}"
                             ButtonType="Default"
                             atom:ToolTip.Tip="{Binding MonitorToolTip}"
                             atom:ToolTip.Placement="Bottom">
                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <atom:TextBlock Text="▦" FontSize="14" Width="18"
                                        TextAlignment="Center" VerticalAlignment="Center"/>
                        <atom:TextBlock Text="{Binding MonitorText}" VerticalAlignment="Center"/>
                    </StackPanel>
                </atom:Button>
                <!-- 主题切换 -->
                <Border Width="1" Background="{atom:SharedTokenResource ColorSplit}" Margin="8,4" Opacity="0.6"/>
                <atom:Button ButtonType="Default" Command="{Binding ToggleThemeCommand}"
                             atom:ToolTip.Tip="{Binding ThemeToolTip}"
                             atom:ToolTip.Placement="Bottom">
                    <atom:TextBlock Text="{Binding ThemeIcon}" FontSize="14"
                                    TextAlignment="Center" VerticalAlignment="Center"/>
                </atom:Button>
                <atom:Button ButtonType="Default" Command="{Binding ToggleTerminalFullScreenCommand}"
                             atom:ToolTip.Tip="{Binding FullScreenToolTip}"
                             atom:ToolTip.Placement="Bottom">
                    <atom:TextBlock Text="⛶"
                                    FontSize="14"
                                    Width="18"
                                    TextAlignment="Center"
                                    VerticalAlignment="Center"/>
                </atom:Button>
                <atom:Button x:Name="TabArrangeButton"
                             ButtonType="Default"
                             Icon="{antdicons:AntDesignIconProvider Kind=LayoutOutlined}"
                             Click="OnTabArrangeButtonClick"
                             atom:ToolTip.Tip="{Binding ArrangeToolTip}"
                             atom:ToolTip.Placement="Bottom">
                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <atom:TextBlock Text="{Binding ArrangeText}" VerticalAlignment="Center"/>
                        <atom:TextBlock Text="▾" FontSize="10" VerticalAlignment="Center" Opacity="0.75"/>
                    </StackPanel>
                </atom:Button>
                <atom:Button x:Name="LanguageButton"
                             ButtonType="Default"
                             Click="OnLanguageButtonClick"
                             atom:ToolTip.Tip="{Binding LanguageToolTip}"
                             atom:ToolTip.Placement="Bottom">
                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <atom:TextBlock Text="{Binding LanguageIcon}"
                                        FontSize="12"
                                        FontWeight="Bold"
                                        MinWidth="18"
                                        TextAlignment="Center"
                                        VerticalAlignment="Center"/>
                        <atom:TextBlock Text="▾" FontSize="10" VerticalAlignment="Center" Opacity="0.75"/>
                    </StackPanel>
                </atom:Button>
                <atom:Popup x:Name="LanguagePopup"
                            Placement="Bottom"
                            IsLightDismissEnabled="True">
                    <Border Background="{atom:SharedTokenResource ColorBgElevated}"
                            BorderBrush="{atom:SharedTokenResource ColorBorder}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="0,4"
                            MinWidth="120">
                        <StackPanel Spacing="0">
                            <atom:Button Content="{Binding ChineseLanguageText}"
                                         Command="{Binding SetLanguageCommand}"
                                         CommandParameter="zh-CN"
                                         Click="OnLanguageMenuItemClick"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         HorizontalAlignment="Stretch"
                                         HorizontalContentAlignment="Left"
                                         Padding="16,7"
                                         FontSize="13"/>
                            <atom:Button Content="{Binding EnglishLanguageText}"
                                         Command="{Binding SetLanguageCommand}"
                                         CommandParameter="en-US"
                                         Click="OnLanguageMenuItemClick"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         HorizontalAlignment="Stretch"
                                         HorizontalContentAlignment="Left"
                                         Padding="16,7"
                                         FontSize="13"/>
                        </StackPanel>
                    </Border>
                </atom:Popup>
                <atom:Popup x:Name="TabArrangePopup"
                            Placement="Bottom"
                            IsLightDismissEnabled="True">
                    <Border Background="{atom:SharedTokenResource ColorBgElevated}"
                            BorderBrush="{atom:SharedTokenResource ColorBorder}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="0,4"
                            MinWidth="170">
                        <StackPanel Spacing="0">
                            <atom:Button Content="{Binding ArrangeVerticalText}"
                                         Command="{Binding ArrangeTabsVerticalCommand}"
                                         Click="OnTabArrangeMenuItemClick"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         HorizontalAlignment="Stretch"
                                         HorizontalContentAlignment="Left"
                                         Padding="16,7"
                                         FontSize="13"/>
                            <atom:Button Content="{Binding ArrangeHorizontalText}"
                                         Command="{Binding ArrangeTabsHorizontalCommand}"
                                         Click="OnTabArrangeMenuItemClick"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         HorizontalAlignment="Stretch"
                                         HorizontalContentAlignment="Left"
                                         Padding="16,7"
                                         FontSize="13"/>
                            <atom:Button Content="{Binding ArrangeTileText}"
                                         Command="{Binding ArrangeTabsTileCommand}"
                                         Click="OnTabArrangeMenuItemClick"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         HorizontalAlignment="Stretch"
                                         HorizontalContentAlignment="Left"
                                         Padding="16,7"
                                         FontSize="13"/>
                            <Border Height="1" Background="{atom:SharedTokenResource ColorSplit}" Margin="8,4"/>
                            <atom:Button Content="{Binding ArrangeMergeText}"
                                         Command="{Binding MergeTabGroupsCommand}"
                                         Click="OnTabArrangeMenuItemClick"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         HorizontalAlignment="Stretch"
                                         HorizontalContentAlignment="Left"
                                         Padding="16,7"
                                         FontSize="13"/>
                        </StackPanel>
                    </Border>
                </atom:Popup>
            </StackPanel>
        </Border>

        <!-- 状态栏 -->
        <Border Grid.Row="1"
                Height="44"
                Padding="8,5"
                ClipToBounds="False"
                IsVisible="{Binding IsMainChromeVisible}"
                Background="{atom:SharedTokenResource ColorBgLayout}"
                BorderBrush="{atom:SharedTokenResource ColorSplit}"
                BorderThickness="0,1,0,1">
            <DockPanel LastChildFill="True"
                       ClipToBounds="False"
                       VerticalAlignment="Center">
                <atom:Button DockPanel.Dock="Left"
                             Classes="quick-session-bar-button"
                              Width="32"
                              Height="32"
                              Padding="0"
                              ButtonType="Default"
                              Shape="Default"
                              SizeType="Small"
                              Icon="{antdicons:AntDesignIconProvider PlusOutlined}"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             HorizontalContentAlignment="Center"
                             VerticalContentAlignment="Center"
                             Command="{Binding AddCurrentSessionToQuickBarCommand}"
                             atom:ToolTip.Tip="{Binding AddQuickSessionToolTip}"
                             atom:ToolTip.Placement="Bottom"/>
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled"
                              Height="34"
                              Margin="6,0,0,0"
                              ClipToBounds="False"
                              VerticalAlignment="Center">
                    <ItemsControl ItemsSource="{Binding QuickSessions}"
                                  Height="34"
                                  ClipToBounds="False"
                                  VerticalAlignment="Center">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="models:SessionInfo">
                                <atom:Button ButtonType="Default"
                                             Classes="quick-session-bar-button"
                                             SizeType="Middle"
                                             Height="30"
                                             MinHeight="30"
                                             Icon="{antdicons:AntDesignIconProvider CloudServerOutlined}"
                                             Content="{Binding Name}"
                                             Padding="10,0"
                                             Margin="0,2,4,2"
                                             Cursor="Hand"
                                             VerticalAlignment="Center"
                                             HorizontalContentAlignment="Center"
                                             VerticalContentAlignment="Center"
                                             Command="{Binding $parent[Window].DataContext.ConnectQuickSessionCommand, x:CompileBindings=False}"
                                             CommandParameter="{Binding}"
                                             PointerPressed="OnQuickSessionTagPointerPressed"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <Border Grid.Row="3" Padding="8,4"
                IsVisible="{Binding IsMainChromeVisible}"
                Background="{atom:SharedTokenResource ColorBgContainer}"
                BorderBrush="{atom:SharedTokenResource ColorSplit}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" Spacing="16">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Ellipse Width="8" Height="8"
                             Fill="{Binding ConnectionStatusColor}"/>
                    <atom:TextBlock Text="{Binding ConnectionStatusText}"/>
                </StackPanel>
                <atom:TextBlock Text="{Binding ConnectedHostInfo}" Opacity="0.8"/>
                <atom:TextBlock Text="{Binding TerminalSizeText}" Opacity="0.8"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid x:Name="MainContentGrid">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0"/>
                    <ColumnDefinition Width="{Binding SftpSplitterWidth}"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Col 0: 左侧 SFTP 面板 -->
                <Border Grid.Column="0"
                        x:Name="SftpPanelHost"
                        IsVisible="{Binding IsSftpPanelVisible}"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Stretch"
                        ClipToBounds="True">
                    <views:SftpPanelView DataContext="{Binding Sftp, x:CompileBindings=False}"/>
                </Border>
                <Border Grid.Column="1"
                        x:Name="SftpSplitterHandle"
                        IsVisible="{Binding IsSftpPanelVisible}"
                        HorizontalAlignment="Stretch"
                        Background="Transparent"
                        Cursor="SizeWestEast"
                        PointerPressed="OnSftpSplitterPointerPressed"
                        PointerMoved="OnSftpSplitterPointerMoved"
                        PointerReleased="OnSftpSplitterPointerReleased">
                    <Border Width="1"
                            HorizontalAlignment="Center"
                            Background="{atom:SharedTokenResource ColorSplit}"/>
                </Border>

                <!-- Col 1: 终端区域（始终深色）-->
                <Grid Grid.Column="2" Background="#141414">
                    <!-- 无标签时显示欢迎页 -->
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                Spacing="12"
                                IsVisible="{Binding !HasTabs}">
                        <atom:TextBlock Text="CxShell" FontSize="32" FontWeight="Bold"
                                       HorizontalAlignment="Center" Opacity="0.3"
                                       Foreground="{atom:SharedTokenResource ColorTextLightSolid}"/>
                        <atom:TextBlock Text="{Binding WelcomeSelectSessionText}"
                                       HorizontalAlignment="Center" Opacity="0.5"
                                       Foreground="{atom:SharedTokenResource ColorTextLightSolid}"/>
                        <atom:TextBlock Text="{Binding WelcomeBuiltWithAtomUiText}"
                                       HorizontalAlignment="Center" Opacity="0.25"
                                       Foreground="{atom:SharedTokenResource ColorTextLightSolid}"
                                       FontSize="11"/>
                    </StackPanel>

                    <!-- 有标签时显示多标签布局 -->
                    <Grid IsVisible="{Binding HasTabs}" RowDefinitions="Auto,*">
                        <!-- Tab 标题栏 -->
                        <Border Grid.Row="0"
                                IsVisible="{Binding IsMainTabHeaderVisible}"
                                Background="{atom:SharedTokenResource ColorBgLayout}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}" BorderThickness="0,0,0,1">
                            <ItemsControl ItemsSource="{Binding Tabs}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="vm:TerminalTabViewModel">
                                        <atom:Button Background="Transparent" BorderThickness="0"
                                                     Padding="0"
                                                     Command="{Binding $parent[Window].DataContext.SelectTabCommand, x:CompileBindings=False}"
                                                     CommandParameter="{Binding}">
                                            <Border Padding="12,6"
                                                    BorderThickness="1,1,1,0"
                                                    Margin="2,2,0,0"
                                                    PointerPressed="OnTabHeaderPointerPressed"
                                                    Background="{Binding TabBackgroundBrush}">
                                                <Border.BorderBrush>
                                                    <SolidColorBrush Color="{Binding IsSelected, Converter={x:Static vm:TabSelectedBorderConverter.Instance}}"/>
                                                 </Border.BorderBrush>
                                                 <StackPanel Orientation="Horizontal" Spacing="6">
                                                     <Ellipse Width="8"
                                                              Height="8"
                                                              Fill="{Binding ConnectionIndicatorBrush}"
                                                              VerticalAlignment="Center"
                                                              atom:ToolTip.Tip="{Binding ConnectionIndicatorText}"/>
                                                     <atom:TextBlock Text="{Binding Title}" FontSize="12"
                                                                    VerticalAlignment="Center"
                                                                    Foreground="{Binding IsSelected, Converter={x:Static vm:TabSelectedFgConverter.Instance}}"/>
                                                    <Button Classes="tab-close-button"
                                                            Command="{Binding CloseTabCommand}"
                                                            Margin="2,0,0,0">
                                                        <Grid Width="10"
                                                              Height="10"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center">
                                                            <Path Data="M 2,2 L 8,8 M 8,2 L 2,8"
                                                                  Stroke="{atom:SharedTokenResource ColorTextSecondary}"
                                                                  StrokeThickness="1.4"
                                                                  StrokeLineCap="Round"/>
                                                        </Grid>
                                                    </Button>
                                                </StackPanel>
                                            </Border>
                                        </atom:Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                        <!-- 当前 Tab 的终端内容 -->
                        <Grid Grid.Row="1"
                              IsVisible="{Binding IsSingleTabContentVisible}">
                            <views:TerminalView x:Name="ActiveTerminalView"
                                                DataContext="{Binding SelectedTab.Terminal, x:CompileBindings=False}"
                                                IsVisible="{Binding $parent[Window].DataContext.IsSelectedTerminalSession, x:CompileBindings=False}"/>
                            <views:VncView DataContext="{Binding SelectedTab.Vnc, x:CompileBindings=False}"
                                           IsVisible="{Binding $parent[Window].DataContext.IsSelectedVncSession, x:CompileBindings=False}"/>
                            <views:RdpView DataContext="{Binding SelectedTab.Rdp, x:CompileBindings=False}"
                                           IsVisible="{Binding $parent[Window].DataContext.IsSelectedRdpSession, x:CompileBindings=False}"/>
                            <views:SftpPanelView DataContext="{Binding SelectedTab.FileTransfer, x:CompileBindings=False}"
                                                 IsVisible="{Binding $parent[Window].DataContext.IsSelectedFileTransferSession, x:CompileBindings=False}"/>
                        </Grid>

                        <!-- 多标签排列内容 -->
                        <Grid Grid.Row="1"
                              Background="{atom:SharedTokenResource ColorBgLayout}"
                              IsVisible="{Binding IsArrangedTabsVisible}">
                            <ItemsControl ItemsSource="{Binding TabGroups}"
                                          ItemTemplate="{StaticResource ArrangedTabPaneTemplate}"
                                          IsVisible="{Binding IsVerticalTabArrangement}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <controls:ResizableStackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>

                            <ItemsControl ItemsSource="{Binding TabGroups}"
                                          ItemTemplate="{StaticResource ArrangedTabPaneTemplate}"
                                          IsVisible="{Binding IsHorizontalTabArrangement}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <controls:ResizableStackPanel Orientation="Vertical"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>

                            <ItemsControl ItemsSource="{Binding TileRows}"
                                          IsVisible="{Binding IsTileTabArrangement}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <controls:ResizableStackPanel Orientation="Vertical"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="vm:TileTabGroupRowViewModel">
                                        <ItemsControl ItemsSource="{Binding Groups}"
                                                      ItemTemplate="{StaticResource ArrangedTabPaneTemplate}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <controls:ResizableStackPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                        <Grid Grid.RowSpan="2"
                              IsVisible="{Binding IsTerminalFullScreen}"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Top"
                              Height="44"
                              Background="Transparent"
                              PointerEntered="FullScreenHintArea_OnPointerEntered"
                              PointerExited="FullScreenHintArea_OnPointerExited">
                            <Border Height="3"
                                    Width="180"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Top"
                                    Background="#64D8FF"
                                    BoxShadow="0 0 12 0 #9964D8FF"/>
                            <Border IsVisible="{Binding IsFullScreenHintVisible}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Top"
                                    Margin="0,8,0,0"
                                    Padding="14,6"
                                    CornerRadius="6"
                                    Background="#CC1F2933"
                                    BorderBrush="#4464D8FF"
                                    BorderThickness="1">
                                <atom:TextBlock Text="{Binding FullScreenEscBackText}"
                                                Foreground="White"
                                                FontSize="13"/>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>

                <!-- Col 2: 右侧分割线 + 监控面板（整体隐藏时不占宽度，Terminal 自动扩展） -->
                <StackPanel Grid.Column="3" Orientation="Horizontal"
                            IsVisible="{Binding IsMonitorPanelVisible}">
                    <GridSplitter Width="3" HorizontalAlignment="Left"
                                  Background="{atom:SharedTokenResource ColorSplit}"/>
                    <views:ServerMonitorView DataContext="{Binding Monitor, x:CompileBindings=False}"
                                             Width="280"/>
                </StackPanel>
            </Grid>

        </Grid>
    </Grid>
</atom:Window>
