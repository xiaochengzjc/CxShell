                <ScrollViewer x:Name="LoggingPage"
                              IsVisible="{Binding IsLoggingPage}"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="16">
                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Margin="0,0,18,0"
                                Padding="18">
                            <Grid ColumnDefinitions="150,*,48"
                                  RowDefinitions="Auto,14,Auto,12,Auto,12,Auto,12,Auto,12,Auto,12,Auto,12,Auto"
                                  ColumnSpacing="8">
                                <TextBlock Grid.ColumnSpan="3"
                                           Text="{Binding [UiText.215], Source={x:Static services:LocalizationService.Shared}}"
                                           FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="2"
                                           Text="{Binding [UiText.216], Source={x:Static services:LocalizationService.Shared}}"
                                           VerticalAlignment="Center"/>
                                <atom:LineEdit Grid.Row="2"
                                               Grid.Column="1"
                                               Text="{Binding AdvancedLogFilePath, Mode=TwoWay}"/>
                                <atom:Button Grid.Row="2"
                                             Grid.Column="2"
                                             Content="..."
                                             Width="48"
                                             MinWidth="48"
                                             HorizontalContentAlignment="Center"
                                             Click="OnBrowseAdvancedLogFileClick"/>
                                <atom:CheckBox Grid.Row="4"
                                               Grid.ColumnSpan="3"
                                               Content="{Binding [UiText.217], Source={x:Static services:LocalizationService.Shared}}"
                                               IsChecked="{Binding AdvancedLogOverwriteExisting, Mode=TwoWay}"/>
                                <atom:CheckBox Grid.Row="6"
                                               Grid.ColumnSpan="3"
                                               Content="{Binding [UiText.218], Source={x:Static services:LocalizationService.Shared}}"
                                               IsChecked="{Binding AdvancedLogStartOnConnect, Mode=TwoWay}"/>
                                <atom:CheckBox Grid.Row="8"
                                               Grid.ColumnSpan="3"
                                               Margin="28,0,0,0"
                                               Content="{Binding [UiText.219], Source={x:Static services:LocalizationService.Shared}}"
                                               IsEnabled="{Binding IsAdvancedLogPromptFileOnStartEnabled}"
                                               IsChecked="{Binding AdvancedLogPromptFileOnStart, Mode=TwoWay}"/>
                                <atom:CheckBox Grid.Row="10"
                                               Grid.ColumnSpan="3"
                                               Content="{Binding [UiText.220], Source={x:Static services:LocalizationService.Shared}}"
                                               IsChecked="{Binding AdvancedLogUseRtf, Mode=TwoWay}"/>
                                <atom:CheckBox Grid.Row="12"
                                               Grid.ColumnSpan="3"
                                               Content="{Binding [UiText.221], Source={x:Static services:LocalizationService.Shared}}"
                                               IsChecked="{Binding AdvancedLogIncludeTerminalCodes, Mode=TwoWay}"/>
                                <TextBlock Grid.Row="14"
                                           Text="{Binding [UiText.107], Source={x:Static services:LocalizationService.Shared}}"
                                           VerticalAlignment="Center"/>
                                <atom:Select Grid.Row="14"
                                             Grid.Column="1"
                                             x:Name="SessionLogEncodingSelect"
                                             Width="260"
                                             HorizontalAlignment="Left"
                                             OptionsSource="{Binding LogEncodingOptions}"
                                             Mode="Single"/>
                            </Grid>
                        </Border>

                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Margin="0,0,18,0"
                                Padding="18">
                            <Grid ColumnDefinitions="150,*"
                                  RowDefinitions="Auto,14,Auto,12,Auto,12,Auto"
                                  ColumnSpacing="8">
                                <TextBlock Grid.ColumnSpan="2"
                                           Text="{Binding [UiText.222], Source={x:Static services:LocalizationService.Shared}}"
                                           FontWeight="SemiBold"/>
                                <atom:CheckBox Grid.Row="2"
                                               Grid.ColumnSpan="2"
                                               Content="{Binding [UiText.223], Source={x:Static services:LocalizationService.Shared}}"
                                               IsChecked="{Binding AdvancedLogWriteTimestamp, Mode=TwoWay}"/>
                                <TextBlock Grid.Row="4"
                                           Text="{Binding [UiText.224], Source={x:Static services:LocalizationService.Shared}}"
                                           Margin="28,0,0,0"
                                           VerticalAlignment="Center"
                                           IsEnabled="{Binding IsAdvancedLogTimestampSettingsEnabled}"/>
                                <atom:LineEdit Grid.Row="4"
                                               Grid.Column="1"
                                               IsEnabled="{Binding IsAdvancedLogTimestampSettingsEnabled}"
                                               Text="{Binding AdvancedLogTimestampFormat, Mode=TwoWay}"/>
                                <TextBlock Grid.Row="6"
                                           Text="{Binding [UiText.225], Source={x:Static services:LocalizationService.Shared}}"
                                           Margin="28,0,0,0"
                                           VerticalAlignment="Center"
                                           IsEnabled="{Binding IsAdvancedLogTimestampSettingsEnabled}"/>
                                <atom:LineEdit Grid.Row="6"
                                               Grid.Column="1"
                                               IsReadOnly="True"
                                               IsEnabled="{Binding IsAdvancedLogTimestampSettingsEnabled}"
                                               Text="{Binding AdvancedLogTimestampPreview}"/>
                            </Grid>
                        </Border>

                        <Border BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                Margin="0,12,18,0"
                                Padding="16,12">
                            <TextBlock Text="{Binding [UiText.226], Source={x:Static services:LocalizationService.Shared}}"
                                       TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="BellPage"
                              IsVisible="{Binding IsBellPage}"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="16">
                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Margin="0,0,18,0"
                                Padding="18">
                            <Grid ColumnDefinitions="20,*,48"
                                  RowDefinitions="Auto,12,Auto,12,Auto,12,Auto,12,Auto,20,Auto,12,Auto"
                                  ColumnSpacing="8">
                                <TextBlock Grid.ColumnSpan="3"
                                           Text="{Binding [UiText.064], Source={x:Static services:LocalizationService.Shared}}"
                                           FontWeight="SemiBold"/>
                                <atom:RadioButton Grid.Row="2"
                                                  Grid.ColumnSpan="3"
                                                  Content="{Binding [UiText.227], Source={x:Static services:LocalizationService.Shared}}"
                                                  GroupName="SessionBellMode"
                                                  IsChecked="{Binding IsAdvancedBellModeNone, Mode=TwoWay}"/>
                                <atom:RadioButton Grid.Row="4"
                                                  Grid.ColumnSpan="3"
                                                  Content="{Binding [UiText.228], Source={x:Static services:LocalizationService.Shared}}"
                                                  GroupName="SessionBellMode"
                                                  IsChecked="{Binding IsAdvancedBellModeDefault, Mode=TwoWay}"/>
                                <atom:RadioButton Grid.Row="6"
                                                  Grid.ColumnSpan="3"
                                                  Content="{Binding [UiText.229], Source={x:Static services:LocalizationService.Shared}}"
                                                  GroupName="SessionBellMode"
                                                  IsChecked="{Binding IsAdvancedBellModeBuiltin, Mode=TwoWay}"/>
                                <atom:RadioButton Grid.Row="8"
                                                  Grid.ColumnSpan="3"
                                                  Content="{Binding [UiText.230], Source={x:Static services:LocalizationService.Shared}}"
                                                  GroupName="SessionBellMode"
                                                  IsChecked="{Binding IsAdvancedBellModeSound, Mode=TwoWay}"/>
                                <atom:LineEdit Grid.Row="10"
                                               Grid.Column="1"
                                               IsEnabled="{Binding IsAdvancedBellSoundPathEnabled}"
                                               Text="{Binding AdvancedBellSoundPath, Mode=TwoWay}"/>
                                <atom:Button Grid.Row="10"
                                             Grid.Column="2"
                                             Content="..."
                                             Width="48"
                                             MinWidth="48"
                                             HorizontalContentAlignment="Center"
                                             IsEnabled="{Binding IsAdvancedBellSoundPathEnabled}"
                                             Click="OnBrowseAdvancedBellSoundClick"/>
                                <atom:CheckBox Grid.Row="12"
                                               Grid.ColumnSpan="3"
                                               Content="{Binding [UiText.231], Source={x:Static services:LocalizationService.Shared}}"
                                               IsEnabled="{Binding IsAdvancedBellFlashInactiveWindowEnabled}"
                                               IsChecked="{Binding AdvancedBellFlashInactiveWindow, Mode=TwoWay}"/>
                            </Grid>
                        </Border>

                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Margin="0,0,18,0"
                                Padding="18">
                            <Grid ColumnDefinitions="*"
                                  RowDefinitions="Auto,14,Auto,12,Auto,24,Auto,12,Auto"
                                  ColumnSpacing="8">
                                <TextBlock Text="{Binding [UiText.232], Source={x:Static services:LocalizationService.Shared}}"
                                           FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="2"
                                           Text="{Binding [UiText.233], Source={x:Static services:LocalizationService.Shared}}"/>
                                <StackPanel Grid.Row="4"
                                            Orientation="Horizontal"
                                            Spacing="10">
                                    <atom:NumericUpDown Width="118"
                                                        Minimum="1"
                                                        Maximum="3600"
                                                        Value="{Binding AdvancedBellIgnoreRepeatedSeconds, Mode=TwoWay}"/>
                                    <TextBlock Text="{Binding [UiText.234], Source={x:Static services:LocalizationService.Shared}}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Grid.Row="6"
                                           Text="{Binding [UiText.235], Source={x:Static services:LocalizationService.Shared}}"/>
                                <StackPanel Grid.Row="8"
                                            Orientation="Horizontal"
                                            Spacing="10">
                                    <atom:NumericUpDown Width="118"
                                                        Minimum="1"
                                                        Maximum="3600"
                                                        Value="{Binding AdvancedBellReactivateAfterSeconds, Mode=TwoWay}"/>
                                    <TextBlock Text="{Binding [UiText.234], Source={x:Static services:LocalizationService.Shared}}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="AdvancedPage"
                              IsVisible="{Binding IsAdvancedPage}"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="16">
                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Margin="0,0,18,0"
                                Padding="18">
                            <StackPanel Spacing="14">
                                <TextBlock Text="{Binding [UiText.236], Source={x:Static services:LocalizationService.Shared}}" FontWeight="SemiBold"/>
                                <Grid ColumnDefinitions="*,18,196"
                                      ColumnSpacing="0">
                                    <atom:LineEdit Text="{Binding AdvancedQuickCommandSet, Mode=TwoWay}"/>
                                    <atom:Button Grid.Column="2"
                                                 Content="{Binding [UiText.069], Source={x:Static services:LocalizationService.Shared}}"
                                                 Click="OnBrowseQuickCommandSetClick"/>
                                </Grid>
                                <atom:CheckBox Content="{Binding [UiText.237], Source={x:Static services:LocalizationService.Shared}}"
                                               IsChecked="{Binding AdvancedDisableQuickCommandShortcuts, Mode=TwoWay}"/>
                            </StackPanel>
                        </Border>

                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Margin="0,0,18,0"
                                Padding="18">
                            <StackPanel Spacing="14">
                                <TextBlock Text="{Binding [UiText.238], Source={x:Static services:LocalizationService.Shared}}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding [UiText.239], Source={x:Static services:LocalizationService.Shared}}"/>
                                <StackPanel Orientation="Horizontal" Spacing="24">
                                    <atom:NumericUpDown Width="138"
                                                        Minimum="1"
                                                        Maximum="65535"
                                                        Value="{Binding AdvancedFtpPort, Mode=TwoWay}"/>
                                    <atom:Button Width="136"
                                                 Content="{Binding [UiText.240], Source={x:Static services:LocalizationService.Shared}}"
                                                 Click="OnResetAdvancedFtpPortClick"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Margin="0,0,18,0"
                                Padding="18">
                            <Grid ColumnDefinitions="170,104,56,120,160,*"
                                  RowDefinitions="Auto,14,Auto,14,Auto,12,Auto,12,Auto,12,Auto"
                                  ColumnSpacing="8">
                                <TextBlock Grid.ColumnSpan="6"
                                           Text="{Binding [UiText.241], Source={x:Static services:LocalizationService.Shared}}"
                                           FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="2"
                                           Grid.ColumnSpan="6"
                                           Text="{Binding [UiText.242], Source={x:Static services:LocalizationService.Shared}}"/>
                                <TextBlock Grid.Row="4"
                                           Text="{Binding [UiText.243], Source={x:Static services:LocalizationService.Shared}}"
                                           VerticalAlignment="Center"/>
                                <atom:NumericUpDown Grid.Row="4"
                                                    Grid.Column="1"
                                                    Minimum="0"
                                                    Maximum="60000"
                                                    Value="{Binding AdvancedCharacterDelayMilliseconds, Mode=TwoWay}"/>
                                <TextBlock Grid.Row="4"
                                           Grid.Column="2"
                                           Text="{Binding [UiText.244], Source={x:Static services:LocalizationService.Shared}}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="6"
                                           Grid.ColumnSpan="6"
                                           Text="{Binding [UiText.245], Source={x:Static services:LocalizationService.Shared}}"/>
                                <atom:RadioButton Grid.Row="8"
                                                  Content="{Binding [UiText.246], Source={x:Static services:LocalizationService.Shared}}"
                                                  GroupName="AdvancedDelayMode"
                                                  IsChecked="{Binding AdvancedUseLineDelay, Mode=TwoWay}"/>
                                <atom:NumericUpDown Grid.Row="8"
                                                    Grid.Column="1"
                                                    Minimum="0"
                                                    Maximum="60000"
                                                    IsEnabled="{Binding IsAdvancedLineDelay}"
                                                    Value="{Binding AdvancedLineDelayMilliseconds, Mode=TwoWay}"/>
                                <TextBlock Grid.Row="8"
                                           Grid.Column="2"
                                           Text="{Binding [UiText.244], Source={x:Static services:LocalizationService.Shared}}"
                                           VerticalAlignment="Center"/>
                                <atom:RadioButton Grid.Row="10"
                                                  Content="{Binding [UiText.247], Source={x:Static services:LocalizationService.Shared}}"
                                                  GroupName="AdvancedDelayMode"
                                                  IsChecked="{Binding AdvancedUsePromptDelay, Mode=TwoWay}"/>
                                <atom:LineEdit Grid.Row="10"
                                               Grid.Column="1"
                                               Grid.ColumnSpan="2"
                                               IsEnabled="{Binding IsAdvancedPromptDelay}"
                                               Text="{Binding AdvancedPromptText, Mode=TwoWay}"/>
                                <StackPanel Grid.Row="10"
                                            Grid.Column="3"
                                            Grid.ColumnSpan="3"
                                            Orientation="Horizontal"
                                            Spacing="6"
                                            IsEnabled="{Binding IsAdvancedPromptDelay}">
                                    <TextBlock Text="{Binding [UiText.248], Source={x:Static services:LocalizationService.Shared}}"
                                               VerticalAlignment="Center"/>
                                    <atom:NumericUpDown Width="88"
                                                        Minimum="0"
                                                        Maximum="600000"
                                                        Value="{Binding AdvancedPromptMaxWaitMilliseconds, Mode=TwoWay}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Margin="0,0,18,0"
                                Padding="18">
                            <StackPanel Spacing="12">
                                <TextBlock Text="{Binding [UiText.249], Source={x:Static services:LocalizationService.Shared}}" FontWeight="SemiBold"/>
                                <atom:CheckBox Content="{Binding [UiText.250], Source={x:Static services:LocalizationService.Shared}}"
                                               IsChecked="{Binding AdvancedUseNagle, Mode=TwoWay}"/>
                            </StackPanel>
                        </Border>

                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Margin="0,0,18,0"
                                Padding="18">
                            <StackPanel Spacing="12">
                                <TextBlock Text="{Binding [UiText.251], Source={x:Static services:LocalizationService.Shared}}" FontWeight="SemiBold"/>
                                <StackPanel Orientation="Horizontal" Spacing="72">
                                    <atom:RadioButton Content="{Binding [UiText.252], Source={x:Static services:LocalizationService.Shared}}"
                                                      GroupName="AdvancedIpVersion"
                                                      IsChecked="{Binding IsAdvancedIpVersionAuto, Mode=TwoWay}"/>
                                    <atom:RadioButton Content="IPv4"
                                                      GroupName="AdvancedIpVersion"
                                                      IsChecked="{Binding IsAdvancedIpVersion4, Mode=TwoWay}"/>
                                    <atom:RadioButton Content="IPv6"
                                                      GroupName="AdvancedIpVersion"
                                                      IsChecked="{Binding IsAdvancedIpVersion6, Mode=TwoWay}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="TracingPage"
                              IsVisible="{Binding IsTracingPage}"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="16">
                        <atom:TextBlock Text="{Binding [UiText.253], Source={x:Static services:LocalizationService.Shared}}"
                                        Foreground="{atom:SharedTokenResource ColorText}"
                                        TextWrapping="Wrap"/>

                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Margin="0,0,18,0"
                                Padding="18">
                            <StackPanel Spacing="16">
                                <atom:TextBlock Text="{Binding [UiText.254], Source={x:Static services:LocalizationService.Shared}}"
                                                FontWeight="SemiBold"
                                                Foreground="{atom:SharedTokenResource ColorText}"/>
                                <StackPanel Spacing="12">
                                    <atom:CheckBox Content="{Binding [UiText.255], Source={x:Static services:LocalizationService.Shared}}"
                                                   IsChecked="{Binding AdvancedTraceSshProtocol, Mode=TwoWay}"/>
                                    <atom:CheckBox Content="{Binding [UiText.256], Source={x:Static services:LocalizationService.Shared}}"
                                                   IsChecked="{Binding AdvancedTraceSshTunneling, Mode=TwoWay}"/>
                                    <atom:CheckBox Content="{Binding [UiText.257], Source={x:Static services:LocalizationService.Shared}}"
                                                   IsChecked="{Binding AdvancedTraceSshPackets, Mode=TwoWay}"/>
                                    <atom:CheckBox Content="{Binding [UiText.258], Source={x:Static services:LocalizationService.Shared}}"
                                                   IsChecked="{Binding AdvancedTraceTelnetOptions, Mode=TwoWay}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Border x:Name="PlaceholderPage"
                        IsVisible="False"
                        Background="{atom:SharedTokenResource ColorBgContainer}"
                        BorderBrush="{atom:SharedTokenResource ColorBorder}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="24">
                    <StackPanel Spacing="8" VerticalAlignment="Top">
                        <TextBlock x:Name="PlaceholderTitleText"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{atom:SharedTokenResource ColorText}"/>
                        <TextBlock Text="{Binding PlaceholderText}"
                                   Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <StackPanel Grid.Column="4" Spacing="10">
            <atom:Button x:Name="SaveBtn"
                         ButtonType="Primary"
                         Icon="{antdicons:AntDesignIconProvider Kind=CheckOutlined}"
                         Content="{Binding SaveText}"
                         MinWidth="132"
                         HorizontalAlignment="Stretch"/>
            <atom:Button x:Name="ConnectBtn"
                         ButtonType="Default"
                         Icon="{antdicons:AntDesignIconProvider Kind=LinkOutlined}"
                         Content="{Binding ConnectText}"
                         MinWidth="132"
                         IsVisible="{Binding IsSessionScope}"
                         HorizontalAlignment="Stretch"/>
            <atom:Button x:Name="CancelBtn"
                         Icon="{antdicons:AntDesignIconProvider Kind=CloseOutlined}"
                         Content="{Binding CancelText}"
                         MinWidth="132"
                         HorizontalAlignment="Stretch"/>
        </StackPanel>
    </Grid>
</atom:Window>



