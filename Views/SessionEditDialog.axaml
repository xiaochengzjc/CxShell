<atom:Window xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:atom="https://atomui.net"
             xmlns:vm="using:ChiXueSsh.ViewModels"
             x:Class="ChiXueSsh.Views.SessionEditDialog"
             x:DataType="vm:SessionEditViewModel"
             Title="{Binding DialogTitle}"
             Width="480"
             Height="440"
             WindowStartupLocation="CenterOwner"
             CanResize="False"
             ShowInTaskbar="False"
             Background="{atom:SharedTokenResource ColorBgLayout}"
             Loaded="OnWindowLoaded">

    <!-- 控件样式配置 -->
    <atom:Window.Styles>
        <Style Selector="atom|TextBox">
            <Setter Property="Background" Value="{atom:SharedTokenResource ColorBgContainer}"/>
            <Setter Property="Foreground" Value="{atom:SharedTokenResource ColorText}"/>
            <Setter Property="CaretBrush" Value="{atom:SharedTokenResource ColorText}"/>
            <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style Selector="atom|RadioButton">
            <Setter Property="Foreground" Value="{atom:SharedTokenResource ColorTextSecondary}"/>
        </Style>
    </atom:Window.Styles>

    <DockPanel>
        <!-- 底部按钮栏 -->
        <Border DockPanel.Dock="Bottom" Padding="20,10"
                Background="{atom:SharedTokenResource ColorBgContainer}"
                BorderBrush="{atom:SharedTokenResource ColorSplit}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                <atom:Button x:Name="CancelBtn" Content="取消" Width="80"
                             ButtonType="Default"/>
                <atom:Button x:Name="SaveBtn" Content="保存" Width="80"
                             ButtonType="Primary"/>
            </StackPanel>
        </Border>

        <!-- 表单内容 -->
        <ScrollViewer Background="{atom:SharedTokenResource ColorBgLayout}">
            <StackPanel Margin="24,16,24,12" Spacing="0">

                <!-- 基本信息 -->
                <Border Margin="0,0,0,14" Padding="0,0,0,6"
                        BorderBrush="{atom:SharedTokenResource ColorSplit}" BorderThickness="0,0,0,1">
                    <TextBlock Text="基本信息" FontSize="11"
                               Foreground="{atom:SharedTokenResource ColorTextTertiary}" FontWeight="Bold"/>
                </Border>

                <!-- 会话名称 -->
                <Grid ColumnDefinitions="90,*" Margin="0,0,0,10">
                    <TextBlock Grid.Column="0" Text="会话名称"
                               Foreground="{atom:SharedTokenResource ColorTextSecondary}" FontSize="13"
                               VerticalAlignment="Center"/>
                    <atom:TextBox Grid.Column="1" x:Name="NameBox"
                                  Text="{Binding SessionName, Mode=TwoWay}"
                                  PlaceholderText="例如: 生产服务器"/>
                </Grid>

                <!-- 主机地址 -->
                <Grid ColumnDefinitions="90,*" Margin="0,0,0,10">
                    <TextBlock Grid.Column="0" Text="主机地址"
                               Foreground="{atom:SharedTokenResource ColorTextSecondary}" FontSize="13"
                               VerticalAlignment="Center"/>
                    <atom:TextBox Grid.Column="1" x:Name="HostBox"
                                  Text="{Binding Host, Mode=TwoWay}"
                                  PlaceholderText="192.168.1.100 或 example.com"/>
                </Grid>

                <!-- 端口 -->
                <Grid ColumnDefinitions="90,*" Margin="0,0,0,10">
                    <TextBlock Grid.Column="0" Text="端口"
                               Foreground="{atom:SharedTokenResource ColorTextSecondary}" FontSize="13"
                               VerticalAlignment="Center"/>
                    <atom:TextBox Grid.Column="1" x:Name="PortBox"
                                  Text="{Binding Port, Mode=TwoWay}"
                                  PlaceholderText="22"/>
                </Grid>

                <!-- 用户名 -->
                <Grid ColumnDefinitions="90,*" Margin="0,0,0,18">
                    <TextBlock Grid.Column="0" Text="用户名"
                               Foreground="{atom:SharedTokenResource ColorTextSecondary}" FontSize="13"
                               VerticalAlignment="Center"/>
                    <atom:TextBox Grid.Column="1" x:Name="UsernameBox"
                                  Text="{Binding Username, Mode=TwoWay}"
                                  PlaceholderText="root"/>
                </Grid>

                <!-- 认证方式 -->
                <Border Margin="0,0,0,14" Padding="0,0,0,6"
                        BorderBrush="{atom:SharedTokenResource ColorSplit}" BorderThickness="0,0,0,1">
                    <TextBlock Text="认证方式" FontSize="11"
                               Foreground="{atom:SharedTokenResource ColorTextTertiary}" FontWeight="Bold"/>
                </Border>

                <!-- 认证选项 -->
                <Grid ColumnDefinitions="90,*" Margin="0,0,0,10">
                    <TextBlock Grid.Column="0" Text="方式"
                               Foreground="{atom:SharedTokenResource ColorTextSecondary}" FontSize="13"
                               VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="20"
                                VerticalAlignment="Center">
                        <atom:RadioButton Content="密码" IsChecked="{Binding IsPasswordAuth}"
                                          GroupName="AuthMethod"/>
                        <atom:RadioButton Content="私钥" IsChecked="{Binding IsPrivateKeyAuth}"
                                          GroupName="AuthMethod"/>
                    </StackPanel>
                </Grid>

                <!-- 私钥路径 -->
                <Grid ColumnDefinitions="90,*" Margin="0,0,0,10"
                      IsVisible="{Binding IsPrivateKeyAuth}">
                    <TextBlock Grid.Column="0" Text="私钥路径"
                               Foreground="{atom:SharedTokenResource ColorTextSecondary}" FontSize="13"
                               VerticalAlignment="Center"/>
                    <Grid Grid.Column="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <atom:TextBox Grid.Column="0" x:Name="KeyPathBox"
                                      Text="{Binding PrivateKeyPath, Mode=TwoWay}"
                                      PlaceholderText="~/.ssh/id_rsa"/>
                        <atom:Button Grid.Column="1" Content="浏览"
                                     Command="{Binding BrowseKeyCommand}"
                                     ButtonType="Default"/>
                    </Grid>
                </Grid>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</atom:Window>
