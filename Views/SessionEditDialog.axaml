<atom:Window xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:atom="https://atomui.net"
             xmlns:antdicons="https://atomui.net/icons/antdesign"
             xmlns:vm="using:ChiXueSsh.ViewModels"
             xmlns:models="using:ChiXueSsh.Models"
             x:Class="ChiXueSsh.Views.SessionEditDialog"
             x:DataType="vm:SessionEditViewModel"
             Title="{Binding DialogTitle}"
             Width="1040"
             Height="720"
             MinWidth="860"
             MinHeight="600"
             WindowStartupLocation="CenterOwner"
             CanResize="True"
             ShowInTaskbar="False"
             Background="{atom:SharedTokenResource ColorBgLayout}"
             Loaded="OnWindowLoaded">

    <atom:Window.Styles>
        <Style Selector="atom|LineEdit">
            <Setter Property="Background" Value="{atom:SharedTokenResource ColorBgContainer}"/>
            <Setter Property="Foreground" Value="{atom:SharedTokenResource ColorText}"/>
            <Setter Property="CaretBrush" Value="{atom:SharedTokenResource ColorText}"/>
            <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="atom|RadioButton">
            <Setter Property="Foreground" Value="{atom:SharedTokenResource ColorTextSecondary}"/>
        </Style>
        <Style Selector="atom|NumericUpDown">
            <Setter Property="MinWidth" Value="112"/>
        </Style>
        <Style Selector="atom|Button.session-nav">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="MinHeight" Value="34"/>
        </Style>
        <Style Selector="atom|Button.session-nav:pointerover">
            <Setter Property="Background" Value="{atom:SharedTokenResource ColorFillTertiary}"/>
        </Style>
        <Style Selector="atom|Button.file-picker-button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="MinWidth" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="IsWaveSpiritEnabled" Value="False"/>
            <Setter Property="ClipToBounds" Value="True"/>
        </Style>
        <Style Selector="atom|Button.file-picker-button /template/ Border#ShadowsFrame">
            <Setter Property="BoxShadow" Value="0 0 0 0 Transparent"/>
        </Style>
    </atom:Window.Styles>

    <Grid Margin="20" ColumnDefinitions="250,16,*,16,104">
        <Border Grid.Column="0"
                Background="{atom:SharedTokenResource ColorBgContainer}"
                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Spacing="2" Margin="2,2,2,12">
                    <TextBlock Text="会话配置"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{atom:SharedTokenResource ColorText}"/>
                    <TextBlock Text="连接相关设置"
                               FontSize="12"
                               Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                </StackPanel>
                <atom:NavMenu x:Name="SessionNavMenu"
                              Mode="Inline"
                              IsAccordionMode="False"
                              DefaultOpenPaths="{Binding DefaultOpenNavPaths}"
                              DefaultSelectedPath="{Binding DefaultSelectedNavPath}"
                              NavMenuItemClick="OnSessionNavMenuItemClick">
                    <atom:NavMenuNode Header="连接"
                                      ItemKey="Connection"
                                      Icon="{antdicons:AntDesignIconProvider Kind=LinkOutlined}">
                        <atom:NavMenuNode Header="登录提示符" ItemKey="LoginPrompt"/>
                        <atom:NavMenuNode Header="登录脚本" ItemKey="LoginScript"/>
                        <atom:NavMenuNode Header="代理" ItemKey="Proxy"/>
                        <atom:NavMenuNode Header="保持活动" ItemKey="KeepAlive"/>
                        <atom:NavMenuNode Header="TELNET" ItemKey="Telnet"/>
                        <atom:NavMenuNode Header="RLOGIN" ItemKey="Rlogin"/>
                        <atom:NavMenuNode Header="串口" ItemKey="Serial"/>
                        <atom:NavMenuNode Header="RDP" ItemKey="Rdp"/>
                    </atom:NavMenuNode>
                    <atom:NavMenuNode Header="SSH"
                                      ItemKey="Ssh"
                                      Icon="{antdicons:AntDesignIconProvider Kind=SafetyCertificateOutlined}">
                        <atom:NavMenuNode Header="安全性" ItemKey="SshSecurity"/>
                        <atom:NavMenuNode Header="隧道" ItemKey="SshTunnel"/>
                        <atom:NavMenuNode Header="SFTP" ItemKey="SshSftp"/>
                    </atom:NavMenuNode>
                    <atom:NavMenuNode Header="终端"
                                      ItemKey="Terminal"
                                      Icon="{antdicons:AntDesignIconProvider Kind=CodeOutlined}">
                        <atom:NavMenuNode Header="键盘" ItemKey="Keyboard"/>
                    </atom:NavMenuNode>
                    <atom:NavMenuNode Header="外观"
                                      ItemKey="Appearance"
                                      Icon="{antdicons:AntDesignIconProvider Kind=BgColorsOutlined}">
                        <atom:NavMenuNode Header="窗口" ItemKey="AppearanceWindow"/>
                    </atom:NavMenuNode>
                    <atom:NavMenuNode Header="文件传输" ItemKey="Transfer"/>
                    <atom:NavMenuNode Header="日志" ItemKey="Logging"/>
                    <atom:NavMenuNode Header="响铃" ItemKey="Bell"/>
                    <atom:NavMenuNode Header="高级" ItemKey="Advanced"/>
                    <atom:NavMenuNode Header="协议跟踪" ItemKey="Tracing"/>
                </atom:NavMenu>
            </DockPanel>
        </Border>

        <Grid Grid.Column="2" RowDefinitions="Auto,12,*">
            <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                    BorderBrush="{atom:SharedTokenResource ColorSplit}"
                    BorderThickness="0,0,0,1"
                    Padding="12,8">
                <TextBlock x:Name="PageTitleText"
                           Text="连接"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="{atom:SharedTokenResource ColorText}"/>
            </Border>

            <Grid Grid.Row="2">
                <ScrollViewer x:Name="ConnectionPage">
                    <StackPanel Spacing="16">
                        <Border Background="{atom:SharedTokenResource ColorErrorBg}"
                                BorderBrush="{atom:SharedTokenResource ColorErrorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="10,8"
                                IsVisible="{Binding HasValidationError}">
                            <TextBlock Text="{Binding ValidationMessage}"
                                       Foreground="{atom:SharedTokenResource ColorError}"
                                       FontSize="13"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <Grid RowDefinitions="Auto,14,Auto,12,Auto,12,Auto,12,Auto,12,Auto"
                                  ColumnDefinitions="110,*">
                                <TextBlock Grid.ColumnSpan="2"
                                           Text="常规"
                                           FontWeight="SemiBold"
                                           Foreground="{atom:SharedTokenResource ColorText}"/>

                                <TextBlock Grid.Row="4" Text="名称"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:LineEdit Grid.Row="4" Grid.Column="1"
                                              x:Name="NameBox"
                                              Status="{Binding NameStatus}"
                                              Text="{Binding SessionName, Mode=TwoWay}"
                                              PlaceholderText="例如：生产服务器"/>

                                <TextBlock Grid.Row="6" Text="协议"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:Select Grid.Row="6" Grid.Column="1"
                                             x:Name="ProtocolSelect"
                                             Mode="Single"
                                             HorizontalAlignment="Stretch"
                                             PlaceholderText="请选择协议"
                                             OptionsSource="{Binding ProtocolOptions}"
                                             SelectionChanged="OnProtocolSelectionChanged"/>

                                <TextBlock Grid.Row="8" Text="主机"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:LineEdit Grid.Row="8" Grid.Column="1"
                                              x:Name="HostBox"
                                              Status="{Binding HostStatus}"
                                              Text="{Binding Host, Mode=TwoWay}"
                                              PlaceholderText="192.168.1.100 或 example.com"/>

                                <TextBlock Grid.Row="10" Text="端口"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:LineEdit Grid.Row="10" Grid.Column="1"
                                              x:Name="PortBox"
                                              Width="160"
                                              HorizontalAlignment="Left"
                                              Status="{Binding PortStatus}"
                                              Text="{Binding Port, Mode=TwoWay}"
                                              PlaceholderText="22"/>
                            </Grid>
                        </Border>

                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <Grid RowDefinitions="Auto,14,Auto,12,Auto,12,Auto,12,Auto"
                                  ColumnDefinitions="110,*">
                                <TextBlock Grid.ColumnSpan="2"
                                           Text="用户身份验证"
                                           FontWeight="SemiBold"
                                           Foreground="{atom:SharedTokenResource ColorText}"/>

                                <TextBlock Grid.Row="2" Text="用户名"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:LineEdit Grid.Row="2" Grid.Column="1"
                                              x:Name="ConnectionUsernameBox"
                                              Text="{Binding Username, Mode=TwoWay}"
                                              PlaceholderText="root"/>

                                <TextBlock Grid.Row="4" Text="认证方法"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <StackPanel Grid.Row="4" Grid.Column="1"
                                            Orientation="Horizontal"
                                            Spacing="20">
                                    <atom:RadioButton Content="密码"
                                                      IsChecked="{Binding IsPasswordAuth}"
                                                      GroupName="ConnectionAuthMethod"/>
                                    <atom:RadioButton Content="私钥"
                                                      IsChecked="{Binding IsPrivateKeyAuth}"
                                                      GroupName="ConnectionAuthMethod"/>
                                </StackPanel>

                                <TextBlock Grid.Row="6" Text="密码"
                                           VerticalAlignment="Center"
                                           IsVisible="{Binding IsPasswordAuth}"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <StackPanel Grid.Row="6" Grid.Column="1"
                                            Spacing="6"
                                            IsVisible="{Binding IsPasswordAuth}">
                                    <atom:CheckBox Content="连接时提示输入密码"
                                                   IsChecked="True"
                                                   IsEnabled="False"/>
                                    <TextBlock Text="密码不会保存到会话文件。"
                                               FontSize="12"
                                               Foreground="{atom:SharedTokenResource ColorTextTertiary}"/>
                                </StackPanel>

                                <TextBlock Grid.Row="8" Text="私钥路径"
                                           VerticalAlignment="Center"
                                           IsVisible="{Binding IsPrivateKeyAuth}"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <Grid Grid.Row="8" Grid.Column="1"
                                      ColumnDefinitions="*,Auto"
                                      ColumnSpacing="8"
                                      IsVisible="{Binding IsPrivateKeyAuth}">
                                    <atom:LineEdit Text="{Binding PrivateKeyPath, Mode=TwoWay}"
                                                  PlaceholderText="~/.ssh/id_rsa"/>
                                    <atom:Button Grid.Column="1"
                                                 Icon="{antdicons:AntDesignIconProvider Kind=FolderOpenOutlined}"
                                                 Content="浏览"
                                                 Command="{Binding BrowseKeyCommand}"/>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <Grid RowDefinitions="Auto,14,Auto,12,Auto"
                                  ColumnDefinitions="*,110,112,32,110,112,32">
                                <TextBlock Grid.ColumnSpan="7"
                                           Text="重新连接"
                                           FontWeight="SemiBold"
                                           Foreground="{atom:SharedTokenResource ColorText}"/>

                                <atom:CheckBox Grid.Row="2"
                                               Grid.ColumnSpan="7"
                                               Content="连接异常关闭时自动重新连接"
                                               IsChecked="{Binding AutoReconnect, Mode=TwoWay}"/>

                                <TextBlock Grid.Row="4" Grid.Column="1"
                                           Text="间隔"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:NumericUpDown Grid.Row="4" Grid.Column="2"
                                                    Minimum="1"
                                                    Maximum="3600"
                                                    Value="{Binding ReconnectIntervalSeconds, Mode=TwoWay}"
                                                    IsEnabled="{Binding AutoReconnect}"/>
                                <TextBlock Grid.Row="4" Grid.Column="3"
                                           Text="秒"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>

                                <TextBlock Grid.Row="4" Grid.Column="4"
                                           Text="限制"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:NumericUpDown Grid.Row="4" Grid.Column="5"
                                                    Minimum="0"
                                                    Maximum="1440"
                                                    Value="{Binding ReconnectLimitMinutes, Mode=TwoWay}"
                                                    IsEnabled="{Binding AutoReconnect}"/>
                                <TextBlock Grid.Row="4" Grid.Column="6"
                                           Text="分钟"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="KeepAlivePage" IsVisible="False">
                    <StackPanel Spacing="16">
                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <Grid RowDefinitions="Auto,14,Auto,18,Auto,12,Auto,18,Auto"
                                  ColumnDefinitions="Auto,14,110,12,56,56,120,*">
                                <TextBlock Grid.ColumnSpan="8"
                                           Text="保持活动状态"
                                           FontWeight="SemiBold"
                                           Foreground="{atom:SharedTokenResource ColorText}"/>

                                <atom:CheckBox Grid.Row="2"
                                               Grid.ColumnSpan="8"
                                               Content="连接会话期间发送保持活动状态消息(S)"
                                               IsChecked="{Binding SendSessionKeepAlive, Mode=TwoWay}"/>

                                <TextBlock Grid.Row="4"
                                           Grid.Column="1"
                                           Grid.ColumnSpan="2"
                                           Text="间隔(I):"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:NumericUpDown Grid.Row="4"
                                                    Grid.Column="4"
                                                    Grid.ColumnSpan="2"
                                                    Minimum="1"
                                                    Maximum="86400"
                                                    Value="{Binding SessionKeepAliveIntervalSeconds, Mode=TwoWay}"
                                                    IsEnabled="{Binding IsSessionKeepAliveIntervalEnabled}"/>
                                <TextBlock Grid.Row="4"
                                           Grid.Column="6"
                                           Text="秒"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>

                                <atom:CheckBox Grid.Row="6"
                                               Grid.ColumnSpan="8"
                                               Content="网络空闲时发送字符串(R)"
                                               IsChecked="{Binding SendIdleString, Mode=TwoWay}"/>

                                <TextBlock Grid.Row="8"
                                           Grid.Column="1"
                                           Grid.ColumnSpan="2"
                                           Text="间隔(E):"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:NumericUpDown Grid.Row="8"
                                                    Grid.Column="4"
                                                    Grid.ColumnSpan="2"
                                                    Minimum="0"
                                                    Maximum="86400"
                                                    Value="{Binding IdleStringIntervalSeconds, Mode=TwoWay}"
                                                    IsEnabled="{Binding IsIdleStringSettingsEnabled}"/>
                                <TextBlock Grid.Row="8"
                                           Grid.Column="6"
                                           Text="秒"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <TextBlock Grid.Row="8"
                                           Grid.Column="7"
                                           Text="字符串(G):"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Left"
                                           Margin="28,0,8,0"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:LineEdit Grid.Row="8"
                                               Grid.Column="7"
                                               Width="130"
                                               HorizontalAlignment="Right"
                                               Text="{Binding IdleString, Mode=TwoWay}"
                                               IsEnabled="{Binding IsIdleStringSettingsEnabled}"/>
                            </Grid>
                        </Border>

                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <atom:CheckBox Content="网络为空闲状态时发送 TCP 保持活动数据包(T)"
                                           IsChecked="{Binding TcpKeepAlive, Mode=TwoWay}"/>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="LoginPromptPage" IsVisible="False">
                    <StackPanel Spacing="16">
                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <Grid RowDefinitions="Auto,14,Auto,28,Auto,12,Auto"
                                  ColumnDefinitions="160,320">
                                <TextBlock Grid.ColumnSpan="2"
                                           Text="TELNET"
                                           FontWeight="SemiBold"
                                           Foreground="{atom:SharedTokenResource ColorText}"/>
                                <TextBlock Grid.Row="2"
                                           Grid.ColumnSpan="2"
                                           Text="请指定用户名和密码提示，以便 TELNET 登录过程可自动运行。"
                                           TextWrapping="Wrap"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <TextBlock Grid.Row="4" Text="用户名提示"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:LineEdit Grid.Row="4" Grid.Column="1"
                                              x:Name="TelnetUsernamePromptBox"
                                              Text="{Binding TelnetUsernamePrompt, Mode=TwoWay}"
                                              PlaceholderText="ogin:"/>
                                <TextBlock Grid.Row="6" Text="密码提示"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:LineEdit Grid.Row="6" Grid.Column="1"
                                              x:Name="TelnetPasswordPromptBox"
                                              Text="{Binding TelnetPasswordPrompt, Mode=TwoWay}"
                                              PlaceholderText="assword:"/>
                            </Grid>
                        </Border>

                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <Grid RowDefinitions="Auto,14,Auto,28,Auto"
                                  ColumnDefinitions="160,320">
                                <TextBlock Grid.ColumnSpan="2"
                                           Text="RLOGIN"
                                           FontWeight="SemiBold"
                                           Foreground="{atom:SharedTokenResource ColorText}"/>
                                <TextBlock Grid.Row="2"
                                           Grid.ColumnSpan="2"
                                           Text="请指定密码提示，以便 RLOGIN 登录过程可自动运行。"
                                           TextWrapping="Wrap"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <TextBlock Grid.Row="4" Text="密码提示"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:LineEdit Grid.Row="4" Grid.Column="1"
                                              x:Name="RloginPasswordPromptBox"
                                              Text="{Binding RloginPasswordPrompt, Mode=TwoWay}"
                                              PlaceholderText="assword:"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="LoginScriptPage" IsVisible="False">
                    <StackPanel Spacing="16">
                        <TextBlock Text="成功登录服务器后，可以执行使用等待并发送规则添加的命令或者使用第二次自动登录。"
                                   TextWrapping="Wrap"
                                   Foreground="{atom:SharedTokenResource ColorText}"/>

                        <Grid RowDefinitions="Auto,12,380,22,Auto,12,Auto,12,Auto"
                              ColumnDefinitions="*,18,164">
                            <atom:CheckBox Grid.ColumnSpan="3"
                                           Content="执行以下等待并发送规则(X)."
                                           IsChecked="{Binding EnableLoginScriptRules, Mode=TwoWay}"/>

                            <atom:DataGrid x:Name="LoginScriptRulesGrid"
                                           Grid.Row="2"
                                           ItemsSource="{Binding LoginScriptRules}"
                                           SelectedItem="{Binding SelectedLoginScriptRule, Mode=TwoWay}"
                                           AutoGenerateColumns="False"
                                           IsReadOnly="True"
                                           SelectionMode="Single"
                                           SizeType="Middle"
                                           GridLinesVisibility="Vertical"
                                           CanUserResizeColumns="True"
                                           IsHideOnSinglePage="True">
                                <atom:DataGrid.Columns>
                                    <atom:DataGridTextColumn Header="Expect" Binding="{Binding Expect}" Width="160"/>
                                    <atom:DataGridTextColumn Header="Send" Binding="{Binding SendDisplay}" Width="360"/>
                                </atom:DataGrid.Columns>
                            </atom:DataGrid>

                            <StackPanel Grid.Row="2"
                                        Grid.Column="2"
                                        Spacing="10">
                                <atom:Button x:Name="AddLoginScriptRuleBtn"
                                             Content="添加(A)..."
                                             Click="OnAddLoginScriptRuleClick"/>
                                <atom:Button x:Name="EditLoginScriptRuleBtn"
                                             Content="编辑(E)..."
                                             IsEnabled="{Binding HasSelectedLoginScriptRule}"
                                             Click="OnEditLoginScriptRuleClick"/>
                                <atom:Button x:Name="DeleteLoginScriptRuleBtn"
                                             Content="删除(R)"
                                             IsEnabled="{Binding HasSelectedLoginScriptRule}"
                                             Click="OnDeleteLoginScriptRuleClick"/>
                                <atom:Button x:Name="MoveUpLoginScriptRuleBtn"
                                             Content="上移(U)"
                                             IsEnabled="{Binding HasSelectedLoginScriptRule}"
                                             Click="OnMoveUpLoginScriptRuleClick"/>
                                <atom:Button x:Name="MoveDownLoginScriptRuleBtn"
                                             Content="下移(D)"
                                             IsEnabled="{Binding HasSelectedLoginScriptRule}"
                                             Click="OnMoveDownLoginScriptRuleClick"/>
                            </StackPanel>

                            <atom:CheckBox Grid.Row="4"
                                           Grid.ColumnSpan="3"
                                           Content="连接会话时运行脚本(S)."
                                           IsChecked="{Binding RunLoginScriptFile, Mode=TwoWay}"/>

                            <Grid Grid.Row="6"
                                  Grid.ColumnSpan="3"
                                  ColumnDefinitions="*,8,40,28">
                                <atom:LineEdit x:Name="LoginScriptFilePathBox"
                                               Text="{Binding LoginScriptFilePath, Mode=TwoWay}"
                                               VerticalAlignment="Center"
                                               IsEnabled="{Binding IsLoginScriptFileEnabled}"/>
                                <atom:Button Grid.Column="2"
                                             Classes="file-picker-button"
                                              Content="..."
                                              IsEnabled="{Binding IsLoginScriptFileEnabled}"
                                              Click="OnBrowseLoginScriptFileClick"/>
                            </Grid>

                            <Grid Grid.Row="8"
                                  Grid.ColumnSpan="3"
                                  ColumnDefinitions="Auto,12,*">
                                <TextBlock Text="参数(P):"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:LineEdit Grid.Column="2"
                                               Text="{Binding LoginScriptParameters, Mode=TwoWay}"
                                               IsEnabled="{Binding IsLoginScriptFileEnabled}"/>
                            </Grid>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="SshPage" IsVisible="False">
                    <StackPanel Spacing="16">
                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <Grid RowDefinitions="Auto,14,Auto,28,Auto"
                                  ColumnDefinitions="*">
                                <TextBlock Text="远程命令"
                                           FontWeight="SemiBold"
                                           Foreground="{atom:SharedTokenResource ColorText}"/>
                                <TextBlock Grid.Row="2"
                                           Text="指定连接后要运行的远程命令。"
                                           TextWrapping="Wrap"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:LineEdit Grid.Row="4"
                                              x:Name="SshRemoteCommandBox"
                                              Text="{Binding SshRemoteCommand, Mode=TwoWay}"
                                              PlaceholderText="例如：cd /var/log"/>
                            </Grid>
                        </Border>

                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <Grid RowDefinitions="Auto,14,Auto,28,Auto"
                                  ColumnDefinitions="*">
                                <TextBlock Text="协议版本优先级"
                                           FontWeight="SemiBold"
                                           Foreground="{atom:SharedTokenResource ColorText}"/>
                                <TextBlock Grid.Row="2"
                                           Text="选择首选的 SSH 版本。通常，SSH2 提供高安全性和更多的特征。"
                                           TextWrapping="Wrap"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:Select Grid.Row="4"
                                             x:Name="SshVersionPolicySelect"
                                             Mode="Single"
                                             HorizontalAlignment="Stretch"
                                             OptionsSource="{Binding SshVersionOptions}"/>
                            </Grid>
                        </Border>

                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Xagent (SSH 身份验证代理)"
                                           FontWeight="SemiBold"
                                           Foreground="{atom:SharedTokenResource ColorText}"/>
                                <TextBlock Text="Xagent 会记住密码，并在请求时将其传递给服务器。"
                                           TextWrapping="Wrap"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:CheckBox Content="使用 SSH 密钥代理(Xagent)(U)"
                                               IsChecked="{Binding SshUseXagent, Mode=TwoWay}"/>
                                <atom:CheckBox Content="允许代理转发(E)"
                                               IsChecked="{Binding SshForwardAgent, Mode=TwoWay}"/>
                            </StackPanel>
                        </Border>

                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <StackPanel Spacing="12">
                                <TextBlock Text="其他"
                                           FontWeight="SemiBold"
                                           Foreground="{atom:SharedTokenResource ColorText}"/>
                                <atom:CheckBox Content="使用 ZLIB 压缩(Z)"
                                               IsChecked="{Binding SshUseCompression, Mode=TwoWay}"/>
                                <atom:CheckBox Content="不分配终端(D)"
                                               IsChecked="{Binding SshNoTerminal, Mode=TwoWay}"/>
                                <atom:CheckBox Content="第一次连接时自动接受并保存主机密钥(A)"
                                               IsChecked="{Binding SshAcceptAndSaveHostKey, Mode=TwoWay}"/>
                                <atom:CheckBox Content="不要建立文件管理器连接(N)"
                                               IsChecked="{Binding SshDoNotStartFileManager, Mode=TwoWay}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="SshSecurityPage" IsVisible="False">
                    <StackPanel Spacing="16">
                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <Grid RowDefinitions="Auto,14,Auto,80,Auto,12,Auto,12,Auto"
                                  ColumnDefinitions="110,*,100">
                                <TextBlock Grid.ColumnSpan="3"
                                           Text="算法"
                                           FontWeight="SemiBold"
                                           Foreground="{atom:SharedTokenResource ColorText}"/>
                                <TextBlock Grid.Row="2"
                                           Grid.ColumnSpan="3"
                                           Text="选择要使用的算法 SSH 连接。选择 &lt;... List&gt; 使用默认或编辑后的算法列表。"
                                           TextWrapping="Wrap"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>

                                <TextBlock Grid.Row="4"
                                           Text="加密(E):"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:Select Grid.Row="4"
                                             Grid.Column="1"
                                             x:Name="SshCipherSelect"
                                             Mode="Single"
                                             OptionsSource="{Binding SshCipherOptions}"/>
                                <atom:Button Grid.Row="4"
                                             Grid.Column="2"
                                             Margin="8,0,0,0"
                                             Content="编辑(D)..."
                                             Click="OnEditSshCipherListClick"/>

                                <TextBlock Grid.Row="6"
                                           Text="MAC:"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:Select Grid.Row="6"
                                             Grid.Column="1"
                                             x:Name="SshMacSelect"
                                             Mode="Single"
                                             OptionsSource="{Binding SshMacOptions}"/>
                                <atom:Button Grid.Row="6"
                                             Grid.Column="2"
                                             Margin="8,0,0,0"
                                             Content="编辑(I)..."
                                             Click="OnEditSshMacListClick"/>

                                <TextBlock Grid.Row="8"
                                           Text="密钥交换(K):"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:Select Grid.Row="8"
                                             Grid.Column="1"
                                             x:Name="SshKeyExchangeSelect"
                                             Mode="Single"
                                             OptionsSource="{Binding SshKeyExchangeOptions}"/>
                                <atom:Button Grid.Row="8"
                                             Grid.Column="2"
                                             Margin="8,0,0,0"
                                             Content="编辑(T)..."
                                             Click="OnEditSshKeyExchangeListClick"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="SshTunnelPage" IsVisible="False">
                    <StackPanel Spacing="16">
                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <Grid RowDefinitions="Auto,10,Auto,14,260,14,Auto"
                                  ColumnDefinitions="*,120,120,120,56">
                                <TextBlock Grid.ColumnSpan="5"
                                           Text="TCP/IP 转移"
                                           FontWeight="SemiBold"
                                           Foreground="{atom:SharedTokenResource ColorText}"/>
                                <TextBlock Grid.Row="2"
                                           Grid.ColumnSpan="5"
                                           Text="添加/编辑/删除 TCP/IP 转移规则。此规则连接后自动应用。"
                                           TextWrapping="Wrap"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>

                                <atom:DataGrid x:Name="SshTunnelRulesGrid"
                                               Grid.Row="4"
                                               Grid.ColumnSpan="5"
                                               ItemsSource="{Binding SshTunnelRules}"
                                               SelectedItem="{Binding SelectedSshTunnelRule, Mode=TwoWay}"
                                               AutoGenerateColumns="False"
                                               IsReadOnly="True"
                                               SelectionMode="Single"
                                               GridLinesVisibility="Horizontal"
                                               CanUserResizeColumns="True">
                                    <atom:DataGrid.Columns>
                                        <atom:DataGridTextColumn Header="类型" Binding="{Binding TypeDisplay}" Width="150"/>
                                        <atom:DataGridTextColumn Header="侦听端口" Binding="{Binding ListenPortDisplay}" Width="120"/>
                                        <atom:DataGridTextColumn Header="目标" Binding="{Binding TargetDisplay}" Width="200"/>
                                        <atom:DataGridTextColumn Header="说明" Binding="{Binding Description}" Width="260"/>
                                    </atom:DataGrid.Columns>
                                </atom:DataGrid>

                                <atom:Button Grid.Row="6"
                                             Grid.Column="1"
                                             Content="添加(A)..."
                                             Click="OnAddSshTunnelRuleClick"/>
                                <atom:Button Grid.Row="6"
                                             Grid.Column="2"
                                             Content="编辑(E)..."
                                             IsEnabled="{Binding HasSelectedSshTunnelRule}"
                                             Click="OnEditSshTunnelRuleClick"/>
                                <atom:Button Grid.Row="6"
                                             Grid.Column="3"
                                             Content="删除(R)"
                                             IsEnabled="{Binding HasSelectedSshTunnelRule}"
                                             Click="OnDeleteSshTunnelRuleClick"/>
                                <atom:Button Grid.Row="6"
                                             Grid.Column="4"
                                             Content="..."
                                             Click="OnAddSshTunnelRuleClick"/>
                            </Grid>
                        </Border>

                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <Grid RowDefinitions="Auto,12,Auto,10,Auto"
                                  ColumnDefinitions="36,120,170,*">
                                <TextBlock Grid.ColumnSpan="4"
                                           Text="X11 转移"
                                           FontWeight="SemiBold"
                                           Foreground="{atom:SharedTokenResource ColorText}"/>
                                <atom:CheckBox Grid.Row="2"
                                               Grid.Column="1"
                                               Grid.ColumnSpan="3"
                                               Content="转发 X11 连接到(X):"
                                               IsChecked="{Binding SshForwardX11, Mode=TwoWay}"/>
                                <StackPanel Grid.Row="4"
                                            Grid.Column="1"
                                            Grid.ColumnSpan="3"
                                            Spacing="8">
                                    <atom:RadioButton x:Name="SshX11XmanagerButton"
                                                      Content="Xmanager(M)"
                                                      GroupName="SshX11DisplayMode"
                                                      IsChecked="{Binding SshX11UseXmanager, Mode=TwoWay}"/>
                                    <Grid ColumnDefinitions="Auto,12,*">
                                        <atom:RadioButton x:Name="SshX11DisplayButton"
                                                          Content="X DISPLAY(D):"
                                                          GroupName="SshX11DisplayMode"
                                                          VerticalAlignment="Center"/>
                                        <atom:LineEdit Grid.Column="2"
                                                       x:Name="SshX11DisplayBox"
                                                       MinWidth="260"
                                                       MaxWidth="420"
                                                       HorizontalAlignment="Left"
                                                       Text="{Binding SshX11Display, Mode=TwoWay}"
                                                       PlaceholderText="localhost:0.0"/>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="TelnetPage" IsVisible="False">
                    <StackPanel Spacing="16">
                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <Grid RowDefinitions="Auto,14,Auto,22,Auto,12,Auto,12,Auto"
                                  ColumnDefinitions="140,360">
                                <TextBlock Grid.ColumnSpan="2"
                                           Text="XDISPLOC"
                                           FontWeight="SemiBold"
                                           Foreground="{atom:SharedTokenResource ColorText}"/>
                                <TextBlock Grid.Row="2"
                                           Grid.ColumnSpan="2"
                                           Text="使用 X 服务器时，可指定 DISPLAY 地址、显示编号和屏幕编号。"
                                           TextWrapping="Wrap"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:CheckBox Grid.Row="4"
                                               Grid.ColumnSpan="2"
                                               Content="使用 XDISPLOC Telnet 选项"
                                               IsChecked="{Binding TelnetUseXDisplayLocation, Mode=TwoWay}"/>
                                <TextBlock Grid.Row="6" Text="显示"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:LineEdit Grid.Row="6" Grid.Column="1"
                                              x:Name="TelnetXDisplayLocationBox"
                                              Text="{Binding TelnetXDisplayLocation, Mode=TwoWay}"
                                              PlaceholderText="$PCADDR:0.0"/>
                                <TextBlock Grid.Row="8"
                                           Grid.ColumnSpan="2"
                                           Text="注释：PCADDR 会替换为当前连接使用的本机 IP 地址。"
                                           TextWrapping="Wrap"
                                           Foreground="{atom:SharedTokenResource ColorTextTertiary}"/>
                            </Grid>
                        </Border>

                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <StackPanel Spacing="12">
                                <TextBlock Text="选项协商"
                                           FontWeight="SemiBold"
                                           Foreground="{atom:SharedTokenResource ColorText}"/>
                                <TextBlock Text="请选择 TELNET 选项协商模式："
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:RadioButton x:Name="TelnetPassiveOptionButton"
                                                  Content="Passive"
                                                  GroupName="TelnetOptionMode"/>
                                <atom:RadioButton x:Name="TelnetActiveOptionButton"
                                                  Content="Active"
                                                  GroupName="TelnetOptionMode"/>
                            </StackPanel>
                        </Border>

                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <StackPanel Spacing="12">
                                <TextBlock Text="选项"
                                           FontWeight="SemiBold"
                                           Foreground="{atom:SharedTokenResource ColorText}"/>
                                <atom:CheckBox Content="强制 Character-at-a-time 模式"
                                               IsChecked="{Binding TelnetForceCharacterAtATime, Mode=TwoWay}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="ProxyPage" IsVisible="False">
                    <StackPanel Spacing="16">
                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <Grid RowDefinitions="Auto,12,Auto,28,Auto"
                                  ColumnDefinitions="140,*,160">
                                <TextBlock Grid.ColumnSpan="3"
                                           Text="代理服务器"
                                           FontWeight="SemiBold"
                                           Foreground="{atom:SharedTokenResource ColorText}"/>
                                <TextBlock Grid.Row="2"
                                           Grid.ColumnSpan="3"
                                           Text="用户的网络环境使用代理服务器防火墙时，请在下方选择合适的代理服务器。要添加、编辑或删除代理服务器，请点击“浏览”。"
                                           TextWrapping="Wrap"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <TextBlock Grid.Row="4"
                                           Text="代理服务器(R):"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:Select Grid.Row="4"
                                             Grid.Column="1"
                                             x:Name="ProxySelect"
                                             Mode="Single"
                                             ShouldUseOverlayPopup="False"
                                             OptionsSource="{Binding ProxyOptions}"/>
                                <atom:Button Grid.Row="4"
                                             Grid.Column="2"
                                             Margin="14,0,0,0"
                                             Content="浏览(B)..."
                                             Click="OnBrowseProxyClick"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="RloginPage" IsVisible="False">
                    <StackPanel Spacing="16">
                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <Grid RowDefinitions="Auto,18,Auto"
                                  ColumnDefinitions="140,250,*">
                                <TextBlock Grid.ColumnSpan="3"
                                           Text="常规"
                                           FontWeight="SemiBold"
                                           Foreground="{atom:SharedTokenResource ColorText}"/>
                                <TextBlock Grid.Row="2"
                                           Text="终端速度(T):"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:Select Grid.Row="2"
                                             Grid.Column="1"
                                             x:Name="RloginTerminalSpeedSelect"
                                             Mode="Single"
                                             ShouldUseOverlayPopup="False"
                                             DisplayPageSize="15"
                                             HorizontalAlignment="Stretch"
                                             OptionsSource="{Binding TerminalSpeedOptions}"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="SftpPage" IsVisible="False">
                    <StackPanel Spacing="16">
                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <Grid RowDefinitions="Auto,14,Auto,28,Auto,12,Auto"
                                  ColumnDefinitions="140,*,40">
                                <TextBlock Grid.ColumnSpan="3"
                                           Text="启动文件夹"
                                           FontWeight="SemiBold"
                                           Foreground="{atom:SharedTokenResource ColorText}"/>
                                <TextBlock Grid.Row="2"
                                           Grid.ColumnSpan="3"
                                           Text="连接后自动指定转到的本地文件夹和远程文件夹。"
                                           TextWrapping="Wrap"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>

                                <TextBlock Grid.Row="4"
                                           Text="本地文件夹(L):"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:LineEdit Grid.Row="4"
                                               Grid.Column="1"
                                               x:Name="SftpLocalStartDirectoryBox"
                                               Text="{Binding SftpLocalStartDirectory, Mode=TwoWay}"
                                               PlaceholderText="选择上传和下载默认目录"/>
                                <atom:Button Grid.Row="4"
                                             Grid.Column="2"
                                             Content="..."
                                             Width="32"
                                             HorizontalAlignment="Right"
                                             Click="OnBrowseSftpLocalDirectoryClick"/>

                                <TextBlock Grid.Row="6"
                                           Text="远程文件夹(R):"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:LineEdit Grid.Row="6"
                                               Grid.Column="1"
                                               Grid.ColumnSpan="2"
                                               x:Name="SftpRemoteStartDirectoryBox"
                                               Text="{Binding SftpRemoteStartDirectory, Mode=TwoWay}"
                                               PlaceholderText="/var/www"/>
                            </Grid>
                        </Border>

                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <Grid RowDefinitions="Auto,14,Auto,12,Auto,8,Auto"
                                  ColumnDefinitions="140,*">
                                <TextBlock Grid.ColumnSpan="2"
                                           Text="SFTP服务器"
                                           FontWeight="SemiBold"
                                           Foreground="{atom:SharedTokenResource ColorText}"/>
                                <atom:CheckBox Grid.Row="2"
                                               Grid.ColumnSpan="2"
                                               Content="使用自定义SFTP服务器(S)"
                                               IsChecked="{Binding SftpUseCustomServer, Mode=TwoWay}"/>
                                <TextBlock Grid.Row="4"
                                           Text="命令(C):"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:LineEdit Grid.Row="4"
                                               Grid.Column="1"
                                               x:Name="SftpCustomServerCommandBox"
                                               IsEnabled="{Binding IsSftpCustomServerCommandEnabled}"
                                               Text="{Binding SftpCustomServerCommand, Mode=TwoWay}"
                                               PlaceholderText="/usr/lib/openssh/sftp-server"/>
                                <TextBlock Grid.Row="6"
                                           Grid.Column="1"
                                           Text="默认使用 SSH 标准 sftp subsystem；自定义命令保存到会话配置，当前连接时会提示需要低层通道支持。"
                                           TextWrapping="Wrap"
                                           Foreground="{atom:SharedTokenResource ColorTextTertiary}"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="SerialPage" IsVisible="False">
                    <StackPanel Spacing="16">
                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <Grid RowDefinitions="Auto,14,Auto,12,Auto,12,Auto,12,Auto,12,Auto,12,Auto"
                                  ColumnDefinitions="140,240">
                                <TextBlock Grid.ColumnSpan="2"
                                           Text="Serial"
                                           FontWeight="SemiBold"
                                           Foreground="{atom:SharedTokenResource ColorText}"/>

                                <TextBlock Grid.Row="2" Text="Port"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:Select Grid.Row="2" Grid.Column="1"
                                             x:Name="SerialPortSelect"
                                             Mode="Single"
                                             Status="{Binding SerialPortStatus}"
                                             OptionsSource="{Binding SerialPortOptions}"/>

                                <TextBlock Grid.Row="4" Text="Baud rate"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:Select Grid.Row="4" Grid.Column="1"
                                             x:Name="SerialBaudRateSelect"
                                             Mode="Single"
                                             OptionsSource="{Binding SerialBaudRateOptions}"/>

                                <TextBlock Grid.Row="6" Text="Data bits"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:Select Grid.Row="6" Grid.Column="1"
                                             x:Name="SerialDataBitsSelect"
                                             Mode="Single"
                                             OptionsSource="{Binding SerialDataBitsOptions}"/>

                                <TextBlock Grid.Row="8" Text="Stop bits"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:Select Grid.Row="8" Grid.Column="1"
                                             x:Name="SerialStopBitsSelect"
                                             Mode="Single"
                                             OptionsSource="{Binding SerialStopBitsOptions}"/>

                                <TextBlock Grid.Row="10" Text="Parity"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:Select Grid.Row="10" Grid.Column="1"
                                             x:Name="SerialParitySelect"
                                             Mode="Single"
                                             OptionsSource="{Binding SerialParityOptions}"/>

                                <TextBlock Grid.Row="12" Text="Flow control"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:Select Grid.Row="12" Grid.Column="1"
                                             x:Name="SerialFlowControlSelect"
                                             Mode="Single"
                                             OptionsSource="{Binding SerialFlowControlOptions}"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="RdpPage" IsVisible="False">
                    <StackPanel Spacing="16">
                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <Grid RowDefinitions="Auto,14,Auto,12,Auto,12,Auto,12,Auto"
                                  ColumnDefinitions="150,280,18,112,24,112,*"
                                  ColumnSpacing="8">
                                <TextBlock Grid.ColumnSpan="7"
                                           Text="显示"
                                           FontWeight="SemiBold"
                                           Foreground="{atom:SharedTokenResource ColorText}"/>

                                <TextBlock Grid.Row="2" Text="窗口大小"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:Select Grid.Row="2" Grid.Column="1"
                                             x:Name="RdpWindowSizeSelect"
                                             Mode="Single"
                                             HorizontalAlignment="Stretch"
                                             OptionsSource="{Binding RdpWindowSizeOptions}"/>
                                <atom:LineEdit Grid.Row="2" Grid.Column="3"
                                               x:Name="RdpWidthBox"
                                               HorizontalAlignment="Stretch"
                                               Text="{Binding RdpDesktopWidth, Mode=TwoWay}"/>
                                <TextBlock Grid.Row="2" Grid.Column="4"
                                           Text="x"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:LineEdit Grid.Row="2" Grid.Column="5"
                                               x:Name="RdpHeightBox"
                                               HorizontalAlignment="Stretch"
                                               Text="{Binding RdpDesktopHeight, Mode=TwoWay}"/>

                                <TextBlock Grid.Row="4" Text="改变屏幕大小"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:Select Grid.Row="4" Grid.Column="1"
                                             Grid.ColumnSpan="5"
                                             x:Name="RdpResizeModeSelect"
                                             Mode="Single"
                                             HorizontalAlignment="Stretch"
                                             OptionsSource="{Binding RdpResizeModeOptions}"/>

                                <TextBlock Grid.Row="6" Text="屏幕缩放"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:Select Grid.Row="6" Grid.Column="1"
                                             x:Name="RdpScreenScaleSelect"
                                             Mode="Single"
                                             HorizontalAlignment="Stretch"
                                             OptionsSource="{Binding RdpScreenScaleOptions}"/>

                                <TextBlock Grid.Row="8" Text="颜色质量"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:Select Grid.Row="8" Grid.Column="1"
                                             x:Name="RdpColorQualitySelect"
                                             Mode="Single"
                                             HorizontalAlignment="Stretch"
                                             OptionsSource="{Binding RdpColorQualityOptions}"/>
                            </Grid>
                        </Border>

                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <StackPanel Spacing="14">
                                <TextBlock Text="设备"
                                           FontWeight="SemiBold"
                                           Foreground="{atom:SharedTokenResource ColorText}"/>
                                <atom:CheckBox Content="在远程计算机上应用密钥组合"
                                               IsChecked="{Binding RdpApplyKeyCombinations, Mode=TwoWay}"/>
                                <atom:CheckBox Content="与远程计算机分享该计算机的驱动器"
                                               IsChecked="{Binding RdpRedirectDrives, Mode=TwoWay}"/>
                            </StackPanel>
                        </Border>

                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <Grid RowDefinitions="Auto,14,Auto,12,Auto"
                                  ColumnDefinitions="150,*">
                                <TextBlock Grid.ColumnSpan="2"
                                           Text="声音"
                                           FontWeight="SemiBold"
                                           Foreground="{atom:SharedTokenResource ColorText}"/>
                                <TextBlock Grid.Row="2" Text="远程音频播放"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:Select Grid.Row="2" Grid.Column="1"
                                             x:Name="RdpAudioModeSelect"
                                             Mode="Single"
                                             OptionsSource="{Binding RdpAudioModeOptions}"/>
                                <atom:CheckBox Grid.Row="4" Grid.Column="1"
                                               Content="从这台电脑录制"
                                               IsChecked="{Binding RdpAudioCapture, Mode=TwoWay}"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="TerminalPage"
                              IsVisible="{Binding IsTerminalPage}"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="16">
                        <TextBlock Text="终端" FontSize="18" FontWeight="SemiBold"/>

                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <StackPanel Spacing="14">
                                <TextBlock Text="仿真" FontWeight="SemiBold"/>
                                <Grid ColumnDefinitions="120,240,48,90,120"
                                      RowDefinitions="Auto,14,Auto"
                                      ColumnSpacing="10"
                                      HorizontalAlignment="Left">
                                    <TextBlock Text="终端类型(T):" VerticalAlignment="Center"/>
                                    <atom:Select Grid.Column="1"
                                                 x:Name="SessionTerminalTypeSelect"
                                                 OptionsSource="{Binding TerminalTypeOptions}"
                                                 Mode="Single"
                                                 HorizontalAlignment="Stretch"/>
                                    <TextBlock Grid.Row="2" Text="列(O):" VerticalAlignment="Center"/>
                                    <atom:NumericUpDown Grid.Row="2"
                                                        Grid.Column="1"
                                                        Minimum="20"
                                                        Maximum="500"
                                                        HorizontalAlignment="Stretch"
                                                        Value="{Binding TerminalColumns, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="3" Text="行(R):" VerticalAlignment="Center"/>
                                    <atom:NumericUpDown Grid.Row="2"
                                                        Grid.Column="4"
                                                        Minimum="5"
                                                        Maximum="200"
                                                        HorizontalAlignment="Stretch"
                                                        Value="{Binding TerminalRows, Mode=TwoWay}"/>
                                </Grid>
                                <WrapPanel>
                                    <atom:CheckBox Content="固定终端大小(F)"
                                                   Margin="0,0,18,8"
                                                   IsChecked="{Binding TerminalFixedSize, Mode=TwoWay}"/>
                                    <atom:CheckBox Content="连接时重置端子尺寸(C)"
                                                   Margin="0,0,18,8"
                                                   IsChecked="{Binding TerminalResetSizeOnConnect, Mode=TwoWay}"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <StackPanel Spacing="14">
                                <TextBlock Text="滚动缓冲区" FontWeight="SemiBold"/>
                                <Grid ColumnDefinitions="120,220,40,*"
                                      ColumnSpacing="10">
                                    <TextBlock Text="缓冲区大小(S):" VerticalAlignment="Center"/>
                                    <atom:NumericUpDown Grid.Column="1"
                                                        Minimum="0"
                                                        Maximum="200000"
                                                        HorizontalAlignment="Stretch"
                                                        Value="{Binding TerminalScrollbackSize, Mode=TwoWay}"/>
                                    <TextBlock Grid.Column="2" Text="行" VerticalAlignment="Center"/>
                                    <atom:CheckBox Grid.Column="3"
                                                   Content="将清除的屏幕推到滚动缓冲区(P)"
                                                   IsChecked="{Binding TerminalPushClearedScreenToScrollback, Mode=TwoWay}"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <StackPanel Spacing="14">
                                <TextBlock Text="转换" FontWeight="SemiBold"/>
                                <Grid ColumnDefinitions="120,300"
                                      RowDefinitions="Auto,14,Auto"
                                      ColumnSpacing="10"
                                      HorizontalAlignment="Left">
                                    <TextBlock Text="编码(E):" VerticalAlignment="Center"/>
                                    <atom:Select Grid.Column="1"
                                                 x:Name="SessionTerminalEncodingSelect"
                                                 OptionsSource="{Binding EncodingOptions}"
                                                 Mode="Single"
                                                 HorizontalAlignment="Stretch"/>
                                    <TextBlock Grid.Row="2" Text="模糊宽度字符(A):" VerticalAlignment="Center"/>
                                    <atom:CheckBox Grid.Row="2"
                                                   Grid.Column="1"
                                                   Content="将含糊的大小字符视为宽字符"
                                                   IsChecked="{Binding TerminalTreatAmbiguousAsWide, Mode=TwoWay}"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <StackPanel Spacing="14">
                                <TextBlock Text="换行符" FontWeight="SemiBold"/>
                                <Grid ColumnDefinitions="120,220,60,220"
                                      ColumnSpacing="10"
                                      HorizontalAlignment="Left">
                                    <TextBlock Text="发送(D):" VerticalAlignment="Center"/>
                                    <atom:Select Grid.Column="1"
                                                 x:Name="SessionTerminalSendLineEndingSelect"
                                                 OptionsSource="{Binding SendLineEndingOptions}"
                                                 Mode="Single"
                                                 HorizontalAlignment="Stretch"/>
                                    <TextBlock Grid.Column="2" Text="收到(V):" VerticalAlignment="Center"/>
                                    <atom:Select Grid.Column="3"
                                                 x:Name="SessionTerminalReceiveLineEndingSelect"
                                                 OptionsSource="{Binding ReceiveLineEndingOptions}"
                                                 Mode="Single"
                                                 HorizontalAlignment="Stretch"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="AppearancePage"
                              IsVisible="{Binding IsAppearancePage}"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="16">
                        <TextBlock Text="外观" FontSize="18" FontWeight="SemiBold"/>

                        <StackPanel Spacing="8">
                            <TextBlock Text="预览:" FontWeight="SemiBold"/>
                            <Border x:Name="SessionAppearancePreviewBorder"
                                    Padding="10"
                                    MinHeight="128"
                                    Background="{Binding AppearanceBackgroundBrush}"
                                    BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                    BorderThickness="1"
                                    CornerRadius="4">
                                <StackPanel Spacing="1">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="Normal"
                                                   FontFamily="{Binding AppearancePreviewFontFamily}"
                                                   FontSize="{Binding AppearanceFontSize}"
                                                   FontStyle="{Binding AppearancePreviewFontStyle}"
                                                   FontWeight="{Binding AppearancePreviewFontWeight}"
                                                   Foreground="{Binding AppearanceForegroundBrush}"/>
                                        <TextBlock Text="Bold"
                                                   FontFamily="{Binding AppearancePreviewFontFamily}"
                                                   FontSize="{Binding AppearanceFontSize}"
                                                   FontStyle="{Binding AppearancePreviewFontStyle}"
                                                   FontWeight="{Binding AppearancePreviewBoldWeight}"
                                                   Foreground="{Binding AppearancePreviewBoldBrush}"/>
                                        <TextBlock Text="Underline"
                                                   FontFamily="{Binding AppearancePreviewFontFamily}"
                                                   FontSize="{Binding AppearanceFontSize}"
                                                   TextDecorations="Underline"
                                                   Foreground="{Binding AppearanceForegroundBrush}"/>
                                        <TextBlock Text="Reversed"
                                                   FontFamily="{Binding AppearancePreviewFontFamily}"
                                                   FontSize="{Binding AppearanceFontSize}"
                                                   Background="{Binding AppearanceForegroundBrush}"
                                                   Foreground="{Binding AppearanceBackgroundBrush}"/>
                                        <StackPanel Orientation="Horizontal" Spacing="0">
                                            <Grid Width="10" Height="24">
                                                <TextBlock Text="C"
                                                           FontFamily="{Binding AppearancePreviewFontFamily}"
                                                           FontSize="{Binding AppearanceFontSize}"
                                                           Foreground="{Binding AppearanceForegroundBrush}"/>
                                                <Border Height="{Binding AppearanceFontSize}"
                                                        Background="{Binding AppearanceCursorBrush}"
                                                        IsVisible="{Binding IsAppearanceCursorBlockVisible}">
                                                    <TextBlock Text="C"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               FontFamily="{Binding AppearancePreviewFontFamily}"
                                                               FontSize="{Binding AppearanceFontSize}"
                                                               Foreground="{Binding AppearanceCursorTextBrush}"/>
                                                </Border>
                                                <Border Width="3"
                                                        Height="{Binding AppearanceFontSize}"
                                                        HorizontalAlignment="Left"
                                                        Background="{Binding AppearanceCursorBrush}"
                                                        IsVisible="{Binding IsAppearanceCursorVerticalVisible}"/>
                                                <Border Height="3"
                                                        VerticalAlignment="Bottom"
                                                        Background="{Binding AppearanceCursorBrush}"
                                                        IsVisible="{Binding IsAppearanceCursorUnderlineVisible}"/>
                                            </Grid>
                                            <TextBlock Text="ursor"
                                                       FontFamily="{Binding AppearancePreviewFontFamily}"
                                                       FontSize="{Binding AppearanceFontSize}"
                                                       Foreground="{Binding AppearanceForegroundBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <TextBlock FontFamily="{Binding AppearancePreviewFontFamily}"
                                               FontSize="{Binding AppearanceFontSize}">
                                        <Run Text="black " Foreground="{Binding AppearanceAnsiBlackBrush}"/>
                                        <Run Text="red " Foreground="{Binding AppearanceAnsiRedBrush}"/>
                                        <Run Text="green " Foreground="{Binding AppearanceAnsiGreenBrush}"/>
                                        <Run Text="yellow " Foreground="{Binding AppearanceAnsiYellowBrush}"/>
                                        <Run Text="blue " Foreground="{Binding AppearanceAnsiBlueBrush}"/>
                                        <Run Text="magenta " Foreground="{Binding AppearanceAnsiMagentaBrush}"/>
                                        <Run Text="cyan " Foreground="{Binding AppearanceAnsiCyanBrush}"/>
                                        <Run Text="white" Foreground="{Binding AppearanceAnsiWhiteBrush}"/>
                                    </TextBlock>
                                    <TextBlock FontFamily="{Binding AppearancePreviewCjkFontFamily}"
                                               FontSize="{Binding AppearanceCjkFontSize}"
                                               FontWeight="{Binding AppearancePreviewBoldWeight}"
                                               Text="文本颜色  使用大胆的颜色和字体"
                                               Foreground="{Binding AppearancePreviewBoldBrush}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <Grid ColumnDefinitions="120,*" ColumnSpacing="12">
                            <TextBlock Text="配色方案(O):" VerticalAlignment="Center"/>
                            <atom:Select Grid.Column="1"
                                         x:Name="SessionAppearanceColorSchemeSelect"
                                         OptionsSource="{Binding AppearanceColorSchemeOptions}"
                                         Mode="Single"
                                         SelectionChanged="OnSessionAppearanceSelectionChanged"
                                         HorizontalAlignment="Stretch"/>
                        </Grid>

                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <StackPanel Spacing="14">
                                <TextBlock Text="字体" FontWeight="SemiBold"/>
                                <Grid ColumnDefinitions="120,*,12,156,12,112"
                                      RowDefinitions="Auto,14,Auto,14,Auto,14,Auto"
                                      ColumnSpacing="0">
                                    <TextBlock Text="字体(F):" VerticalAlignment="Center"/>
                                    <atom:Select Grid.Column="1"
                                                 x:Name="SessionAppearanceFontSelect"
                                                 OptionsSource="{Binding AppearanceFontOptions}"
                                                 Mode="Single"
                                                 SelectionChanged="OnSessionAppearanceSelectionChanged"
                                                 HorizontalAlignment="Stretch"/>
                                    <atom:Select Grid.Column="3"
                                                 x:Name="SessionAppearanceFontStyleSelect"
                                                 OptionsSource="{Binding AppearanceFontStyleOptions}"
                                                 Mode="Single"
                                                 SelectionChanged="OnSessionAppearanceSelectionChanged"
                                                 HorizontalAlignment="Stretch"/>
                                    <atom:NumericUpDown Grid.Column="5"
                                                        Minimum="6"
                                                        Maximum="96"
                                                        Value="{Binding AppearanceFontSize, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="2" Text="亚洲字体(S):" VerticalAlignment="Center"/>
                                    <atom:Select Grid.Row="2"
                                                 Grid.Column="1"
                                                 x:Name="SessionAppearanceCjkFontSelect"
                                                 OptionsSource="{Binding AppearanceFontOptions}"
                                                 Mode="Single"
                                                 SelectionChanged="OnSessionAppearanceSelectionChanged"
                                                 HorizontalAlignment="Stretch"/>
                                    <atom:Select Grid.Row="2"
                                                 Grid.Column="3"
                                                 x:Name="SessionAppearanceCjkFontStyleSelect"
                                                 OptionsSource="{Binding AppearanceFontStyleOptions}"
                                                 Mode="Single"
                                                 SelectionChanged="OnSessionAppearanceSelectionChanged"
                                                 HorizontalAlignment="Stretch"/>
                                    <atom:NumericUpDown Grid.Row="2"
                                                        Grid.Column="5"
                                                        Minimum="6"
                                                        Maximum="96"
                                                        Value="{Binding AppearanceCjkFontSize, Mode=TwoWay}"/>
                                    <atom:CheckBox Grid.Row="4"
                                                   Grid.Column="1"
                                                   Grid.ColumnSpan="5"
                                                   Content="使用可变间距字体(V)"
                                                   IsChecked="{Binding AppearanceUseVariablePitchFont, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="6" Text="字体质量(Q):" VerticalAlignment="Center"/>
                                    <atom:Select Grid.Row="6"
                                                 Grid.Column="1"
                                                 x:Name="SessionAppearanceFontQualitySelect"
                                                 OptionsSource="{Binding AppearanceFontQualityOptions}"
                                                 Mode="Single"
                                                 SelectionChanged="OnSessionAppearanceSelectionChanged"
                                                 HorizontalAlignment="Stretch"/>
                                    <TextBlock Grid.Row="6" Grid.Column="3" Text="“加粗”文本(B):" VerticalAlignment="Center"/>
                                    <atom:Select Grid.Row="6"
                                                 Grid.Column="5"
                                                 x:Name="SessionAppearanceBoldTextModeSelect"
                                                 OptionsSource="{Binding AppearanceBoldTextModeOptions}"
                                                 Mode="Single"
                                                 SelectionChanged="OnSessionAppearanceSelectionChanged"
                                                 HorizontalAlignment="Stretch"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <StackPanel Spacing="14">
                                <TextBlock Text="游标" FontWeight="SemiBold"/>
                                <Grid ColumnDefinitions="120,180,28,90,112,72"
                                      RowDefinitions="Auto,14,Auto,14,Auto"
                                      ColumnSpacing="10">
                                    <TextBlock Text="游标颜色(R):" VerticalAlignment="Center"/>
                                    <atom:ColorPicker Grid.Column="1"
                                                      Value="{Binding AppearanceCursorColor, Mode=TwoWay}"/>
                                    <atom:CheckBox Grid.Column="3"
                                                   Grid.ColumnSpan="3"
                                                   Content="使用闪烁的光标(U)"
                                                   IsChecked="{Binding AppearanceUseBlinkingCursor, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="2" Text="文本颜色(T):" VerticalAlignment="Center"/>
                                    <atom:ColorPicker Grid.Row="2"
                                                      Grid.Column="1"
                                                      Value="{Binding AppearanceCursorTextColor, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="3" Text="速度(P):" VerticalAlignment="Center"/>
                                    <atom:NumericUpDown Grid.Row="2"
                                                        Grid.Column="4"
                                                        Minimum="1"
                                                        Maximum="5000"
                                                        Width="104"
                                                        HorizontalAlignment="Left"
                                                        Value="{Binding AppearanceCursorBlinkSpeedMilliseconds, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="5" Text="millisec" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="4" Text="外观(A):" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Row="4"
                                                Grid.Column="1"
                                                Grid.ColumnSpan="5"
                                                Orientation="Horizontal"
                                                Spacing="32">
                                        <atom:RadioButton Content="块" GroupName="SessionCursorShape"
                                                          IsChecked="{Binding IsAppearanceCursorShapeBlock, Mode=TwoWay}"/>
                                        <atom:RadioButton Content="竖线" GroupName="SessionCursorShape"
                                                          IsChecked="{Binding IsAppearanceCursorShapeVertical, Mode=TwoWay}"/>
                                        <atom:RadioButton Content="下划线" GroupName="SessionCursorShape"
                                                          IsChecked="{Binding IsAppearanceCursorShapeUnderline, Mode=TwoWay}"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="AppearanceWindowPage"
                              IsVisible="{Binding IsAppearanceWindowPage}"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="16">
                        <TextBlock Text="外观 > 窗口" FontSize="18" FontWeight="SemiBold"/>
                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <StackPanel Spacing="18">
                                <TextBlock Text="边距" FontWeight="SemiBold"/>
                                <Grid ColumnDefinitions="90,112,96,90,112"
                                      RowDefinitions="Auto,14,Auto"
                                      ColumnSpacing="14">
                                    <TextBlock Text="顶(T):" VerticalAlignment="Center"/>
                                    <atom:NumericUpDown Grid.Column="1" Minimum="0" Maximum="200"
                                                        Value="{Binding AppearanceWindowPaddingTop, Mode=TwoWay}"/>
                                    <TextBlock Grid.Column="3" Text="底部(B):" VerticalAlignment="Center"/>
                                    <atom:NumericUpDown Grid.Column="4" Minimum="0" Maximum="200"
                                                        Value="{Binding AppearanceWindowPaddingBottom, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="2" Text="左(L):" VerticalAlignment="Center"/>
                                    <atom:NumericUpDown Grid.Row="2" Grid.Column="1" Minimum="0" Maximum="200"
                                                        Value="{Binding AppearanceWindowPaddingLeft, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="3" Text="右(R):" VerticalAlignment="Center"/>
                                    <atom:NumericUpDown Grid.Row="2" Grid.Column="4" Minimum="0" Maximum="200"
                                                        Value="{Binding AppearanceWindowPaddingRight, Mode=TwoWay}"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <StackPanel Spacing="18">
                                <TextBlock Text="间隔" FontWeight="SemiBold"/>
                                <Grid ColumnDefinitions="110,112,90,Auto"
                                      RowDefinitions="Auto,14,Auto"
                                      ColumnSpacing="14">
                                    <TextBlock Text="行距(I):" VerticalAlignment="Center"/>
                                    <atom:NumericUpDown Grid.Column="1" Minimum="-5" Maximum="32"
                                                        Value="{Binding AppearanceLineSpacing, Mode=TwoWay}"/>
                                    <TextBlock Grid.Column="3" Text="(-5 ~ 32)" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="2" Text="字符间距(H):" VerticalAlignment="Center"/>
                                    <atom:NumericUpDown Grid.Row="2" Grid.Column="1" Minimum="-5" Maximum="32"
                                                        Value="{Binding AppearanceCharacterSpacing, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="3" Text="(-5 ~ 32)" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <StackPanel Spacing="14">
                                <TextBlock Text="工作表标签颜色" FontWeight="SemiBold"/>
                                <StackPanel Orientation="Horizontal" Spacing="22">
                                    <atom:RadioButton Content="默认" GroupName="SessionAppearanceTabColor"
                                                      IsChecked="{Binding IsAppearanceTabColorDefault, Mode=TwoWay}"/>
                                    <atom:RadioButton Content="红" GroupName="SessionAppearanceTabColor"
                                                      IsChecked="{Binding IsAppearanceTabColorRed, Mode=TwoWay}"/>
                                    <atom:RadioButton Content="紫色" GroupName="SessionAppearanceTabColor"
                                                      IsChecked="{Binding IsAppearanceTabColorPurple, Mode=TwoWay}"/>
                                    <atom:RadioButton Content="黄色" GroupName="SessionAppearanceTabColor"
                                                      IsChecked="{Binding IsAppearanceTabColorYellow, Mode=TwoWay}"/>
                                    <atom:RadioButton Content="其他:" GroupName="SessionAppearanceTabColor"
                                                      IsChecked="{Binding IsAppearanceTabColorCustom, Mode=TwoWay}"/>
                                    <atom:ColorPicker Width="116"
                                                      Value="{Binding AppearanceTabCustomColor, Mode=TwoWay}"
                                                      IsEnabled="{Binding IsAppearanceTabColorCustom}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <StackPanel Spacing="14">
                                <TextBlock Text="背景图" FontWeight="SemiBold"/>
                                <Grid ColumnDefinitions="110,*,34"
                                      RowDefinitions="Auto,14,Auto"
                                      ColumnSpacing="10">
                                    <TextBlock Text="文件(F):" VerticalAlignment="Center"/>
                                    <atom:LineEdit Grid.Column="1"
                                                   x:Name="SessionAppearanceBackgroundImagePathBox"
                                                   Text="{Binding AppearanceBackgroundImagePath, Mode=TwoWay}"/>
                                    <atom:Button Grid.Column="2"
                                                 Content="..."
                                                 Click="OnBrowseSessionAppearanceBackgroundImageClick"/>
                                    <TextBlock Grid.Row="2" Text="位置(P):" VerticalAlignment="Center"/>
                                    <atom:Select Grid.Row="2"
                                                 Grid.Column="1"
                                                 x:Name="SessionAppearanceBackgroundImagePositionSelect"
                                                 OptionsSource="{Binding AppearanceBackgroundImagePositionOptions}"
                                                 Mode="Single"
                                                 SelectionChanged="OnSessionAppearanceSelectionChanged"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <StackPanel Spacing="14">
                                <TextBlock Text="突出显示" FontWeight="SemiBold"/>
                                <Grid ColumnDefinitions="120,*,12,116" ColumnSpacing="14">
                                    <TextBlock Text="高亮集" VerticalAlignment="Center"/>
                                    <atom:Select Grid.Column="1"
                                                 x:Name="SessionAppearanceHighlightSetSelect"
                                                 OptionsSource="{Binding AppearanceHighlightSetOptions}"
                                                 Mode="Single"
                                                 SelectionChanged="OnSessionAppearanceSelectionChanged"/>
                                    <atom:Button Grid.Column="3"
                                                 Content="浏览(B)..."
                                                 Click="OnBrowseSessionAppearanceHighlightSetsClick"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="KeyboardPage"
                              IsVisible="{Binding IsKeyboardPage}"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="18">
                        <TextBlock Text="键盘" FontSize="18" FontWeight="SemiBold"/>
                        <Grid ColumnDefinitions="120,*"
                              RowDefinitions="Auto,14,Auto,14,Auto,14,Auto"
                              ColumnSpacing="14">
                            <TextBlock Text="功能键模式" VerticalAlignment="Center"/>
                            <atom:Select Grid.Column="1"
                                         x:Name="SessionFunctionKeySelect"
                                         OptionsSource="{Binding FunctionKeyOptions}"
                                         Mode="Single"/>
                            <TextBlock Grid.Row="2" Text="Delete 键" VerticalAlignment="Center"/>
                            <atom:LineEdit Grid.Row="2" Grid.Column="1"
                                           Text="{Binding TerminalDeleteKeySequence, Mode=TwoWay}"/>
                            <TextBlock Grid.Row="4" Text="Backspace 键" VerticalAlignment="Center"/>
                            <atom:LineEdit Grid.Row="4" Grid.Column="1"
                                           Text="{Binding TerminalBackspaceKeySequence, Mode=TwoWay}"/>
                            <TextBlock Grid.Row="6" Text="映射文件" VerticalAlignment="Center"/>
                            <atom:LineEdit Grid.Row="6" Grid.Column="1"
                                           IsEnabled="{Binding IsKeyboardMappingFileEnabled}"
                                           Text="{Binding TerminalKeyboardMappingFile, Mode=TwoWay}"/>
                        </Grid>
                        <WrapPanel>
                            <atom:CheckBox Content="左 Alt 作为 Meta" Margin="0,0,18,8"
                                           IsChecked="{Binding TerminalLeftAltAsMeta, Mode=TwoWay}"/>
                            <atom:CheckBox Content="右 Alt 作为 Meta" Margin="0,0,18,8"
                                           IsChecked="{Binding TerminalRightAltAsMeta, Mode=TwoWay}"/>
                            <atom:CheckBox Content="Ctrl+Alt 作为 AltGr" Margin="0,0,18,8"
                                           IsChecked="{Binding TerminalCtrlAltAsAltGr, Mode=TwoWay}"/>
                        </WrapPanel>
                        <TextBlock Text="VT 模式" FontWeight="SemiBold"/>
                        <Grid ColumnDefinitions="120,*,24,120,*" ColumnSpacing="14">
                            <TextBlock Text="光标键模式" VerticalAlignment="Center"/>
                            <atom:Select Grid.Column="1"
                                         x:Name="SessionTerminalVtCursorKeyModeSelect"
                                         OptionsSource="{Binding TerminalVtCursorKeyModeOptions}"
                                         Mode="Single"/>
                            <TextBlock Grid.Column="3" Text="数字键盘模式" VerticalAlignment="Center"/>
                            <atom:Select Grid.Column="4"
                                         x:Name="SessionTerminalVtNumericKeypadModeSelect"
                                         OptionsSource="{Binding TerminalVtNumericKeypadModeOptions}"
                                         Mode="Single"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="TransferPage"
                              IsVisible="{Binding IsTransferPage}"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="18">
                        <TextBlock Text="文件传输" FontSize="18" FontWeight="SemiBold"/>
                        <atom:CheckBox Content="下载前总是询问保存目录"
                                       IsChecked="{Binding FileTransferAlwaysAskDownloadFolder, Mode=TwoWay}"/>
                        <Grid ColumnDefinitions="120,*"
                              RowDefinitions="Auto,14,Auto"
                              ColumnSpacing="14">
                            <TextBlock Text="下载目录" VerticalAlignment="Center"/>
                            <atom:LineEdit Grid.Column="1"
                                           IsEnabled="{Binding IsFileTransferPathSettingsEnabled}"
                                           Text="{Binding FileTransferDownloadDirectory, Mode=TwoWay}"/>
                            <TextBlock Grid.Row="2" Text="上传目录" VerticalAlignment="Center"/>
                            <atom:LineEdit Grid.Row="2" Grid.Column="1"
                                           IsEnabled="{Binding IsFileTransferPathSettingsEnabled}"
                                           Text="{Binding FileTransferUploadDirectory, Mode=TwoWay}"/>
                        </Grid>
                        <TextBlock Text="重复文件处理" FontWeight="SemiBold"/>
                        <StackPanel Orientation="Horizontal" Spacing="18">
                            <atom:RadioButton Content="自动重命名" GroupName="SessionFileTransferDuplicate"
                                              IsChecked="{Binding IsFileTransferDuplicateAutoRename, Mode=TwoWay}"/>
                            <atom:RadioButton Content="覆盖" GroupName="SessionFileTransferDuplicate"
                                              IsChecked="{Binding IsFileTransferDuplicateOverwrite, Mode=TwoWay}"/>
                        </StackPanel>
                        <TextBlock Text="默认上传协议" FontWeight="SemiBold"/>
                        <StackPanel Orientation="Horizontal" Spacing="18">
                            <atom:RadioButton Content="XMODEM" GroupName="SessionFileTransferUpload"
                                              IsChecked="{Binding IsFileTransferUploadProtocolXmodem, Mode=TwoWay}"/>
                            <atom:RadioButton Content="YMODEM" GroupName="SessionFileTransferUpload"
                                              IsChecked="{Binding IsFileTransferUploadProtocolYmodem, Mode=TwoWay}"/>
                            <atom:RadioButton Content="ZMODEM" GroupName="SessionFileTransferUpload"
                                              IsChecked="{Binding IsFileTransferUploadProtocolZmodem, Mode=TwoWay}"/>
                            <atom:RadioButton Content="FTP" GroupName="SessionFileTransferUpload"
                                              IsChecked="{Binding IsFileTransferUploadProtocolFtp, Mode=TwoWay}"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="LoggingPage"
                              IsVisible="{Binding IsLoggingPage}"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="18">
                        <TextBlock Text="日志" FontSize="18" FontWeight="SemiBold"/>
                        <Grid ColumnDefinitions="120,*"
                              RowDefinitions="Auto,14,Auto,14,Auto,14,Auto"
                              ColumnSpacing="14">
                            <TextBlock Text="日志路径" VerticalAlignment="Center"/>
                            <atom:LineEdit Grid.Column="1"
                                           Text="{Binding AdvancedLogFilePath, Mode=TwoWay}"/>
                            <TextBlock Grid.Row="2" Text="编码" VerticalAlignment="Center"/>
                            <atom:Select Grid.Row="2"
                                         Grid.Column="1"
                                         x:Name="SessionLogEncodingSelect"
                                         OptionsSource="{Binding LogEncodingOptions}"
                                         Mode="Single"/>
                            <atom:CheckBox Grid.Row="4" Grid.ColumnSpan="2"
                                           Content="写入时间戳"
                                           IsChecked="{Binding AdvancedLogWriteTimestamp, Mode=TwoWay}"/>
                            <TextBlock Grid.Row="6" Text="时间戳格式" VerticalAlignment="Center"/>
                            <atom:LineEdit Grid.Row="6" Grid.Column="1"
                                           Text="{Binding AdvancedLogTimestampFormat, Mode=TwoWay}"/>
                        </Grid>
                        <WrapPanel>
                            <atom:CheckBox Content="覆盖已有文件" Margin="0,0,18,8"
                                           IsChecked="{Binding AdvancedLogOverwriteExisting, Mode=TwoWay}"/>
                            <atom:CheckBox Content="连接时开始记录" Margin="0,0,18,8"
                                           IsChecked="{Binding AdvancedLogStartOnConnect, Mode=TwoWay}"/>
                            <atom:CheckBox Content="启动时提示文件" Margin="0,0,18,8"
                                           IsChecked="{Binding AdvancedLogPromptFileOnStart, Mode=TwoWay}"/>
                            <atom:CheckBox Content="使用 RTF" Margin="0,0,18,8"
                                           IsChecked="{Binding AdvancedLogUseRtf, Mode=TwoWay}"/>
                            <atom:CheckBox Content="包含终端控制码" Margin="0,0,18,8"
                                           IsChecked="{Binding AdvancedLogIncludeTerminalCodes, Mode=TwoWay}"/>
                        </WrapPanel>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="BellPage"
                              IsVisible="{Binding IsBellPage}"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="18">
                        <TextBlock Text="响铃" FontSize="18" FontWeight="SemiBold"/>
                        <StackPanel Orientation="Horizontal" Spacing="18">
                            <atom:RadioButton Content="默认提示音" GroupName="SessionBellMode"
                                              IsChecked="{Binding IsAdvancedBellModeDefault, Mode=TwoWay}"/>
                            <atom:RadioButton Content="忽略响铃" GroupName="SessionBellMode"
                                              IsChecked="{Binding IsAdvancedBellModeNone, Mode=TwoWay}"/>
                            <atom:RadioButton Content="内置响铃" GroupName="SessionBellMode"
                                              IsChecked="{Binding IsAdvancedBellModeBuiltin, Mode=TwoWay}"/>
                            <atom:RadioButton Content="声音文件" GroupName="SessionBellMode"
                                              IsChecked="{Binding IsAdvancedBellModeSound, Mode=TwoWay}"/>
                        </StackPanel>
                        <atom:LineEdit PlaceholderText="自定义声音文件"
                                       Text="{Binding AdvancedBellSoundPath, Mode=TwoWay}"
                                       IsEnabled="{Binding IsAdvancedBellSoundPathEnabled}"/>
                        <Grid ColumnDefinitions="120,*,24,120,*"
                              RowDefinitions="Auto,14,Auto"
                              ColumnSpacing="14">
                            <TextBlock Text="忽略重复(秒)" VerticalAlignment="Center"/>
                            <atom:NumericUpDown Grid.Column="1" Minimum="1" Maximum="3600"
                                                Value="{Binding AdvancedBellIgnoreRepeatedSeconds, Mode=TwoWay}"/>
                            <TextBlock Grid.Column="3" Text="重新激活(秒)" VerticalAlignment="Center"/>
                            <atom:NumericUpDown Grid.Column="4" Minimum="1" Maximum="3600"
                                                Value="{Binding AdvancedBellReactivateAfterSeconds, Mode=TwoWay}"/>
                            <atom:CheckBox Grid.Row="2" Grid.ColumnSpan="4"
                                           Content="焦点不在窗口时闪烁窗口"
                                           IsChecked="{Binding AdvancedBellFlashInactiveWindow, Mode=TwoWay}"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="AdvancedPage"
                              IsVisible="{Binding IsAdvancedPage}"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="18">
                        <TextBlock Text="高级" FontSize="18" FontWeight="SemiBold"/>
                        <Grid ColumnDefinitions="120,*,24,120,*"
                              RowDefinitions="Auto,14,Auto,14,Auto,14,Auto,14,Auto"
                              ColumnSpacing="14">
                            <TextBlock Text="字符延迟(ms)" VerticalAlignment="Center"/>
                            <atom:NumericUpDown Grid.Column="1" Minimum="0" Maximum="60000"
                                                Value="{Binding AdvancedCharacterDelayMilliseconds, Mode=TwoWay}"/>
                            <atom:CheckBox Grid.Column="3" Grid.ColumnSpan="2"
                                           Content="启用行延迟"
                                           IsChecked="{Binding AdvancedUseLineDelay, Mode=TwoWay}"/>
                            <TextBlock Grid.Row="2" Text="行延迟(ms)" VerticalAlignment="Center"/>
                            <atom:NumericUpDown Grid.Row="2" Grid.Column="1" Minimum="0" Maximum="60000"
                                                Value="{Binding AdvancedLineDelayMilliseconds, Mode=TwoWay}"/>
                            <atom:CheckBox Grid.Row="2" Grid.Column="3" Grid.ColumnSpan="2"
                                           Content="使用 Nagle 算法"
                                           IsChecked="{Binding AdvancedUseNagle, Mode=TwoWay}"/>
                            <TextBlock Grid.Row="4" Text="提示符文本" VerticalAlignment="Center"/>
                            <atom:LineEdit Grid.Row="4" Grid.Column="1"
                                           Text="{Binding AdvancedPromptText, Mode=TwoWay}"/>
                            <TextBlock Grid.Row="4" Grid.Column="3" Text="最大等待(ms)" VerticalAlignment="Center"/>
                            <atom:NumericUpDown Grid.Row="4" Grid.Column="4" Minimum="0" Maximum="600000"
                                                Value="{Binding AdvancedPromptMaxWaitMilliseconds, Mode=TwoWay}"/>
                            <TextBlock Grid.Row="6" Text="FTP 端口" VerticalAlignment="Center"/>
                            <atom:NumericUpDown Grid.Row="6" Grid.Column="1" Minimum="1" Maximum="65535"
                                                Value="{Binding AdvancedFtpPort, Mode=TwoWay}"/>
                            <atom:CheckBox Grid.Row="6" Grid.Column="3" Grid.ColumnSpan="2"
                                           Content="启用提示符延迟"
                                           IsChecked="{Binding AdvancedUsePromptDelay, Mode=TwoWay}"/>
                            <TextBlock Grid.Row="8" Text="IP 版本" VerticalAlignment="Center"/>
                            <atom:Select Grid.Row="8"
                                         Grid.Column="1"
                                         x:Name="SessionAdvancedIpVersionSelect"
                                         OptionsSource="{Binding AdvancedIpVersionOptions}"
                                         Mode="Single"/>
                            <TextBlock Grid.Row="8" Grid.Column="3" Text="快速命令集" VerticalAlignment="Center"/>
                            <atom:LineEdit Grid.Row="8" Grid.Column="4"
                                           Text="{Binding AdvancedQuickCommandSet, Mode=TwoWay}"/>
                        </Grid>
                        <WrapPanel>
                            <atom:CheckBox Content="禁用快速命令快捷键" Margin="0,0,18,8"
                                           IsChecked="{Binding AdvancedDisableQuickCommandShortcuts, Mode=TwoWay}"/>
                            <atom:CheckBox Content="Trace SSH 协议" Margin="0,0,18,8"
                                           IsChecked="{Binding AdvancedTraceSshProtocol, Mode=TwoWay}"/>
                            <atom:CheckBox Content="Trace SSH 隧道" Margin="0,0,18,8"
                                           IsChecked="{Binding AdvancedTraceSshTunneling, Mode=TwoWay}"/>
                            <atom:CheckBox Content="Trace SSH 包" Margin="0,0,18,8"
                                           IsChecked="{Binding AdvancedTraceSshPackets, Mode=TwoWay}"/>
                            <atom:CheckBox Content="Trace Telnet 选项" Margin="0,0,18,8"
                                           IsChecked="{Binding AdvancedTraceTelnetOptions, Mode=TwoWay}"/>
                        </WrapPanel>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="TracingPage" IsVisible="False">
                    <StackPanel Spacing="16">
                        <atom:TextBlock Text="选择跟踪的事件。所选的事件状态将输出到终端窗口中。"
                                        Foreground="{atom:SharedTokenResource ColorText}"
                                        TextWrapping="Wrap"/>

                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <StackPanel Spacing="16">
                                <atom:TextBlock Text="协议事件"
                                                FontWeight="SemiBold"
                                                Foreground="{atom:SharedTokenResource ColorText}"/>
                                <StackPanel Spacing="12">
                                    <atom:CheckBox Content="SSH版本、算法交换和用户身份验证(S)"
                                                   IsChecked="{Binding AdvancedTraceSshProtocol, Mode=TwoWay}"/>
                                    <atom:CheckBox Content="SSH TCP/IP 和 X11隧道(H)"
                                                   IsChecked="{Binding AdvancedTraceSshTunneling, Mode=TwoWay}"/>
                                    <atom:CheckBox Content="SSH数据包(P)"
                                                   IsChecked="{Binding AdvancedTraceSshPackets, Mode=TwoWay}"/>
                                    <atom:CheckBox Content="TELNET选项模式(T)"
                                                   IsChecked="{Binding AdvancedTraceTelnetOptions, Mode=TwoWay}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Border x:Name="PlaceholderPage"
                        IsVisible="False"
                        Background="{atom:SharedTokenResource ColorBgContainer}"
                        BorderBrush="{atom:SharedTokenResource ColorBorder}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="24">
                    <StackPanel Spacing="8" VerticalAlignment="Top">
                        <TextBlock x:Name="PlaceholderTitleText"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{atom:SharedTokenResource ColorText}"/>
                        <TextBlock Text="此配置页将在后续步骤中实现。"
                                   Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <StackPanel Grid.Column="4" Spacing="10">
            <atom:Button x:Name="SaveBtn"
                         ButtonType="Primary"
                         Icon="{antdicons:AntDesignIconProvider Kind=CheckOutlined}"
                         Content="保存"
                         HorizontalAlignment="Stretch"/>
            <atom:Button x:Name="ConnectBtn"
                         ButtonType="Default"
                         Icon="{antdicons:AntDesignIconProvider Kind=LinkOutlined}"
                         Content="连接"
                         IsVisible="{Binding IsSessionScope}"
                         HorizontalAlignment="Stretch"/>
            <atom:Button x:Name="CancelBtn"
                         Icon="{antdicons:AntDesignIconProvider Kind=CloseOutlined}"
                         Content="取消"
                         HorizontalAlignment="Stretch"/>
        </StackPanel>
    </Grid>
</atom:Window>



