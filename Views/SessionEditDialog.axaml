                                    <atom:Button Grid.Column="3"
                                                 Content="{Binding [UiText.069], Source={x:Static services:LocalizationService.Shared}}"
                                                 Click="OnBrowseSessionAppearanceHighlightSetsClick"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="KeyboardPage"
                              IsVisible="{Binding IsKeyboardPage}"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="16">
                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Margin="0,0,18,0"
                                Padding="18">
                            <StackPanel Spacing="14">
                                <TextBlock Text="{Binding [UiText.151], Source={x:Static services:LocalizationService.Shared}}" FontWeight="SemiBold"/>
                                <Grid ColumnDefinitions="150,*"
                                      RowDefinitions="Auto,12,Auto,22,Auto,10,Auto"
                                      ColumnSpacing="12">
                                    <TextBlock Text="{Binding [UiText.152], Source={x:Static services:LocalizationService.Shared}}" VerticalAlignment="Center"/>
                                    <atom:Select Grid.Column="1"
                                                 x:Name="SessionFunctionKeySelect"
                                                 OptionsSource="{Binding FunctionKeyOptions}"
                                                 Mode="Single"
                                                 SelectionChanged="OnSessionFunctionKeySelectionChanged"/>
                                    <TextBlock Grid.Row="2"
                                               Grid.ColumnSpan="2"
                                               Text="{Binding [UiText.153], Source={x:Static services:LocalizationService.Shared}}"
                                               TextWrapping="Wrap"
                                               Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                    <TextBlock Grid.Row="4"
                                               Grid.ColumnSpan="2"
                                               Text="{Binding [UiText.154], Source={x:Static services:LocalizationService.Shared}}"
                                               Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                    <Grid Grid.Row="6"
                                          Grid.ColumnSpan="2"
                                          ColumnDefinitions="*,8,48">
                                        <atom:LineEdit x:Name="KeyboardMappingFileBox"
                                                       VerticalAlignment="Center"
                                                       IsEnabled="{Binding IsKeyboardMappingFileEnabled}"
                                                       Text="{Binding TerminalKeyboardMappingFile, Mode=TwoWay}"/>
                                        <atom:Button Grid.Column="2"
                                                     Content="..."
                                                     Width="48"
                                                     MinWidth="48"
                                                     VerticalAlignment="Center"
                                                     HorizontalContentAlignment="Center"
                                                     VerticalContentAlignment="Center"
                                                     IsEnabled="{Binding IsKeyboardMappingFileEnabled}"
                                                     Click="OnBrowseKeyboardMappingFileClick"/>
                                    </Grid>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Grid ColumnDefinitions="*,16,*"
                              Margin="0,0,18,0">
                            <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                    BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Margin="0,0,0,16"
                                    Padding="18">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="{Binding [UiText.155], Source={x:Static services:LocalizationService.Shared}}" FontWeight="SemiBold"/>
                                    <atom:RadioButton Content="VT220 Del (Esc[3~)"
                                                      GroupName="SessionDeleteKeySequence"
                                                      IsChecked="{Binding IsDeleteKeyVt220, Mode=TwoWay}"/>
                                    <atom:RadioButton Content="ASCII 127 (Ctrl+?)(A)"
                                                      GroupName="SessionDeleteKeySequence"
                                                      IsChecked="{Binding IsDeleteKeyAscii127, Mode=TwoWay}"/>
                                    <atom:RadioButton Content="Backspace (Ctrl+H)(B)"
                                                      GroupName="SessionDeleteKeySequence"
                                                      IsChecked="{Binding IsDeleteKeyBackspace, Mode=TwoWay}"/>
                                </StackPanel>
                            </Border>

                            <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                    Grid.Column="2"
                                    BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Margin="0,0,0,16"
                                    Padding="18">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="{Binding [UiText.156], Source={x:Static services:LocalizationService.Shared}}" FontWeight="SemiBold"/>
                                    <atom:RadioButton Content="VT220 Del (Esc[3~)"
                                                      GroupName="SessionBackspaceKeySequence"
                                                      IsChecked="{Binding IsBackspaceKeyVt220, Mode=TwoWay}"/>
                                    <atom:RadioButton Content="ASCII 127 (Ctrl+?)(I)"
                                                      GroupName="SessionBackspaceKeySequence"
                                                      IsChecked="{Binding IsBackspaceKeyAscii127, Mode=TwoWay}"/>
                                    <atom:RadioButton Content="Backspace (Ctrl+H)(K)"
                                                      GroupName="SessionBackspaceKeySequence"
                                                      IsChecked="{Binding IsBackspaceKeyBackspace, Mode=TwoWay}"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Margin="0,0,18,0"
                                Padding="18">
                            <StackPanel Spacing="14">
                                <TextBlock Text="{Binding [UiText.157], Source={x:Static services:LocalizationService.Shared}}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding [UiText.158], Source={x:Static services:LocalizationService.Shared}}"
                                           TextWrapping="Wrap"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:CheckBox Content="{Binding [UiText.159], Source={x:Static services:LocalizationService.Shared}}"
                                               IsChecked="{Binding TerminalLeftAltAsMeta, Mode=TwoWay}"/>
                                <atom:CheckBox Content="{Binding [UiText.160], Source={x:Static services:LocalizationService.Shared}}"
                                               Margin="34,0,0,0"
                                               IsEnabled="{Binding IsCtrlAltAsAltGrEnabled}"
                                               IsChecked="{Binding TerminalCtrlAltAsAltGr, Mode=TwoWay}"/>
                                <atom:CheckBox Content="{Binding [UiText.161], Source={x:Static services:LocalizationService.Shared}}"
                                               IsChecked="{Binding TerminalRightAltAsMeta, Mode=TwoWay}"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="VtModePage"
                              IsVisible="{Binding IsVtModePage}"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="16">
                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <StackPanel Spacing="16">
                                <TextBlock Text="{Binding [UiText.162], Source={x:Static services:LocalizationService.Shared}}" FontWeight="SemiBold"/>
                                <StackPanel Spacing="10">
                                    <atom:CheckBox Content="Auto Wrap Mode (DECAWM)"
                                                   IsChecked="{Binding TerminalVtAutoWrapMode, Mode=TwoWay}"/>
                                    <atom:CheckBox Content="Origin Mode (DECOM)"
                                                   IsChecked="{Binding TerminalVtOriginMode, Mode=TwoWay}"/>
                                    <atom:CheckBox Content="Reverse Video Mode (DECSCNM)"
                                                   IsChecked="{Binding TerminalVtReverseVideoMode, Mode=TwoWay}"/>
                                    <atom:CheckBox Content="New Line Mode (NLM)"
                                                   IsChecked="{Binding TerminalVtNewLineMode, Mode=TwoWay}"/>
                                    <atom:CheckBox Content="Insert Mode (IRM)"
                                                   IsChecked="{Binding TerminalVtInsertMode, Mode=TwoWay}"/>
                                    <atom:CheckBox Content="Echo Mode (SRM)"
                                                   IsChecked="{Binding TerminalVtEchoMode, Mode=TwoWay}"/>
                                </StackPanel>

                                <StackPanel Spacing="10">
                                    <TextBlock Text="{Binding [UiText.163], Source={x:Static services:LocalizationService.Shared}}"
                                               Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                    <WrapPanel>
                                        <atom:RadioButton Content="{Binding [UiText.164], Source={x:Static services:LocalizationService.Shared}}"
                                                          GroupName="SessionVtCursorKeyMode"
                                                          Margin="0,0,36,8"
                                                          IsChecked="{Binding IsCursorKeyModeNormal, Mode=TwoWay}"/>
                                        <atom:RadioButton Content="{Binding [UiText.165], Source={x:Static services:LocalizationService.Shared}}"
                                                          GroupName="SessionVtCursorKeyMode"
                                                          Margin="0,0,36,8"
                                                          IsChecked="{Binding IsCursorKeyModeApplication, Mode=TwoWay}"/>
                                    </WrapPanel>
                                </StackPanel>

                                <StackPanel Spacing="10">
                                    <TextBlock Text="{Binding [UiText.166], Source={x:Static services:LocalizationService.Shared}}"
                                               Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                    <WrapPanel>
                                        <atom:RadioButton Content="{Binding [UiText.167], Source={x:Static services:LocalizationService.Shared}}"
                                                          GroupName="SessionVtNumericKeypadMode"
                                                          Margin="0,0,36,8"
                                                          IsChecked="{Binding IsNumericKeypadModeNormal, Mode=TwoWay}"/>
                                        <atom:RadioButton Content="{Binding [UiText.168], Source={x:Static services:LocalizationService.Shared}}"
                                                          GroupName="SessionVtNumericKeypadMode"
                                                          Margin="0,0,36,8"
                                                          IsChecked="{Binding IsNumericKeypadModeApplication, Mode=TwoWay}"/>
                                        <atom:RadioButton Content="{Binding [UiText.169], Source={x:Static services:LocalizationService.Shared}}"
                                                          GroupName="SessionVtNumericKeypadMode"
                                                          Margin="0,0,36,8"
                                                          IsChecked="{Binding IsNumericKeypadModeForceNormal, Mode=TwoWay}"/>
                                    </WrapPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="TerminalAdvancedPage"
                              IsVisible="{Binding IsTerminalAdvancedPage}"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="16">
                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Margin="0,0,18,0"
                                Padding="18">
                            <StackPanel Spacing="12">
                                <TextBlock Text="{Binding [UiText.064], Source={x:Static services:LocalizationService.Shared}}" FontWeight="SemiBold"/>
                                <atom:CheckBox Content="{Binding [UiText.170], Source={x:Static services:LocalizationService.Shared}}"
                                               IsChecked="{Binding TerminalAdvancedUseApplicationCursorMode, Mode=TwoWay}"/>
                                <atom:CheckBox Content="{Binding [UiText.171], Source={x:Static services:LocalizationService.Shared}}"
                                               Margin="24,0,0,0"
                                               IsChecked="{Binding TerminalAdvancedShiftLimitsApplicationCursorMode, Mode=TwoWay}"/>
                                <atom:CheckBox Content="{Binding [UiText.172], Source={x:Static services:LocalizationService.Shared}}"
                                               IsChecked="{Binding TerminalAdvancedClearScreenBackground, Mode=TwoWay}"/>
                                <atom:CheckBox Content="{Binding [UiText.173], Source={x:Static services:LocalizationService.Shared}}"
                                               IsChecked="{Binding TerminalAdvancedScrollToBottomOnInputOutput, Mode=TwoWay}"/>
                                <atom:CheckBox Content="{Binding [UiText.174], Source={x:Static services:LocalizationService.Shared}}"
                                               Margin="24,0,0,0"
                                               IsChecked="{Binding TerminalAdvancedSuspendScrollToBottomOnScrollLock, Mode=TwoWay}"/>
                                <atom:CheckBox Content="{Binding [UiText.175], Source={x:Static services:LocalizationService.Shared}}"
                                               IsChecked="{Binding TerminalAdvancedScrollToBottomByKey, Mode=TwoWay}"/>
                                <atom:CheckBox Content="{Binding [UiText.176], Source={x:Static services:LocalizationService.Shared}}"
                                               IsChecked="{Binding TerminalAdvancedDestructiveBackspace, Mode=TwoWay}"/>
                                <atom:CheckBox Content="{Binding [UiText.177], Source={x:Static services:LocalizationService.Shared}}"
                                               IsChecked="{Binding TerminalAdvancedDuplicateSessionCd, Mode=TwoWay}"/>
                                <Grid ColumnDefinitions="180,*"
                                      ColumnSpacing="12">
                                    <TextBlock Text="{Binding [UiText.178], Source={x:Static services:LocalizationService.Shared}}"
                                               VerticalAlignment="Center"/>
                                    <atom:LineEdit Grid.Column="1"
                                                   PlaceholderText="{Binding [UiText.179], Source={x:Static services:LocalizationService.Shared}}"
                                                   Text="{Binding TerminalAdvancedPreinputString, Mode=TwoWay}"/>
                                </Grid>
                                <atom:CheckBox Content="{Binding [UiText.180], Source={x:Static services:LocalizationService.Shared}}"
                                               IsChecked="{Binding TerminalAdvancedUseRxvtHomeEnd, Mode=TwoWay}"/>
                            </StackPanel>
                        </Border>

                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Margin="0,0,18,0"
                                Padding="18">
                            <StackPanel Spacing="12">
                                <TextBlock Text="{Binding [UiText.181], Source={x:Static services:LocalizationService.Shared}}" FontWeight="SemiBold"/>
                                <atom:CheckBox Content="{Binding [UiText.182], Source={x:Static services:LocalizationService.Shared}}"
                                               IsChecked="{Binding TerminalAdvancedDisableBlinkingText, Mode=TwoWay}"/>
                                <atom:CheckBox Content="{Binding [UiText.183], Source={x:Static services:LocalizationService.Shared}}"
                                               IsChecked="{Binding TerminalAdvancedDisableTitleChange, Mode=TwoWay}"/>
                                <atom:CheckBox Content="{Binding [UiText.184], Source={x:Static services:LocalizationService.Shared}}"
                                               IsChecked="{Binding TerminalAdvancedDisableTerminalPrint, Mode=TwoWay}"/>
                                <atom:CheckBox Content="{Binding [UiText.185], Source={x:Static services:LocalizationService.Shared}}"
                                               IsChecked="{Binding TerminalAdvancedDisableAlternateScreen, Mode=TwoWay}"/>
                                <atom:CheckBox Content="{Binding [UiText.186], Source={x:Static services:LocalizationService.Shared}}"
                                               IsChecked="{Binding TerminalAdvancedIgnoreResizeRequest, Mode=TwoWay}"/>
                                <Grid ColumnDefinitions="180,*"
                                      ColumnSpacing="12">
                                    <TextBlock Text="{Binding [UiText.187], Source={x:Static services:LocalizationService.Shared}}"
                                               VerticalAlignment="Center"/>
                                    <atom:LineEdit Grid.Column="1"
                                                   Text="{Binding TerminalAdvancedAnswerback, Mode=TwoWay}"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Margin="0,0,18,0"
                                Padding="18">
                            <StackPanel Spacing="12">
                                <TextBlock Text="{Binding [UiText.188], Source={x:Static services:LocalizationService.Shared}}" FontWeight="SemiBold"/>
                                <atom:CheckBox Content="{Binding [UiText.189], Source={x:Static services:LocalizationService.Shared}}"
                                               IsChecked="{Binding TerminalAdvancedUseBuiltinLineDrawing, Mode=TwoWay}"/>
                                <atom:CheckBox Content="{Binding [UiText.190], Source={x:Static services:LocalizationService.Shared}}"
                                               IsChecked="{Binding TerminalAdvancedUseBuiltinPowerline, Mode=TwoWay}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="TransferPage"
                              IsVisible="{Binding IsTransferPage}"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="16">
                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Margin="0,0,18,0"
                                Padding="18">
                            <Grid ColumnDefinitions="120,*,48,104"
                                  RowDefinitions="Auto,12,Auto,12,Auto,12,Auto,12,Auto,12,Auto"
                                  ColumnSpacing="10">
                                <TextBlock Grid.ColumnSpan="4"
                                           Text="{Binding [UiText.191], Source={x:Static services:LocalizationService.Shared}}"
                                           FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="2"
                                           Grid.ColumnSpan="4"
                                           Text="{Binding [UiText.192], Source={x:Static services:LocalizationService.Shared}}"/>
                                <atom:RadioButton Grid.Row="4"
                                                  Grid.ColumnSpan="4"
                                                  Content="{Binding [UiText.193], Source={x:Static services:LocalizationService.Shared}}"
                                                  GroupName="SessionFileTransferDownloadFolder"
                                                  IsChecked="{Binding FileTransferAlwaysAskDownloadFolder, Mode=TwoWay}"/>
                                <atom:RadioButton Grid.Row="6"
                                                  Grid.ColumnSpan="4"
                                                  Content="{Binding [UiText.194], Source={x:Static services:LocalizationService.Shared}}"
                                                  GroupName="SessionFileTransferDownloadFolder"
                                                  IsChecked="{Binding IsFileTransferUseConfiguredFolders, Mode=TwoWay}"/>

                                <TextBlock Grid.Row="8"
                                           Text="{Binding [UiText.195], Source={x:Static services:LocalizationService.Shared}}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"/>
                                <atom:LineEdit Grid.Row="8"
                                               Grid.Column="1"
                                               IsEnabled="{Binding IsFileTransferPathSettingsEnabled}"
                                               Text="{Binding FileTransferDownloadDirectory, Mode=TwoWay}"/>
                                <atom:Button Grid.Row="8"
                                             Grid.Column="2"
                                             Content="..."
                                             Width="48"
                                             MinWidth="48"
                                             HorizontalContentAlignment="Center"
                                             IsEnabled="{Binding IsFileTransferPathSettingsEnabled}"
                                             Click="OnBrowseFileTransferDownloadDirectoryClick"/>
                                <atom:Button Grid.Row="8"
                                             Grid.Column="3"
                                             Content="{Binding [UiText.196], Source={x:Static services:LocalizationService.Shared}}"
                                             IsEnabled="{Binding IsFileTransferPathSettingsEnabled}"
                                             Click="OnOpenFileTransferDownloadDirectoryClick"/>

                                <TextBlock Grid.Row="10"
                                           Text="{Binding [UiText.197], Source={x:Static services:LocalizationService.Shared}}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"/>
                                <atom:LineEdit Grid.Row="10"
                                               Grid.Column="1"
                                               IsEnabled="{Binding IsFileTransferPathSettingsEnabled}"
                                               Text="{Binding FileTransferUploadDirectory, Mode=TwoWay}"/>
                                <atom:Button Grid.Row="10"
                                             Grid.Column="2"
                                             Content="..."
                                             Width="48"
                                             MinWidth="48"
                                             HorizontalContentAlignment="Center"
                                             IsEnabled="{Binding IsFileTransferPathSettingsEnabled}"
                                             Click="OnBrowseFileTransferUploadDirectoryClick"/>
                                <atom:Button Grid.Row="10"
                                             Grid.Column="3"
                                             Content="{Binding [UiText.198], Source={x:Static services:LocalizationService.Shared}}"
                                             IsEnabled="{Binding IsFileTransferPathSettingsEnabled}"
                                             Click="OnOpenFileTransferUploadDirectoryClick"/>
                            </Grid>
                        </Border>

                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Margin="0,0,18,0"
                                Padding="18">
                            <StackPanel Spacing="14">
                                <TextBlock Text="{Binding [UiText.199], Source={x:Static services:LocalizationService.Shared}}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding [UiText.200], Source={x:Static services:LocalizationService.Shared}}"/>
                                <StackPanel Orientation="Horizontal" Spacing="220">
                                    <atom:RadioButton Content="{Binding [UiText.201], Source={x:Static services:LocalizationService.Shared}}"
                                                      GroupName="SessionFileTransferDuplicate"
                                                      IsChecked="{Binding IsFileTransferDuplicateAutoRename, Mode=TwoWay}"/>
                                    <atom:RadioButton Content="{Binding [UiText.202], Source={x:Static services:LocalizationService.Shared}}"
                                                      GroupName="SessionFileTransferDuplicate"
                                                      IsChecked="{Binding IsFileTransferDuplicateOverwrite, Mode=TwoWay}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Margin="0,0,18,0"
                                Padding="18">
                            <StackPanel Spacing="14">
                                <TextBlock Text="{Binding [UiText.203], Source={x:Static services:LocalizationService.Shared}}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding [UiText.204], Source={x:Static services:LocalizationService.Shared}}"/>
                                <StackPanel Orientation="Horizontal" Spacing="80">
                                    <atom:RadioButton Content="Xmodem"
                                                      GroupName="SessionFileTransferUpload"
                                                      IsChecked="{Binding IsFileTransferUploadProtocolXmodem, Mode=TwoWay}"/>
                                    <atom:RadioButton Content="Ymodem"
                                                      GroupName="SessionFileTransferUpload"
                                                      IsChecked="{Binding IsFileTransferUploadProtocolYmodem, Mode=TwoWay}"/>
                                    <atom:RadioButton Content="{Binding [UiText.205], Source={x:Static services:LocalizationService.Shared}}"
                                                      GroupName="SessionFileTransferUpload"
                                                      IsChecked="{Binding IsFileTransferUploadProtocolZmodem, Mode=TwoWay}"/>
                                    <atom:RadioButton Content="ftp"
                                                      GroupName="SessionFileTransferUpload"
                                                      IsChecked="{Binding IsFileTransferUploadProtocolFtp, Mode=TwoWay}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="FileTransferXymodemPage"
                              IsVisible="{Binding IsFileTransferXymodemPage}"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="16">
                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Margin="0,0,18,0"
                                Padding="18">
                            <StackPanel Spacing="14">
                                <TextBlock Text="{Binding [UiText.064], Source={x:Static services:LocalizationService.Shared}}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding [UiText.206], Source={x:Static services:LocalizationService.Shared}}"/>
                                <atom:RadioButton Content="128 bytes(Xmodem/Ymodem)(B)"
                                                  GroupName="FileTransferXymodemBlockSize"
