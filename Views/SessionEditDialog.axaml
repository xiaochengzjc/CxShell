                <ScrollViewer x:Name="ProxyPage" IsVisible="False">
                    <StackPanel Spacing="16">
                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <Grid RowDefinitions="Auto,12,Auto,28,Auto"
                                  ColumnDefinitions="140,*,160">
                                <TextBlock Grid.ColumnSpan="3"
                                           Text="{Binding [UiText.066], Source={x:Static services:LocalizationService.Shared}}"
                                           FontWeight="SemiBold"
                                           Foreground="{atom:SharedTokenResource ColorText}"/>
                                <TextBlock Grid.Row="2"
                                           Grid.ColumnSpan="3"
                                           Text="{Binding [UiText.067], Source={x:Static services:LocalizationService.Shared}}"
                                           TextWrapping="Wrap"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <TextBlock Grid.Row="4"
                                           Text="{Binding [UiText.068], Source={x:Static services:LocalizationService.Shared}}"
