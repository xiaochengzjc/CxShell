                                <TextBlock Grid.ColumnSpan="2"
                                           Text="{Binding [UiText.207], Source={x:Static services:LocalizationService.Shared}}"
                                           FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="2"
                                           Grid.ColumnSpan="2"
                                           Text="{Binding [UiText.213], Source={x:Static services:LocalizationService.Shared}}"
