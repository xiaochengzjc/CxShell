                <ScrollViewer x:Name="RloginPage" IsVisible="False">
                    <StackPanel Spacing="16">
                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <Grid RowDefinitions="Auto,18,Auto"
                                  ColumnDefinitions="140,250,*">
                                <TextBlock Grid.ColumnSpan="3"
                                           Text="{Binding GeneralText}"
                                           FontWeight="SemiBold"
                                           Foreground="{atom:SharedTokenResource ColorText}"/>
                                <TextBlock Grid.Row="2"
                                           Text="{Binding [UiText.070], Source={x:Static services:LocalizationService.Shared}}"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:Select Grid.Row="2"
                                             Grid.Column="1"
                                             x:Name="RloginTerminalSpeedSelect"
                                             Mode="Single"
                                             ShouldUseOverlayPopup="False"
                                             DisplayPageSize="15"
                                             HorizontalAlignment="Stretch"
                                             OptionsSource="{Binding TerminalSpeedOptions}"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="SftpPage" IsVisible="False">
                    <StackPanel Spacing="16">
                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <Grid RowDefinitions="Auto,14,Auto,28,Auto,12,Auto,12,Auto"
                                  ColumnDefinitions="140,*,64">
                                <TextBlock Grid.ColumnSpan="3"
                                           Text="{Binding [UiText.071], Source={x:Static services:LocalizationService.Shared}}"
                                           FontWeight="SemiBold"
                                           Foreground="{atom:SharedTokenResource ColorText}"/>
                                <TextBlock Grid.Row="2"
                                           Grid.ColumnSpan="3"
                                           Text="{Binding [UiText.072], Source={x:Static services:LocalizationService.Shared}}"
                                           TextWrapping="Wrap"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>

                                <TextBlock Grid.Row="4"
                                           Text="{Binding [UiText.073], Source={x:Static services:LocalizationService.Shared}}"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:LineEdit Grid.Row="4"
                                               Grid.Column="1"
                                               x:Name="SftpLocalStartDirectoryBox"
                                               Text="{Binding SftpLocalStartDirectory, Mode=TwoWay}"
                                               PlaceholderText="{Binding [UiText.074], Source={x:Static services:LocalizationService.Shared}}"/>
                                 <atom:Button Grid.Row="4"
                                              Grid.Column="2"
                                              Content="..."
                                              Width="48"
                                              MinWidth="48"
                                              HorizontalContentAlignment="Center"
                                              HorizontalAlignment="Right"
                                              Click="OnBrowseSftpLocalDirectoryClick"/>

                                <TextBlock Grid.Row="6"
                                           Text="{Binding [UiText.075], Source={x:Static services:LocalizationService.Shared}}"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:LineEdit Grid.Row="6"
                                               Grid.Column="1"
                                               Grid.ColumnSpan="2"
                                               x:Name="SftpRemoteStartDirectoryBox"
                                               Text="{Binding SftpRemoteStartDirectory, Mode=TwoWay}"
                                               PlaceholderText="/var/www"/>
                                <atom:CheckBox Grid.Row="8"
                                               Grid.ColumnSpan="3"
                                               Content="{Binding [UiText.261], Source={x:Static services:LocalizationService.Shared}}"
                                               IsChecked="{Binding SftpFollowTerminalDirectory, Mode=TwoWay}"/>
                            </Grid>
                        </Border>

                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <Grid RowDefinitions="Auto,14,Auto,12,Auto,8,Auto"
                                  ColumnDefinitions="140,*">
                                <TextBlock Grid.ColumnSpan="2"
                                           Text="{Binding [UiText.076], Source={x:Static services:LocalizationService.Shared}}"
                                           FontWeight="SemiBold"
                                           Foreground="{atom:SharedTokenResource ColorText}"/>
                                <atom:CheckBox Grid.Row="2"
                                               Grid.ColumnSpan="2"
                                               Content="{Binding [UiText.077], Source={x:Static services:LocalizationService.Shared}}"
                                               IsChecked="{Binding SftpUseCustomServer, Mode=TwoWay}"/>
                                <TextBlock Grid.Row="4"
                                           Text="{Binding [UiText.078], Source={x:Static services:LocalizationService.Shared}}"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:LineEdit Grid.Row="4"
                                               Grid.Column="1"
                                               x:Name="SftpCustomServerCommandBox"
                                               IsEnabled="{Binding IsSftpCustomServerCommandEnabled}"
                                               Text="{Binding SftpCustomServerCommand, Mode=TwoWay}"
                                               PlaceholderText="/usr/lib/openssh/sftp-server"/>
                                <TextBlock Grid.Row="6"
                                           Grid.Column="1"
                                           Text="{Binding [UiText.079], Source={x:Static services:LocalizationService.Shared}}"
                                           TextWrapping="Wrap"
                                           Foreground="{atom:SharedTokenResource ColorTextTertiary}"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="SerialPage" IsVisible="False">
                    <StackPanel Spacing="16">
                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <Grid RowDefinitions="Auto,14,Auto,12,Auto,12,Auto,12,Auto,12,Auto,12,Auto"
                                  ColumnDefinitions="140,240">
                                <TextBlock Grid.ColumnSpan="2"
                                           Text="{Binding [UiText.080], Source={x:Static services:LocalizationService.Shared}}"
                                           FontWeight="SemiBold"
                                           Foreground="{atom:SharedTokenResource ColorText}"/>

                                <TextBlock Grid.Row="2" Text="{Binding [UiText.081], Source={x:Static services:LocalizationService.Shared}}"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:Select Grid.Row="2" Grid.Column="1"
                                             x:Name="SerialPortSelect"
                                             Mode="Single"
                                             Width="220"
                                             HorizontalAlignment="Left"
                                             Status="{Binding SerialPortStatus}"
                                             OptionsSource="{Binding SerialPortOptions}"/>

                                <TextBlock Grid.Row="4" Text="{Binding [UiText.082], Source={x:Static services:LocalizationService.Shared}}"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:Select Grid.Row="4" Grid.Column="1"
                                             x:Name="SerialBaudRateSelect"
                                             Mode="Single"
                                             Width="220"
                                             HorizontalAlignment="Left"
                                             OptionsSource="{Binding SerialBaudRateOptions}"/>

                                <TextBlock Grid.Row="6" Text="{Binding [UiText.083], Source={x:Static services:LocalizationService.Shared}}"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:Select Grid.Row="6" Grid.Column="1"
                                             x:Name="SerialDataBitsSelect"
                                             Mode="Single"
                                             Width="220"
                                             HorizontalAlignment="Left"
                                             OptionsSource="{Binding SerialDataBitsOptions}"/>

                                <TextBlock Grid.Row="8" Text="{Binding [UiText.084], Source={x:Static services:LocalizationService.Shared}}"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:Select Grid.Row="8" Grid.Column="1"
                                             x:Name="SerialStopBitsSelect"
                                             Mode="Single"
                                             Width="220"
                                             HorizontalAlignment="Left"
                                             OptionsSource="{Binding SerialStopBitsOptions}"/>

                                <TextBlock Grid.Row="10" Text="{Binding [UiText.085], Source={x:Static services:LocalizationService.Shared}}"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:Select Grid.Row="10" Grid.Column="1"
                                             x:Name="SerialParitySelect"
                                             Mode="Single"
                                             Width="220"
                                             HorizontalAlignment="Left"
                                             OptionsSource="{Binding SerialParityOptions}"/>

                                <TextBlock Grid.Row="12" Text="{Binding [UiText.086], Source={x:Static services:LocalizationService.Shared}}"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:Select Grid.Row="12" Grid.Column="1"
                                             x:Name="SerialFlowControlSelect"
                                             Mode="Single"
                                             Width="220"
                                             HorizontalAlignment="Left"
                                             OptionsSource="{Binding SerialFlowControlOptions}"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="RdpPage" IsVisible="False">
                    <StackPanel Spacing="16">
                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <Grid RowDefinitions="Auto,14,Auto,10,Auto,12,Auto,12,Auto,12,Auto"
                                  ColumnDefinitions="150,420,*"
                                  ColumnSpacing="8">
                                <TextBlock Grid.ColumnSpan="3"
                                           Text="{Binding [UiText.060], Source={x:Static services:LocalizationService.Shared}}"
                                           FontWeight="SemiBold"
                                           Foreground="{atom:SharedTokenResource ColorText}"/>

                                <TextBlock Grid.Row="2" Text="{Binding [UiText.087], Source={x:Static services:LocalizationService.Shared}}"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:Select Grid.Row="2" Grid.Column="1"
                                             x:Name="RdpWindowSizeSelect"
                                             Mode="Single"
                                             Width="320"
                                             HorizontalAlignment="Left"
                                             OptionsSource="{Binding RdpWindowSizeOptions}"/>
                                <Grid Grid.Row="4"
                                      Grid.Column="1"
                                      ColumnDefinitions="96,28,96"
                                      HorizontalAlignment="Left">
                                    <atom:LineEdit x:Name="RdpWidthBox"
                                                   Text="{Binding RdpDesktopWidth, Mode=TwoWay}"/>
                                    <TextBlock Grid.Column="1"
                                               Text="x"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                    <atom:LineEdit Grid.Column="2"
                                                   x:Name="RdpHeightBox"
                                                   Text="{Binding RdpDesktopHeight, Mode=TwoWay}"/>
                                </Grid>

                                <TextBlock Grid.Row="6" Text="{Binding [UiText.088], Source={x:Static services:LocalizationService.Shared}}"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:Select Grid.Row="6" Grid.Column="1"
                                             x:Name="RdpResizeModeSelect"
                                             Mode="Single"
                                             Width="420"
                                             HorizontalAlignment="Left"
                                             OptionsSource="{Binding RdpResizeModeOptions}"/>

                                <TextBlock Grid.Row="8" Text="Screen Scale:"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:Select Grid.Row="8" Grid.Column="1"
                                             x:Name="RdpScreenScaleSelect"
                                             Mode="Single"
                                             Width="220"
                                             HorizontalAlignment="Left"
                                             OptionsSource="{Binding RdpScreenScaleOptions}"/>

                                <TextBlock Grid.Row="10" Text="{Binding [UiText.089], Source={x:Static services:LocalizationService.Shared}}"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:Select Grid.Row="10" Grid.Column="1"
                                             x:Name="RdpColorQualitySelect"
                                             Mode="Single"
                                             Width="220"
                                             HorizontalAlignment="Left"
                                             OptionsSource="{Binding RdpColorQualityOptions}"/>
                            </Grid>
                        </Border>

                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <StackPanel Spacing="14">
                                <TextBlock Text="{Binding [UiText.090], Source={x:Static services:LocalizationService.Shared}}"
                                           FontWeight="SemiBold"
                                           Foreground="{atom:SharedTokenResource ColorText}"/>
                                <atom:CheckBox Content="{Binding [UiText.091], Source={x:Static services:LocalizationService.Shared}}"
                                               IsChecked="{Binding RdpApplyKeyCombinations, Mode=TwoWay}"/>
                                <atom:CheckBox Content="{Binding [UiText.092], Source={x:Static services:LocalizationService.Shared}}"
                                               IsChecked="{Binding RdpRedirectDrives, Mode=TwoWay}"/>
                            </StackPanel>
                        </Border>

                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <Grid RowDefinitions="Auto,14,Auto,12,Auto"
                                  ColumnDefinitions="Auto,12,220,*">
                                <TextBlock Grid.ColumnSpan="4"
                                           Text="{Binding [UiText.093], Source={x:Static services:LocalizationService.Shared}}"
                                           FontWeight="SemiBold"
                                           Foreground="{atom:SharedTokenResource ColorText}"/>
                                <TextBlock Grid.Row="2" Text="{Binding [UiText.094], Source={x:Static services:LocalizationService.Shared}}"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:Select Grid.Row="2" Grid.Column="2"
                                             x:Name="RdpAudioModeSelect"
                                             Mode="Single"
                                             Width="220"
                                             OptionsSource="{Binding RdpAudioModeOptions}"/>
                                <atom:CheckBox Grid.Row="4" Grid.Column="2"
                                               Content="{Binding [UiText.095], Source={x:Static services:LocalizationService.Shared}}"
                                               IsChecked="{Binding RdpAudioCapture, Mode=TwoWay}"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="TerminalPage"
                              IsVisible="{Binding IsTerminalPage}"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="16">
                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <StackPanel Spacing="14">
                                <TextBlock Text="{Binding [UiText.096], Source={x:Static services:LocalizationService.Shared}}" FontWeight="SemiBold"/>
                                <Grid ColumnDefinitions="120,240"
                                      RowDefinitions="Auto,14,Auto,12,Auto"
                                      ColumnSpacing="10"
                                      HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding [UiText.097], Source={x:Static services:LocalizationService.Shared}}" VerticalAlignment="Center"/>
                                    <atom:Select Grid.Column="1"
                                                 x:Name="SessionTerminalTypeSelect"
                                                 OptionsSource="{Binding TerminalTypeOptions}"
                                                 Mode="Single"
                                                 HorizontalAlignment="Stretch"/>
                                    <TextBlock Grid.Row="2" Text="{Binding [UiText.098], Source={x:Static services:LocalizationService.Shared}}" VerticalAlignment="Center"/>
                                     <atom:NumericUpDown Grid.Row="2"
                                                         Grid.Column="1"
                                                         Minimum="20"
                                                         Maximum="500"
                                                         HorizontalAlignment="Stretch"
                                                         Value="{Binding TerminalColumns, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="4" Text="{Binding [UiText.099], Source={x:Static services:LocalizationService.Shared}}" VerticalAlignment="Center"/>
                                    <atom:NumericUpDown Grid.Row="4"
                                                        Grid.Column="1"
                                                        Minimum="5"
                                                        Maximum="200"
                                                        HorizontalAlignment="Stretch"
                                                        Value="{Binding TerminalRows, Mode=TwoWay}"/>
                                </Grid>
                                <WrapPanel>
                                    <atom:CheckBox Content="{Binding [UiText.100], Source={x:Static services:LocalizationService.Shared}}"
                                                   Margin="0,0,18,8"
                                                   IsChecked="{Binding TerminalFixedSize, Mode=TwoWay}"/>
                                    <atom:CheckBox Content="{Binding [UiText.101], Source={x:Static services:LocalizationService.Shared}}"
                                                   Margin="0,0,18,8"
                                                   IsChecked="{Binding TerminalResetSizeOnConnect, Mode=TwoWay}"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <StackPanel Spacing="14">
                                <TextBlock Text="{Binding [UiText.102], Source={x:Static services:LocalizationService.Shared}}" FontWeight="SemiBold"/>
                                <Grid ColumnDefinitions="120,220,40"
                                      RowDefinitions="Auto,12,Auto"
                                      ColumnSpacing="10"
                                      HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding [UiText.103], Source={x:Static services:LocalizationService.Shared}}" VerticalAlignment="Center"/>
                                    <atom:NumericUpDown Grid.Column="1"
                                                        Minimum="0"
                                                        Maximum="200000"
                                                        HorizontalAlignment="Stretch"
                                                        Value="{Binding TerminalScrollbackSize, Mode=TwoWay}"/>
                                    <TextBlock Grid.Column="2" Text="{Binding [UiText.104], Source={x:Static services:LocalizationService.Shared}}" VerticalAlignment="Center"/>
                                    <atom:CheckBox Grid.Row="2"
                                                   Grid.ColumnSpan="3"
                                                   Content="{Binding [UiText.105], Source={x:Static services:LocalizationService.Shared}}"
                                                   IsChecked="{Binding TerminalPushClearedScreenToScrollback, Mode=TwoWay}"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <StackPanel Spacing="14">
                                <TextBlock Text="{Binding [UiText.106], Source={x:Static services:LocalizationService.Shared}}" FontWeight="SemiBold"/>
                                <Grid ColumnDefinitions="120,300"
                                      RowDefinitions="Auto,14,Auto"
                                      ColumnSpacing="10"
                                      HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding [UiText.107], Source={x:Static services:LocalizationService.Shared}}" VerticalAlignment="Center"/>
                                    <atom:Select Grid.Column="1"
                                                 x:Name="SessionTerminalEncodingSelect"
                                                 OptionsSource="{Binding EncodingOptions}"
                                                 Mode="Single"
                                                 HorizontalAlignment="Stretch"/>
                                    <TextBlock Grid.Row="2" Text="{Binding [UiText.108], Source={x:Static services:LocalizationService.Shared}}" VerticalAlignment="Center"/>
                                    <atom:CheckBox Grid.Row="2"
                                                   Grid.Column="1"
                                                   Content="{Binding [UiText.109], Source={x:Static services:LocalizationService.Shared}}"
                                                   IsChecked="{Binding TerminalTreatAmbiguousAsWide, Mode=TwoWay}"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <StackPanel Spacing="14">
                                <TextBlock Text="{Binding [UiText.110], Source={x:Static services:LocalizationService.Shared}}" FontWeight="SemiBold"/>
                                <Grid ColumnDefinitions="120,220"
                                      RowDefinitions="Auto,12,Auto"
                                      ColumnSpacing="10"
                                      HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding [UiText.111], Source={x:Static services:LocalizationService.Shared}}" VerticalAlignment="Center"/>
                                    <atom:Select Grid.Column="1"
                                                 x:Name="SessionTerminalSendLineEndingSelect"
                                                 OptionsSource="{Binding SendLineEndingOptions}"
                                                 Mode="Single"
                                                 HorizontalAlignment="Stretch"/>
                                    <TextBlock Grid.Row="2" Text="{Binding [UiText.112], Source={x:Static services:LocalizationService.Shared}}" VerticalAlignment="Center"/>
                                    <atom:Select Grid.Row="2"
                                                 Grid.Column="1"
                                                 x:Name="SessionTerminalReceiveLineEndingSelect"
                                                 OptionsSource="{Binding ReceiveLineEndingOptions}"
                                                 Mode="Single"
                                                 HorizontalAlignment="Stretch"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="AppearancePage"
                              IsVisible="{Binding IsAppearancePage}"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="{Binding [UiText.113], Source={x:Static services:LocalizationService.Shared}}" FontWeight="SemiBold"/>
                            <Border x:Name="SessionAppearancePreviewBorder"
                                    Padding="10"
                                    MinHeight="128"
                                    Background="{Binding AppearanceBackgroundBrush}"
                                    BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                    BorderThickness="1"
                                    CornerRadius="4">
                                <StackPanel Spacing="1">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="Normal"
                                                   FontFamily="{Binding AppearancePreviewFontFamily}"
                                                   FontSize="{Binding AppearanceFontSize}"
                                                   FontStyle="{Binding AppearancePreviewFontStyle}"
                                                   FontWeight="{Binding AppearancePreviewFontWeight}"
                                                   Foreground="{Binding AppearanceForegroundBrush}"/>
                                        <TextBlock Text="Bold"
                                                   FontFamily="{Binding AppearancePreviewFontFamily}"
                                                   FontSize="{Binding AppearanceFontSize}"
                                                   FontStyle="{Binding AppearancePreviewFontStyle}"
                                                   FontWeight="{Binding AppearancePreviewBoldWeight}"
                                                   Foreground="{Binding AppearancePreviewBoldBrush}"/>
                                        <TextBlock Text="Underline"
                                                   FontFamily="{Binding AppearancePreviewFontFamily}"
                                                   FontSize="{Binding AppearanceFontSize}"
                                                   TextDecorations="Underline"
                                                   Foreground="{Binding AppearanceForegroundBrush}"/>
                                        <TextBlock Text="Reversed"
                                                   FontFamily="{Binding AppearancePreviewFontFamily}"
                                                   FontSize="{Binding AppearanceFontSize}"
                                                   Background="{Binding AppearanceForegroundBrush}"
                                                   Foreground="{Binding AppearanceBackgroundBrush}"/>
                                        <StackPanel Orientation="Horizontal" Spacing="0">
                                            <Grid Width="10" Height="24">
                                                <TextBlock Text="C"
                                                           FontFamily="{Binding AppearancePreviewFontFamily}"
                                                           FontSize="{Binding AppearanceFontSize}"
                                                           Foreground="{Binding AppearanceForegroundBrush}"/>
                                                <Border Height="{Binding AppearanceFontSize}"
                                                        Background="{Binding AppearanceCursorBrush}"
                                                        IsVisible="{Binding IsAppearanceCursorBlockVisible}">
                                                    <TextBlock Text="C"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               FontFamily="{Binding AppearancePreviewFontFamily}"
                                                               FontSize="{Binding AppearanceFontSize}"
                                                               Foreground="{Binding AppearanceCursorTextBrush}"/>
                                                </Border>
                                                <Border Width="3"
                                                        Height="{Binding AppearanceFontSize}"
                                                        HorizontalAlignment="Left"
                                                        Background="{Binding AppearanceCursorBrush}"
                                                        IsVisible="{Binding IsAppearanceCursorVerticalVisible}"/>
                                                <Border Height="3"
                                                        VerticalAlignment="Bottom"
                                                        Background="{Binding AppearanceCursorBrush}"
                                                        IsVisible="{Binding IsAppearanceCursorUnderlineVisible}"/>
                                            </Grid>
                                            <TextBlock Text="ursor"
                                                       FontFamily="{Binding AppearancePreviewFontFamily}"
                                                       FontSize="{Binding AppearanceFontSize}"
                                                       Foreground="{Binding AppearanceForegroundBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <TextBlock FontFamily="{Binding AppearancePreviewFontFamily}"
                                               FontSize="{Binding AppearanceFontSize}">
                                        <Run Text="black " Foreground="{Binding AppearanceAnsiBlackBrush}"/>
                                        <Run Text="red " Foreground="{Binding AppearanceAnsiRedBrush}"/>
                                        <Run Text="green " Foreground="{Binding AppearanceAnsiGreenBrush}"/>
                                        <Run Text="yellow " Foreground="{Binding AppearanceAnsiYellowBrush}"/>
                                        <Run Text="blue " Foreground="{Binding AppearanceAnsiBlueBrush}"/>
                                        <Run Text="magenta " Foreground="{Binding AppearanceAnsiMagentaBrush}"/>
                                        <Run Text="cyan " Foreground="{Binding AppearanceAnsiCyanBrush}"/>
                                        <Run Text="white" Foreground="{Binding AppearanceAnsiWhiteBrush}"/>
                                    </TextBlock>
                                    <TextBlock FontFamily="{Binding AppearancePreviewCjkFontFamily}"
                                               FontSize="{Binding AppearanceCjkFontSize}"
                                               FontWeight="{Binding AppearancePreviewBoldWeight}"
                                               Text="{Binding [UiText.114], Source={x:Static services:LocalizationService.Shared}}"
                                               Foreground="{Binding AppearancePreviewBoldBrush}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <Grid ColumnDefinitions="120,*" ColumnSpacing="12">
                            <TextBlock Text="{Binding [UiText.115], Source={x:Static services:LocalizationService.Shared}}" VerticalAlignment="Center"/>
                            <atom:Select Grid.Column="1"
                                         x:Name="SessionAppearanceColorSchemeSelect"
                                         OptionsSource="{Binding AppearanceColorSchemeOptions}"
                                         Mode="Single"
                                         SelectionChanged="OnSessionAppearanceSelectionChanged"
                                         HorizontalAlignment="Stretch"/>
                        </Grid>

                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <StackPanel Spacing="14">
                                <TextBlock Text="{Binding [UiText.116], Source={x:Static services:LocalizationService.Shared}}" FontWeight="SemiBold"/>
                                <Grid ColumnDefinitions="120,*,12,156,12,112"
                                      RowDefinitions="Auto,14,Auto,14,Auto,14,Auto"
                                      ColumnSpacing="0">
                                    <TextBlock Text="{Binding [UiText.117], Source={x:Static services:LocalizationService.Shared}}" VerticalAlignment="Center"/>
                                    <atom:Select Grid.Column="1"
                                                 x:Name="SessionAppearanceFontSelect"
                                                 OptionsSource="{Binding AppearanceFontOptions}"
                                                 Mode="Single"
                                                 SelectionChanged="OnSessionAppearanceSelectionChanged"
                                                 HorizontalAlignment="Stretch"/>
                                    <atom:Select Grid.Column="3"
                                                 x:Name="SessionAppearanceFontStyleSelect"
                                                 OptionsSource="{Binding AppearanceFontStyleOptions}"
                                                 Mode="Single"
                                                 SelectionChanged="OnSessionAppearanceSelectionChanged"
                                                 HorizontalAlignment="Stretch"/>
                                    <atom:NumericUpDown Grid.Column="5"
                                                        Minimum="6"
                                                        Maximum="96"
                                                        Value="{Binding AppearanceFontSize, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="2" Text="{Binding [UiText.118], Source={x:Static services:LocalizationService.Shared}}" VerticalAlignment="Center"/>
                                    <atom:Select Grid.Row="2"
                                                 Grid.Column="1"
                                                 x:Name="SessionAppearanceCjkFontSelect"
                                                 OptionsSource="{Binding AppearanceFontOptions}"
                                                 Mode="Single"
                                                 SelectionChanged="OnSessionAppearanceSelectionChanged"
                                                 HorizontalAlignment="Stretch"/>
                                    <atom:Select Grid.Row="2"
                                                 Grid.Column="3"
                                                 x:Name="SessionAppearanceCjkFontStyleSelect"
                                                 OptionsSource="{Binding AppearanceFontStyleOptions}"
                                                 Mode="Single"
                                                 SelectionChanged="OnSessionAppearanceSelectionChanged"
                                                 HorizontalAlignment="Stretch"/>
                                    <atom:NumericUpDown Grid.Row="2"
                                                        Grid.Column="5"
                                                        Minimum="6"
                                                        Maximum="96"
                                                        Value="{Binding AppearanceCjkFontSize, Mode=TwoWay}"/>
                                    <atom:CheckBox Grid.Row="4"
                                                   Grid.Column="1"
                                                   Grid.ColumnSpan="5"
                                                   Content="{Binding [UiText.119], Source={x:Static services:LocalizationService.Shared}}"
                                                   IsChecked="{Binding AppearanceUseVariablePitchFont, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="6" Text="{Binding [UiText.120], Source={x:Static services:LocalizationService.Shared}}" VerticalAlignment="Center"/>
                                    <atom:Select Grid.Row="6"
                                                 Grid.Column="1"
                                                 x:Name="SessionAppearanceFontQualitySelect"
                                                 OptionsSource="{Binding AppearanceFontQualityOptions}"
                                                 Mode="Single"
                                                 SelectionChanged="OnSessionAppearanceSelectionChanged"
                                                 HorizontalAlignment="Stretch"/>
                                    <TextBlock Grid.Row="6" Grid.Column="3" Text="{Binding [UiText.121], Source={x:Static services:LocalizationService.Shared}}" VerticalAlignment="Center"/>
                                    <atom:Select Grid.Row="6"
                                                 Grid.Column="5"
                                                 x:Name="SessionAppearanceBoldTextModeSelect"
                                                 OptionsSource="{Binding AppearanceBoldTextModeOptions}"
                                                 Mode="Single"
                                                 SelectionChanged="OnSessionAppearanceSelectionChanged"
                                                 HorizontalAlignment="Stretch"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <StackPanel Spacing="14">
                                <TextBlock Text="{Binding [UiText.122], Source={x:Static services:LocalizationService.Shared}}" FontWeight="SemiBold"/>
                                <Grid ColumnDefinitions="120,180,28,90,112,72"
                                      RowDefinitions="Auto,14,Auto,14,Auto"
                                      ColumnSpacing="10">
                                    <TextBlock Text="{Binding [UiText.123], Source={x:Static services:LocalizationService.Shared}}" VerticalAlignment="Center"/>
                                    <atom:ColorPicker Grid.Column="1"
                                                      Value="{Binding AppearanceCursorColor, Mode=TwoWay}"/>
                                    <atom:CheckBox Grid.Column="3"
                                                   Grid.ColumnSpan="3"
                                                   Content="{Binding [UiText.124], Source={x:Static services:LocalizationService.Shared}}"
                                                   IsChecked="{Binding AppearanceUseBlinkingCursor, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="2" Text="{Binding [UiText.125], Source={x:Static services:LocalizationService.Shared}}" VerticalAlignment="Center"/>
                                    <atom:ColorPicker Grid.Row="2"
                                                      Grid.Column="1"
                                                      Value="{Binding AppearanceCursorTextColor, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="3" Text="{Binding [UiText.126], Source={x:Static services:LocalizationService.Shared}}" VerticalAlignment="Center"/>
                                    <atom:NumericUpDown Grid.Row="2"
                                                        Grid.Column="4"
                                                        Minimum="1"
                                                        Maximum="5000"
                                                        Width="104"
                                                        HorizontalAlignment="Left"
                                                        Value="{Binding AppearanceCursorBlinkSpeedMilliseconds, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="5" Text="millisec" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="4" Text="{Binding [UiText.127], Source={x:Static services:LocalizationService.Shared}}" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Row="4"
                                                Grid.Column="1"
                                                Grid.ColumnSpan="5"
                                                Orientation="Horizontal"
                                                Spacing="32">
                                        <atom:RadioButton Content="{Binding [UiText.128], Source={x:Static services:LocalizationService.Shared}}" GroupName="SessionCursorShape"
                                                          IsChecked="{Binding IsAppearanceCursorShapeBlock, Mode=TwoWay}"/>
                                        <atom:RadioButton Content="{Binding [UiText.129], Source={x:Static services:LocalizationService.Shared}}" GroupName="SessionCursorShape"
                                                          IsChecked="{Binding IsAppearanceCursorShapeVertical, Mode=TwoWay}"/>
                                        <atom:RadioButton Content="{Binding [UiText.130], Source={x:Static services:LocalizationService.Shared}}" GroupName="SessionCursorShape"
                                                          IsChecked="{Binding IsAppearanceCursorShapeUnderline, Mode=TwoWay}"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="AppearanceWindowPage"
                              IsVisible="{Binding IsAppearanceWindowPage}"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="16">
                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <StackPanel Spacing="18">
                                <TextBlock Text="{Binding [UiText.131], Source={x:Static services:LocalizationService.Shared}}" FontWeight="SemiBold"/>
                                <Grid ColumnDefinitions="90,112,96,90,112"
                                      RowDefinitions="Auto,14,Auto"
                                      ColumnSpacing="14">
                                    <TextBlock Text="{Binding [UiText.132], Source={x:Static services:LocalizationService.Shared}}" VerticalAlignment="Center"/>
                                    <atom:NumericUpDown Grid.Column="1" Minimum="0" Maximum="200"
                                                        Value="{Binding AppearanceWindowPaddingTop, Mode=TwoWay}"/>
                                    <TextBlock Grid.Column="3" Text="{Binding [UiText.133], Source={x:Static services:LocalizationService.Shared}}" VerticalAlignment="Center"/>
                                    <atom:NumericUpDown Grid.Column="4" Minimum="0" Maximum="200"
                                                        Value="{Binding AppearanceWindowPaddingBottom, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="2" Text="{Binding [UiText.134], Source={x:Static services:LocalizationService.Shared}}" VerticalAlignment="Center"/>
                                    <atom:NumericUpDown Grid.Row="2" Grid.Column="1" Minimum="0" Maximum="200"
                                                        Value="{Binding AppearanceWindowPaddingLeft, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="3" Text="{Binding [UiText.135], Source={x:Static services:LocalizationService.Shared}}" VerticalAlignment="Center"/>
                                    <atom:NumericUpDown Grid.Row="2" Grid.Column="4" Minimum="0" Maximum="200"
                                                        Value="{Binding AppearanceWindowPaddingRight, Mode=TwoWay}"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <StackPanel Spacing="18">
                                <TextBlock Text="{Binding [UiText.136], Source={x:Static services:LocalizationService.Shared}}" FontWeight="SemiBold"/>
                                <Grid ColumnDefinitions="110,112,90,Auto"
                                      RowDefinitions="Auto,14,Auto"
                                      ColumnSpacing="14">
                                    <TextBlock Text="{Binding [UiText.137], Source={x:Static services:LocalizationService.Shared}}" VerticalAlignment="Center"/>
                                    <atom:NumericUpDown Grid.Column="1" Minimum="-5" Maximum="32"
                                                        Value="{Binding AppearanceLineSpacing, Mode=TwoWay}"/>
                                    <TextBlock Grid.Column="3" Text="(-5 ~ 32)" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="2" Text="{Binding [UiText.138], Source={x:Static services:LocalizationService.Shared}}" VerticalAlignment="Center"/>
                                    <atom:NumericUpDown Grid.Row="2" Grid.Column="1" Minimum="-5" Maximum="32"
                                                        Value="{Binding AppearanceCharacterSpacing, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="3" Text="(-5 ~ 32)" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <StackPanel Spacing="14">
                                <TextBlock Text="{Binding [UiText.139], Source={x:Static services:LocalizationService.Shared}}" FontWeight="SemiBold"/>
                                <StackPanel Orientation="Horizontal" Spacing="22">
                                    <atom:RadioButton Content="{Binding [UiText.140], Source={x:Static services:LocalizationService.Shared}}" GroupName="SessionAppearanceTabColor"
                                                      IsChecked="{Binding IsAppearanceTabColorDefault, Mode=TwoWay}"/>
                                    <atom:RadioButton Content="{Binding [UiText.141], Source={x:Static services:LocalizationService.Shared}}" GroupName="SessionAppearanceTabColor"
                                                      IsChecked="{Binding IsAppearanceTabColorRed, Mode=TwoWay}"/>
                                    <atom:RadioButton Content="{Binding [UiText.142], Source={x:Static services:LocalizationService.Shared}}" GroupName="SessionAppearanceTabColor"
                                                      IsChecked="{Binding IsAppearanceTabColorPurple, Mode=TwoWay}"/>
                                    <atom:RadioButton Content="{Binding [UiText.143], Source={x:Static services:LocalizationService.Shared}}" GroupName="SessionAppearanceTabColor"
                                                      IsChecked="{Binding IsAppearanceTabColorYellow, Mode=TwoWay}"/>
                                    <atom:RadioButton Content="{Binding [UiText.144], Source={x:Static services:LocalizationService.Shared}}" GroupName="SessionAppearanceTabColor"
                                                      IsChecked="{Binding IsAppearanceTabColorCustom, Mode=TwoWay}"/>
                                    <atom:ColorPicker Width="116"
                                                      Value="{Binding AppearanceTabCustomColor, Mode=TwoWay}"
                                                      IsEnabled="{Binding IsAppearanceTabColorCustom}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <StackPanel Spacing="14">
                                <TextBlock Text="{Binding [UiText.145], Source={x:Static services:LocalizationService.Shared}}" FontWeight="SemiBold"/>
                                <Grid ColumnDefinitions="110,*,64"
                                      RowDefinitions="Auto,14,Auto"
                                      ColumnSpacing="10">
                                    <TextBlock Text="{Binding [UiText.146], Source={x:Static services:LocalizationService.Shared}}" VerticalAlignment="Center"/>
                                    <atom:LineEdit Grid.Column="1"
                                                   x:Name="SessionAppearanceBackgroundImagePathBox"
                                                   Text="{Binding AppearanceBackgroundImagePath, Mode=TwoWay}"/>
                                     <atom:Button Grid.Column="2"
                                                  Content="..."
                                                  Width="48"
                                                  MinWidth="48"
                                                  HorizontalContentAlignment="Center"
                                                  Click="OnBrowseSessionAppearanceBackgroundImageClick"/>
                                    <TextBlock Grid.Row="2" Text="{Binding [UiText.147], Source={x:Static services:LocalizationService.Shared}}" VerticalAlignment="Center"/>
                                    <atom:Select Grid.Row="2"
                                                 Grid.Column="1"
                                                 x:Name="SessionAppearanceBackgroundImagePositionSelect"
                                                 OptionsSource="{Binding AppearanceBackgroundImagePositionOptions}"
                                                 Mode="Single"
                                                 SelectionChanged="OnSessionAppearanceSelectionChanged"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="AppearanceHighlightPage"
                              IsVisible="{Binding IsAppearanceHighlightPage}"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="16">
                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <StackPanel Spacing="14">
                                <TextBlock Text="{Binding [UiText.148], Source={x:Static services:LocalizationService.Shared}}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding [UiText.149], Source={x:Static services:LocalizationService.Shared}}"
                                           TextWrapping="Wrap"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <Grid ColumnDefinitions="120,*,12,116" ColumnSpacing="14">
                                    <TextBlock Text="{Binding [UiText.150], Source={x:Static services:LocalizationService.Shared}}" VerticalAlignment="Center"/>
                                    <atom:Select Grid.Column="1"
                                                 x:Name="SessionAppearanceHighlightSetSelect"
                                                 OptionsSource="{Binding AppearanceHighlightSetOptions}"
                                                 Mode="Single"
