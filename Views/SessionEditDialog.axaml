                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <StackPanel Spacing="12">
                                <TextBlock Text="{Binding [UiText.064], Source={x:Static services:LocalizationService.Shared}}"
                                           FontWeight="SemiBold"
                                           Foreground="{atom:SharedTokenResource ColorText}"/>
                                <atom:CheckBox Content="{Binding [UiText.065], Source={x:Static services:LocalizationService.Shared}}"
