<atom:Window xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:atom="https://atomui.net"
             xmlns:antdicons="https://atomui.net/icons/antdesign"
             xmlns:vm="using:CxShell.ViewModels"
             xmlns:models="using:CxShell.Models"
             xmlns:services="using:CxShell.Services"
             x:Class="CxShell.Views.SessionEditDialog"
             x:DataType="vm:SessionEditViewModel"
             Title="{Binding DialogTitle}"
             Width="1120"
             Height="720"
             MinWidth="980"
             MinHeight="600"
             WindowStartupLocation="CenterOwner"
             CanResize="True"
             ShowInTaskbar="False"
             Background="{atom:SharedTokenResource ColorBgLayout}"
             Loaded="OnWindowLoaded">

    <atom:Window.Styles>
        <Style Selector="atom|LineEdit">
            <Setter Property="Background" Value="{atom:SharedTokenResource ColorBgContainer}"/>
            <Setter Property="Foreground" Value="{atom:SharedTokenResource ColorText}"/>
            <Setter Property="CaretBrush" Value="{atom:SharedTokenResource ColorText}"/>
            <Setter Property="BorderBrush" Value="{atom:SharedTokenResource ColorBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="atom|RadioButton">
            <Setter Property="Foreground" Value="{atom:SharedTokenResource ColorTextSecondary}"/>
        </Style>
        <Style Selector="atom|NumericUpDown">
            <Setter Property="MinWidth" Value="112"/>
        </Style>
        <Style Selector="atom|Button.session-nav">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="MinHeight" Value="34"/>
        </Style>
        <Style Selector="atom|Button.session-nav:pointerover">
            <Setter Property="Background" Value="{atom:SharedTokenResource ColorFillTertiary}"/>
        </Style>
        <Style Selector="atom|Button.file-picker-button">
            <Setter Property="Width" Value="48"/>
            <Setter Property="MinWidth" Value="48"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="MinHeight" Value="48"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="IsWaveSpiritEnabled" Value="False"/>
            <Setter Property="ClipToBounds" Value="True"/>
        </Style>
        <Style Selector="atom|Button.file-picker-button /template/ Border#ShadowsFrame">
            <Setter Property="BoxShadow" Value="0 0 0 0 Transparent"/>
        </Style>
        <Style Selector="atom|InlineNavMenuItemHeader[Level=0]">
            <Setter Property="Background" Value="{atom:SharedTokenResource ColorFillSecondary}"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="atom|InlineNavMenuItemHeader[Level=0]:pointerover">
            <Setter Property="Background" Value="{atom:SharedTokenResource ColorFill}"/>
        </Style>
        <Style Selector="atom|InlineNavMenuItemHeader[Level=0][IsInSelectedPath=True]">
            <Setter Property="Background" Value="{atom:SharedTokenResource ColorPrimaryBg}"/>
        </Style>
        <Style Selector="atom|InlineNavMenuItemHeader[Level=0][IsSelected=True]">
            <Setter Property="Background" Value="{atom:SharedTokenResource ColorPrimaryBg}"/>
        </Style>
        <Style Selector="atom|InlineNavMenuItemHeader[Level=1]">
            <Setter Property="Background" Value="{atom:SharedTokenResource ColorFillQuaternary}"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="atom|InlineNavMenuItemHeader[Level=1]:pointerover">
            <Setter Property="Background" Value="{atom:SharedTokenResource ColorFillTertiary}"/>
        </Style>
        <Style Selector="atom|InlineNavMenuItemHeader[Level=1][IsSelected=True]">
            <Setter Property="Background" Value="{atom:SharedTokenResource ColorPrimaryBg}"/>
        </Style>
    </atom:Window.Styles>

    <Grid Margin="20" ColumnDefinitions="220,14,*,14,140">
        <Border Grid.Column="0"
                Background="{atom:SharedTokenResource ColorBgContainer}"
                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Spacing="2" Margin="2,2,2,12">
                    <TextBlock Text="{Binding NavTitleText}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{atom:SharedTokenResource ColorText}"/>
                    <TextBlock Text="{Binding NavSubtitleText}"
                               FontSize="12"
                               Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                </StackPanel>
                <atom:NavMenu x:Name="SessionNavMenu"
                              Mode="Inline"
                              IsAccordionMode="False"
                              DefaultOpenPaths="{Binding DefaultOpenNavPaths}"
                              DefaultSelectedPath="{Binding DefaultSelectedNavPath}"
                              NavMenuItemClick="OnSessionNavMenuItemClick">
                    <atom:NavMenuNode Header="{Binding ConnectionText}"
                                      ItemKey="Connection"
                                      Icon="{antdicons:AntDesignIconProvider Kind=LinkOutlined}">
                        <atom:NavMenuNode Header="{Binding LoginPromptText}" ItemKey="LoginPrompt"/>
                        <atom:NavMenuNode Header="{Binding LoginScriptText}" ItemKey="LoginScript"/>
                        <atom:NavMenuNode Header="{Binding ProxyText}" ItemKey="Proxy"/>
                        <atom:NavMenuNode Header="{Binding KeepAliveText}" ItemKey="KeepAlive"/>
                        <atom:NavMenuNode Header="TELNET" ItemKey="Telnet"/>
                        <atom:NavMenuNode Header="RLOGIN" ItemKey="Rlogin"/>
                        <atom:NavMenuNode Header="{Binding SerialText}" ItemKey="Serial"/>
                        <atom:NavMenuNode Header="RDP" ItemKey="Rdp"/>
                    </atom:NavMenuNode>
                    <atom:NavMenuNode Header="SSH"
                                      ItemKey="Ssh"
                                      Icon="{antdicons:AntDesignIconProvider Kind=SafetyCertificateOutlined}">
                        <atom:NavMenuNode Header="{Binding SecurityText}" ItemKey="SshSecurity"/>
                        <atom:NavMenuNode Header="{Binding TunnelText}" ItemKey="SshTunnel"/>
                        <atom:NavMenuNode Header="SFTP" ItemKey="SshSftp"/>
                    </atom:NavMenuNode>
                    <atom:NavMenuNode Header="{Binding TerminalText}"
                                      ItemKey="Terminal"
                                      Icon="{antdicons:AntDesignIconProvider Kind=CodeOutlined}">
                        <atom:NavMenuNode Header="{Binding KeyboardText}" ItemKey="Keyboard"/>
                        <atom:NavMenuNode Header="{Binding VtModeText}" ItemKey="VtMode"/>
                        <atom:NavMenuNode Header="{Binding AdvancedText}" ItemKey="TerminalAdvanced"/>
                    </atom:NavMenuNode>
                    <atom:NavMenuNode Header="{Binding AppearanceText}"
                                      ItemKey="Appearance"
                                      Icon="{antdicons:AntDesignIconProvider Kind=BgColorsOutlined}">
                        <atom:NavMenuNode Header="{Binding WindowText}" ItemKey="AppearanceWindow"/>
                        <atom:NavMenuNode Header="{Binding HighlightText}" ItemKey="AppearanceHighlight"/>
                    </atom:NavMenuNode>
                    <atom:NavMenuNode Header="{Binding TransferText}" ItemKey="Transfer">
                        <atom:NavMenuNode Header="{Binding XymodemText}" ItemKey="FileTransferXymodem"/>
                        <atom:NavMenuNode Header="{Binding ZmodemText}" ItemKey="FileTransferZmodem"/>
                    </atom:NavMenuNode>
                    <atom:NavMenuNode Header="{Binding AdvancedText}"
                                      ItemKey="Advanced"
                                      Icon="{antdicons:AntDesignIconProvider Kind=SettingOutlined}">
                        <atom:NavMenuNode Header="{Binding LoggingText}" ItemKey="Logging"/>
                        <atom:NavMenuNode Header="{Binding BellText}" ItemKey="Bell"/>
                        <atom:NavMenuNode Header="{Binding TracingText}" ItemKey="Tracing"/>
                    </atom:NavMenuNode>
                </atom:NavMenu>
            </DockPanel>
        </Border>

        <Grid Grid.Column="2" RowDefinitions="Auto,12,*">
            <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                    BorderBrush="{atom:SharedTokenResource ColorSplit}"
                    BorderThickness="0,0,0,1"
                    Padding="12,8">
                <TextBlock x:Name="PageTitleText"
                           Text="{Binding ConnectionText}"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="{atom:SharedTokenResource ColorText}"/>
            </Border>

            <Grid Grid.Row="2">
                <ScrollViewer x:Name="ConnectionPage">
                    <StackPanel Spacing="16">
                        <Border Background="{atom:SharedTokenResource ColorErrorBg}"
                                BorderBrush="{atom:SharedTokenResource ColorErrorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="10,8"
                                IsVisible="{Binding HasValidationError}">
                            <TextBlock Text="{Binding ValidationMessage}"
                                       Foreground="{atom:SharedTokenResource ColorError}"
                                       FontSize="13"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <Grid RowDefinitions="Auto,14,Auto,12,Auto,12,Auto,12,Auto,12,Auto"
                                  ColumnDefinitions="110,*">
                                <TextBlock Grid.ColumnSpan="2"
                                           Text="{Binding GeneralText}"
                                           FontWeight="SemiBold"
                                           Foreground="{atom:SharedTokenResource ColorText}"/>

                                <TextBlock Grid.Row="4" Text="{Binding NameText}"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:LineEdit Grid.Row="4" Grid.Column="1"
                                              x:Name="NameBox"
                                              Status="{Binding NameStatus}"
                                              Text="{Binding SessionName, Mode=TwoWay}"
                                              PlaceholderText="{Binding NamePlaceholderText}"/>

                                <TextBlock Grid.Row="6" Text="{Binding ProtocolText}"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:Select Grid.Row="6" Grid.Column="1"
                                             x:Name="ProtocolSelect"
                                             Mode="Single"
                                             HorizontalAlignment="Stretch"
                                             PlaceholderText="{Binding ProtocolPlaceholderText}"
                                             OptionsSource="{Binding ProtocolOptions}"
                                             SelectionChanged="OnProtocolSelectionChanged"/>

                                <TextBlock Grid.Row="8" Text="{Binding HostText}"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:LineEdit Grid.Row="8" Grid.Column="1"
                                              x:Name="HostBox"
                                              Status="{Binding HostStatus}"
                                              Text="{Binding Host, Mode=TwoWay}"
                                              PlaceholderText="{Binding HostPlaceholderText}"/>

                                <TextBlock Grid.Row="10" Text="{Binding PortText}"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:LineEdit Grid.Row="10" Grid.Column="1"
                                              x:Name="PortBox"
                                              Width="160"
                                              HorizontalAlignment="Left"
                                              Status="{Binding PortStatus}"
                                              Text="{Binding Port, Mode=TwoWay}"
                                              PlaceholderText="22"/>
                            </Grid>
                        </Border>

                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <Grid RowDefinitions="Auto,14,Auto,12,Auto,12,Auto,12,Auto"
                                  ColumnDefinitions="110,*">
                                <TextBlock Grid.ColumnSpan="2"
                                           Text="{Binding UserAuthText}"
                                           FontWeight="SemiBold"
                                           Foreground="{atom:SharedTokenResource ColorText}"/>

                                <TextBlock Grid.Row="2" Text="{Binding UsernameText}"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:LineEdit Grid.Row="2" Grid.Column="1"
                                              x:Name="ConnectionUsernameBox"
                                              Text="{Binding Username, Mode=TwoWay}"
                                              PlaceholderText="root"/>

                                <TextBlock Grid.Row="4" Text="{Binding AuthMethodText}"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <StackPanel Grid.Row="4" Grid.Column="1"
                                            Orientation="Horizontal"
                                            Spacing="20">
                                    <atom:RadioButton Content="{Binding PasswordText}"
                                                      IsChecked="{Binding IsPasswordAuth}"
                                                      GroupName="ConnectionAuthMethod"/>
                                    <atom:RadioButton Content="{Binding PrivateKeyText}"
                                                      IsChecked="{Binding IsPrivateKeyAuth}"
                                                      GroupName="ConnectionAuthMethod"/>
                                </StackPanel>

                                <TextBlock Grid.Row="6" Text="{Binding PasswordText}"
                                           VerticalAlignment="Center"
                                           IsVisible="{Binding IsPasswordAuth}"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <StackPanel Grid.Row="6" Grid.Column="1"
                                            Spacing="6"
                                            IsVisible="{Binding IsPasswordAuth}">
                                    <atom:LineEdit Text="{Binding Password, Mode=TwoWay}"
                                                   PasswordChar="*"
                                                   IsEnableRevealButton="True"
                                                   IsAllowClear="True"/>
                                    <TextBlock Text="{Binding PasswordNotSavedText}"
                                               FontSize="12"
                                               Foreground="{atom:SharedTokenResource ColorTextTertiary}"/>
                                    <TextBlock Text="{Binding PasswordSavedEncryptedText}"
                                               FontSize="12"
                                               Foreground="{atom:SharedTokenResource ColorTextTertiary}"/>
                                </StackPanel>

                                <TextBlock Grid.Row="8" Text="{Binding PrivateKeyPathText}"
                                           VerticalAlignment="Center"
                                           IsVisible="{Binding IsPrivateKeyAuth}"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <Grid Grid.Row="8" Grid.Column="1"
                                      ColumnDefinitions="*,Auto"
                                      ColumnSpacing="8"
                                      IsVisible="{Binding IsPrivateKeyAuth}">
                                    <atom:LineEdit Text="{Binding PrivateKeyPath, Mode=TwoWay}"
                                                  PlaceholderText="~/.ssh/id_rsa"/>
                                    <atom:Button Grid.Column="1"
                                                 Icon="{antdicons:AntDesignIconProvider Kind=FolderOpenOutlined}"
                                                 Content="{Binding BrowseText}"
                                                 Command="{Binding BrowseKeyCommand}"/>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18"
                                IsVisible="{Binding IsVncProtocol}">
                            <Grid RowDefinitions="Auto,14,Auto,8,Auto,12,Auto,12,Auto,12,Auto,12,Auto,12,Auto"
                                  ColumnDefinitions="110,*">
                                <TextBlock Grid.ColumnSpan="2"
                                           Text="{Binding VncSshTunnelTitleText}"
                                           FontWeight="SemiBold"
                                           Foreground="{atom:SharedTokenResource ColorText}"/>

                                <atom:CheckBox Grid.Row="2"
                                               Grid.ColumnSpan="2"
                                               Content="{Binding UseVncSshTunnelText}"
                                               IsChecked="{Binding VncUseSshTunnel, Mode=TwoWay}"/>

                                <TextBlock Grid.Row="4"
                                           Grid.ColumnSpan="2"
                                           Text="{Binding VncSshTunnelDescriptionText}"
                                           TextWrapping="Wrap"
                                           Foreground="{atom:SharedTokenResource ColorTextTertiary}"/>

                                <TextBlock Grid.Row="6"
                                           Text="{Binding SshHostText}"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:LineEdit Grid.Row="6"
                                               Grid.Column="1"
                                               Text="{Binding VncSshHost, Mode=TwoWay}"
                                               IsEnabled="{Binding VncUseSshTunnel}"
                                               PlaceholderText="{Binding Host}"/>

                                <TextBlock Grid.Row="8"
                                           Text="{Binding SshPortText}"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:LineEdit Grid.Row="8"
                                               Grid.Column="1"
                                               Width="160"
                                               HorizontalAlignment="Left"
                                               Text="{Binding VncSshPort, Mode=TwoWay}"
                                               IsEnabled="{Binding VncUseSshTunnel}"
                                               PlaceholderText="22"/>

                                <TextBlock Grid.Row="10"
                                           Text="{Binding SshUsernameText}"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:LineEdit Grid.Row="10"
                                               Grid.Column="1"
                                               Text="{Binding VncSshUsername, Mode=TwoWay}"
                                               IsEnabled="{Binding VncUseSshTunnel}"
                                               PlaceholderText="root"/>

                                <TextBlock Grid.Row="12"
                                           Text="{Binding AuthMethodText}"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <StackPanel Grid.Row="12"
                                            Grid.Column="1"
                                            Orientation="Horizontal"
                                            Spacing="20"
                                            IsEnabled="{Binding VncUseSshTunnel}">
                                    <atom:RadioButton Content="{Binding PasswordText}"
                                                      IsChecked="{Binding IsVncSshPasswordAuth}"
                                                      GroupName="VncSshAuthMethod"/>
                                    <atom:RadioButton Content="{Binding PrivateKeyText}"
                                                      IsChecked="{Binding IsVncSshPrivateKeyAuth}"
                                                      GroupName="VncSshAuthMethod"/>
                                </StackPanel>

                                <TextBlock Grid.Row="14"
                                           Text="{Binding SshPasswordText}"
                                           VerticalAlignment="Center"
                                           IsVisible="{Binding IsVncSshPasswordAuth}"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:LineEdit Grid.Row="14"
                                               Grid.Column="1"
                                               Text="{Binding VncSshPassword, Mode=TwoWay}"
                                               PasswordChar="*"
                                               IsEnableRevealButton="True"
                                               IsAllowClear="True"
                                               IsEnabled="{Binding VncUseSshTunnel}"
                                               IsVisible="{Binding IsVncSshPasswordAuth}"/>

                                <TextBlock Grid.Row="14"
                                           Text="{Binding SshPrivateKeyText}"
                                           VerticalAlignment="Center"
                                           IsVisible="{Binding IsVncSshPrivateKeyAuth}"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <Grid Grid.Row="14"
                                      Grid.Column="1"
                                      ColumnDefinitions="*,Auto"
                                      ColumnSpacing="8"
                                      IsEnabled="{Binding VncUseSshTunnel}"
                                      IsVisible="{Binding IsVncSshPrivateKeyAuth}">
                                    <atom:LineEdit Text="{Binding VncSshPrivateKeyPath, Mode=TwoWay}"
                                                   PlaceholderText="~/.ssh/id_rsa"/>
                                    <atom:Button Grid.Column="1"
                                                 Icon="{antdicons:AntDesignIconProvider Kind=FolderOpenOutlined}"
                                                 Content="{Binding BrowseText}"
                                                 Command="{Binding BrowseVncSshKeyCommand}"/>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18"
                                IsVisible="{Binding IsRdpProtocol}">
                            <Grid RowDefinitions="Auto,14,Auto,10,Auto,12,Auto,12,Auto,12,Auto,12,Auto,12,Auto"
                                  ColumnDefinitions="120,*"
                                  ColumnSpacing="12">
                                <TextBlock Grid.ColumnSpan="2"
                                           Text="{Binding SshTunnelTitleText}"
                                           FontWeight="SemiBold"
                                           Foreground="{atom:SharedTokenResource ColorText}"/>

                                <atom:CheckBox Grid.Row="2"
                                               Grid.ColumnSpan="2"
                                               Content="{Binding UseRdpSshTunnelText}"
                                               IsChecked="{Binding RdpUseSshTunnel, Mode=TwoWay}"/>

                                <TextBlock Grid.Row="4"
                                           Grid.ColumnSpan="2"
                                           Text="{Binding RdpSshTunnelDescriptionText}"
                                           TextWrapping="Wrap"
                                           Foreground="{atom:SharedTokenResource ColorTextTertiary}"/>

                                <TextBlock Grid.Row="6"
                                           Text="{Binding SshHostText}"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:LineEdit Grid.Row="6"
                                               Grid.Column="1"
                                               Text="{Binding RdpSshHost, Mode=TwoWay}"
                                               IsEnabled="{Binding RdpUseSshTunnel}"
                                               PlaceholderText="{Binding Host}"/>

                                <TextBlock Grid.Row="8"
                                           Text="{Binding SshPortText}"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:LineEdit Grid.Row="8"
                                               Grid.Column="1"
                                               Width="160"
                                               HorizontalAlignment="Left"
                                               Text="{Binding RdpSshPort, Mode=TwoWay}"
                                               IsEnabled="{Binding RdpUseSshTunnel}"
                                               PlaceholderText="22"/>

                                <TextBlock Grid.Row="10"
                                           Text="{Binding SshUsernameText}"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:LineEdit Grid.Row="10"
                                               Grid.Column="1"
                                               Text="{Binding RdpSshUsername, Mode=TwoWay}"
                                               IsEnabled="{Binding RdpUseSshTunnel}"
                                               PlaceholderText="root"/>

                                <TextBlock Grid.Row="12"
                                           Text="{Binding AuthMethodText}"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <StackPanel Grid.Row="12"
                                            Grid.Column="1"
                                            Orientation="Horizontal"
                                            Spacing="20"
                                            IsEnabled="{Binding RdpUseSshTunnel}">
                                    <atom:RadioButton Content="{Binding PasswordText}"
                                                      IsChecked="{Binding IsRdpSshPasswordAuth}"
                                                      GroupName="RdpSshAuthMethod"/>
                                    <atom:RadioButton Content="{Binding PrivateKeyText}"
                                                      IsChecked="{Binding IsRdpSshPrivateKeyAuth}"
                                                      GroupName="RdpSshAuthMethod"/>
                                </StackPanel>

                                <TextBlock Grid.Row="14"
                                           Text="{Binding SshPasswordText}"
                                           VerticalAlignment="Center"
                                           IsVisible="{Binding IsRdpSshPasswordAuth}"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:LineEdit Grid.Row="14"
                                               Grid.Column="1"
                                               Text="{Binding RdpSshPassword, Mode=TwoWay}"
                                               PasswordChar="*"
                                               IsEnableRevealButton="True"
                                               IsAllowClear="True"
                                               IsEnabled="{Binding RdpUseSshTunnel}"
                                               IsVisible="{Binding IsRdpSshPasswordAuth}"/>

                                <TextBlock Grid.Row="14"
                                           Text="{Binding SshPrivateKeyText}"
                                           VerticalAlignment="Center"
                                           IsVisible="{Binding IsRdpSshPrivateKeyAuth}"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <Grid Grid.Row="14"
                                      Grid.Column="1"
                                      ColumnDefinitions="*,Auto"
                                      ColumnSpacing="8"
                                      IsEnabled="{Binding RdpUseSshTunnel}"
                                      IsVisible="{Binding IsRdpSshPrivateKeyAuth}">
                                    <atom:LineEdit Text="{Binding RdpSshPrivateKeyPath, Mode=TwoWay}"
                                                   PlaceholderText="~/.ssh/id_rsa"/>
                                    <atom:Button Grid.Column="1"
                                                 Icon="{antdicons:AntDesignIconProvider Kind=FolderOpenOutlined}"
                                                 Content="{Binding BrowseText}"
                                                 Command="{Binding BrowseRdpSshKeyCommand}"/>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <Grid RowDefinitions="Auto,14,Auto,12,Auto"
                                  ColumnDefinitions="Auto,8,112,6,Auto,24,Auto,8,112,6,Auto,*">
                                <TextBlock Grid.ColumnSpan="12"
                                           Text="{Binding ReconnectText}"
                                           FontWeight="SemiBold"
                                           Foreground="{atom:SharedTokenResource ColorText}"/>

                                <atom:CheckBox Grid.Row="2"
                                               Grid.ColumnSpan="12"
                                               Content="{Binding AutoReconnectText}"
                                               IsChecked="{Binding AutoReconnect, Mode=TwoWay}"/>

                                <TextBlock Grid.Row="4" Grid.Column="0"
                                           Text="{Binding IntervalText}"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:NumericUpDown Grid.Row="4" Grid.Column="2"
                                                    Minimum="1"
                                                    Maximum="3600"
                                                    Value="{Binding ReconnectIntervalSeconds, Mode=TwoWay}"
                                                    IsEnabled="{Binding AutoReconnect}"/>
                                <TextBlock Grid.Row="4" Grid.Column="4"
                                           Text="{Binding SecondsText}"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>

                                <TextBlock Grid.Row="4" Grid.Column="6"
                                           Text="{Binding LimitText}"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:NumericUpDown Grid.Row="4" Grid.Column="8"
                                                    Minimum="0"
                                                    Maximum="1440"
                                                    Value="{Binding ReconnectLimitMinutes, Mode=TwoWay}"
                                                    IsEnabled="{Binding AutoReconnect}"/>
                                <TextBlock Grid.Row="4" Grid.Column="10"
                                           Text="{Binding MinutesText}"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="KeepAlivePage" IsVisible="False">
                    <StackPanel Spacing="16">
                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <Grid RowDefinitions="Auto,14,Auto,18,Auto,12,Auto,18,Auto,10,Auto"
                                  ColumnDefinitions="Auto,14,110,18,56,56,120,*">
                                <TextBlock Grid.ColumnSpan="8"
                                           Text="{Binding [UiText.010], Source={x:Static services:LocalizationService.Shared}}"
                                           FontWeight="SemiBold"
                                           Foreground="{atom:SharedTokenResource ColorText}"/>

                                <atom:CheckBox Grid.Row="2"
                                               Grid.ColumnSpan="8"
                                               Content="{Binding [UiText.011], Source={x:Static services:LocalizationService.Shared}}"
                                               IsChecked="{Binding SendSessionKeepAlive, Mode=TwoWay}"/>

                                <TextBlock Grid.Row="4"
                                           Grid.Column="1"
                                           Grid.ColumnSpan="2"
                                           Text="{Binding [UiText.012], Source={x:Static services:LocalizationService.Shared}}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:NumericUpDown Grid.Row="4"
                                                    Grid.Column="4"
                                                    Grid.ColumnSpan="2"
                                                    Minimum="1"
                                                    Maximum="86400"
                                                    Value="{Binding SessionKeepAliveIntervalSeconds, Mode=TwoWay}"
                                                    IsEnabled="{Binding IsSessionKeepAliveIntervalEnabled}"/>
                                <TextBlock Grid.Row="4"
                                           Grid.Column="6"
                                           Text="{Binding SecondsText}"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>

                                <atom:CheckBox Grid.Row="6"
                                               Grid.ColumnSpan="8"
                                               Content="{Binding [UiText.013], Source={x:Static services:LocalizationService.Shared}}"
                                               IsChecked="{Binding SendIdleString, Mode=TwoWay}"/>

                                <TextBlock Grid.Row="8"
                                           Grid.Column="1"
                                           Grid.ColumnSpan="2"
                                           Text="{Binding [UiText.014], Source={x:Static services:LocalizationService.Shared}}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:NumericUpDown Grid.Row="8"
                                                    Grid.Column="4"
                                                    Grid.ColumnSpan="2"
                                                    Minimum="0"
                                                    Maximum="86400"
                                                    Value="{Binding IdleStringIntervalSeconds, Mode=TwoWay}"
                                                    IsEnabled="{Binding IsIdleStringSettingsEnabled}"/>
                                <TextBlock Grid.Row="8"
                                           Grid.Column="6"
                                           Text="{Binding SecondsText}"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <TextBlock Grid.Row="10"
                                           Grid.Column="1"
                                           Grid.ColumnSpan="2"
                                           Text="{Binding [UiText.015], Source={x:Static services:LocalizationService.Shared}}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:LineEdit Grid.Row="10"
                                               Grid.Column="4"
                                               Grid.ColumnSpan="4"
                                               Width="220"
                                               HorizontalAlignment="Left"
                                               Text="{Binding IdleString, Mode=TwoWay}"
                                               IsEnabled="{Binding IsIdleStringSettingsEnabled}"/>
                            </Grid>
                        </Border>

                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <atom:CheckBox Content="{Binding [UiText.016], Source={x:Static services:LocalizationService.Shared}}"
                                           IsChecked="{Binding TcpKeepAlive, Mode=TwoWay}"/>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="LoginPromptPage" IsVisible="False">
                    <StackPanel Spacing="16">
                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <Grid RowDefinitions="Auto,14,Auto,28,Auto,12,Auto"
                                  ColumnDefinitions="160,320">
                                <TextBlock Grid.ColumnSpan="2"
                                           Text="TELNET"
                                           FontWeight="SemiBold"
                                           Foreground="{atom:SharedTokenResource ColorText}"/>
                                <TextBlock Grid.Row="2"
                                           Grid.ColumnSpan="2"
                                           Text="{Binding [SessionEdit.LoginPrompt.TelnetDescription], Source={x:Static services:LocalizationService.Shared}}"
                                           TextWrapping="Wrap"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <TextBlock Grid.Row="4" Text="{Binding [UiText.017], Source={x:Static services:LocalizationService.Shared}}"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:LineEdit Grid.Row="4" Grid.Column="1"
                                              x:Name="TelnetUsernamePromptBox"
                                              Text="{Binding TelnetUsernamePrompt, Mode=TwoWay}"
                                              PlaceholderText="ogin:"/>
                                <TextBlock Grid.Row="6" Text="{Binding [UiText.018], Source={x:Static services:LocalizationService.Shared}}"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:LineEdit Grid.Row="6" Grid.Column="1"
                                              x:Name="TelnetPasswordPromptBox"
                                              Text="{Binding TelnetPasswordPrompt, Mode=TwoWay}"
                                              PlaceholderText="assword:"/>
                            </Grid>
                        </Border>

                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <Grid RowDefinitions="Auto,14,Auto,28,Auto"
                                  ColumnDefinitions="160,320">
                                <TextBlock Grid.ColumnSpan="2"
                                           Text="RLOGIN"
                                           FontWeight="SemiBold"
                                           Foreground="{atom:SharedTokenResource ColorText}"/>
                                <TextBlock Grid.Row="2"
                                           Grid.ColumnSpan="2"
                                           Text="{Binding [UiText.019], Source={x:Static services:LocalizationService.Shared}}"
                                           TextWrapping="Wrap"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <TextBlock Grid.Row="4" Text="{Binding [UiText.018], Source={x:Static services:LocalizationService.Shared}}"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:LineEdit Grid.Row="4" Grid.Column="1"
                                              x:Name="RloginPasswordPromptBox"
                                              Text="{Binding RloginPasswordPrompt, Mode=TwoWay}"
                                              PlaceholderText="assword:"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="LoginScriptPage" IsVisible="False">
                    <StackPanel Spacing="16">
                        <TextBlock Text="{Binding [UiText.020], Source={x:Static services:LocalizationService.Shared}}"
                                   TextWrapping="Wrap"
                                   Foreground="{atom:SharedTokenResource ColorText}"/>

                        <Grid RowDefinitions="Auto,12,380,22,Auto,12,Auto,12,Auto"
                              ColumnDefinitions="*,18,164">
                            <atom:CheckBox Grid.ColumnSpan="3"
                                           Content="{Binding [UiText.021], Source={x:Static services:LocalizationService.Shared}}"
                                           IsChecked="{Binding EnableLoginScriptRules, Mode=TwoWay}"/>

                            <atom:DataGrid x:Name="LoginScriptRulesGrid"
                                           Grid.Row="2"
                                           ItemsSource="{Binding LoginScriptRules}"
                                           SelectedItem="{Binding SelectedLoginScriptRule, Mode=TwoWay}"
                                           AutoGenerateColumns="False"
                                           IsReadOnly="True"
                                           SelectionMode="Single"
                                           SizeType="Middle"
                                           GridLinesVisibility="Vertical"
                                           CanUserResizeColumns="True"
                                           IsHideOnSinglePage="True">
                                <atom:DataGrid.Columns>
                                    <atom:DataGridTextColumn Header="Expect" Binding="{Binding Expect}" Width="160"/>
                                    <atom:DataGridTextColumn Header="Send" Binding="{Binding SendDisplay}" Width="360"/>
                                </atom:DataGrid.Columns>
                            </atom:DataGrid>

                            <StackPanel Grid.Row="2"
                                        Grid.Column="2"
                                        Spacing="10">
                                <atom:Button x:Name="AddLoginScriptRuleBtn"
                                             Content="{Binding [UiText.022], Source={x:Static services:LocalizationService.Shared}}"
                                             Click="OnAddLoginScriptRuleClick"/>
                                <atom:Button x:Name="EditLoginScriptRuleBtn"
                                             Content="{Binding [UiText.023], Source={x:Static services:LocalizationService.Shared}}"
                                             IsEnabled="{Binding HasSelectedLoginScriptRule}"
                                             Click="OnEditLoginScriptRuleClick"/>
                                <atom:Button x:Name="DeleteLoginScriptRuleBtn"
                                             Content="{Binding [UiText.024], Source={x:Static services:LocalizationService.Shared}}"
                                             IsEnabled="{Binding HasSelectedLoginScriptRule}"
                                             Click="OnDeleteLoginScriptRuleClick"/>
                                <atom:Button x:Name="MoveUpLoginScriptRuleBtn"
                                             Content="{Binding [UiText.025], Source={x:Static services:LocalizationService.Shared}}"
                                             IsEnabled="{Binding HasSelectedLoginScriptRule}"
                                             Click="OnMoveUpLoginScriptRuleClick"/>
                                <atom:Button x:Name="MoveDownLoginScriptRuleBtn"
                                             Content="{Binding [UiText.026], Source={x:Static services:LocalizationService.Shared}}"
                                             IsEnabled="{Binding HasSelectedLoginScriptRule}"
                                             Click="OnMoveDownLoginScriptRuleClick"/>
                            </StackPanel>

                            <atom:CheckBox Grid.Row="4"
                                           Grid.ColumnSpan="3"
                                           Content="{Binding [UiText.027], Source={x:Static services:LocalizationService.Shared}}"
                                           IsChecked="{Binding RunLoginScriptFile, Mode=TwoWay}"/>

                            <Grid Grid.Row="6"
                                  Grid.ColumnSpan="3"
                                  ColumnDefinitions="*,8,64,4">
                                <atom:LineEdit x:Name="LoginScriptFilePathBox"
                                               Text="{Binding LoginScriptFilePath, Mode=TwoWay}"
                                               VerticalAlignment="Center"
                                               IsEnabled="{Binding IsLoginScriptFileEnabled}"/>
                                <atom:Button Grid.Column="2"
                                              Classes="file-picker-button"
                                               Content="..."
                                               Width="48"
                                               MinWidth="48"
                                               HorizontalContentAlignment="Center"
                                               IsEnabled="{Binding IsLoginScriptFileEnabled}"
                                               Click="OnBrowseLoginScriptFileClick"/>
                            </Grid>

                            <Grid Grid.Row="8"
                                  Grid.ColumnSpan="3"
                                  ColumnDefinitions="Auto,12,*">
                                <TextBlock Text="{Binding [UiText.028], Source={x:Static services:LocalizationService.Shared}}"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:LineEdit Grid.Column="2"
                                               Text="{Binding LoginScriptParameters, Mode=TwoWay}"
                                               IsEnabled="{Binding IsLoginScriptFileEnabled}"/>
                            </Grid>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="SshPage" IsVisible="False">
                    <StackPanel Spacing="16">
                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <Grid RowDefinitions="Auto,14,Auto,28,Auto"
                                  ColumnDefinitions="*">
                                <TextBlock Text="{Binding [UiText.029], Source={x:Static services:LocalizationService.Shared}}"
                                           FontWeight="SemiBold"
                                           Foreground="{atom:SharedTokenResource ColorText}"/>
                                <TextBlock Grid.Row="2"
                                           Text="{Binding [UiText.030], Source={x:Static services:LocalizationService.Shared}}"
                                           TextWrapping="Wrap"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:LineEdit Grid.Row="4"
                                              x:Name="SshRemoteCommandBox"
                                              Text="{Binding SshRemoteCommand, Mode=TwoWay}"
                                              PlaceholderText="{Binding [UiText.031], Source={x:Static services:LocalizationService.Shared}}"/>
                            </Grid>
                        </Border>

                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <Grid RowDefinitions="Auto,14,Auto,28,Auto"
                                  ColumnDefinitions="*">
                                <TextBlock Text="{Binding [UiText.032], Source={x:Static services:LocalizationService.Shared}}"
                                           FontWeight="SemiBold"
                                           Foreground="{atom:SharedTokenResource ColorText}"/>
                                <TextBlock Grid.Row="2"
                                           Text="{Binding [UiText.033], Source={x:Static services:LocalizationService.Shared}}"
                                           TextWrapping="Wrap"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:Select Grid.Row="4"
                                             x:Name="SshVersionPolicySelect"
                                             Mode="Single"
                                             HorizontalAlignment="Stretch"
                                             OptionsSource="{Binding SshVersionOptions}"/>
                            </Grid>
                        </Border>

                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <StackPanel Spacing="12">
                                <TextBlock Text="{Binding [UiText.034], Source={x:Static services:LocalizationService.Shared}}"
                                           FontWeight="SemiBold"
                                           Foreground="{atom:SharedTokenResource ColorText}"/>
                                <TextBlock Text="{Binding [UiText.035], Source={x:Static services:LocalizationService.Shared}}"
                                           TextWrapping="Wrap"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:CheckBox Content="{Binding [UiText.036], Source={x:Static services:LocalizationService.Shared}}"
                                               IsChecked="{Binding SshUseXagent, Mode=TwoWay}"/>
                                <atom:CheckBox Content="{Binding [UiText.037], Source={x:Static services:LocalizationService.Shared}}"
                                               IsChecked="{Binding SshForwardAgent, Mode=TwoWay}"/>
                            </StackPanel>
                        </Border>

                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <StackPanel Spacing="12">
                                <TextBlock Text="{Binding [UiText.038], Source={x:Static services:LocalizationService.Shared}}"
                                           FontWeight="SemiBold"
                                           Foreground="{atom:SharedTokenResource ColorText}"/>
                                <atom:CheckBox Content="{Binding [UiText.039], Source={x:Static services:LocalizationService.Shared}}"
                                               IsChecked="{Binding SshUseCompression, Mode=TwoWay}"/>
                                <atom:CheckBox Content="{Binding [UiText.040], Source={x:Static services:LocalizationService.Shared}}"
                                               IsChecked="{Binding SshNoTerminal, Mode=TwoWay}"/>
                                <atom:CheckBox Content="{Binding [UiText.041], Source={x:Static services:LocalizationService.Shared}}"
                                               IsChecked="{Binding SshAcceptAndSaveHostKey, Mode=TwoWay}"/>
                                <atom:CheckBox Content="{Binding [UiText.042], Source={x:Static services:LocalizationService.Shared}}"
                                               IsChecked="{Binding SshAutoOpenSftpPanel, Mode=TwoWay}"/>
                                <atom:CheckBox Content="{Binding [UiText.260], Source={x:Static services:LocalizationService.Shared}}"
                                               IsChecked="{Binding SshAutoOpenMonitorPanel, Mode=TwoWay}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="SshSecurityPage" IsVisible="False">
                    <StackPanel Spacing="16">
                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <Grid RowDefinitions="Auto,14,Auto,80,Auto,12,Auto,12,Auto"
                                  ColumnDefinitions="110,*,100">
                                <TextBlock Grid.ColumnSpan="3"
                                           Text="{Binding [UiText.043], Source={x:Static services:LocalizationService.Shared}}"
                                           FontWeight="SemiBold"
                                           Foreground="{atom:SharedTokenResource ColorText}"/>
                                <TextBlock Grid.Row="2"
                                           Grid.ColumnSpan="3"
                                           Text="{Binding [UiText.044], Source={x:Static services:LocalizationService.Shared}}"
                                           TextWrapping="Wrap"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>

                                <TextBlock Grid.Row="4"
                                           Text="{Binding [UiText.045], Source={x:Static services:LocalizationService.Shared}}"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:Select Grid.Row="4"
                                             Grid.Column="1"
                                             x:Name="SshCipherSelect"
                                             Mode="Single"
                                             MinWidth="420"
                                             OptionsSource="{Binding SshCipherOptions}"/>
                                <atom:Button Grid.Row="4"
                                             Grid.Column="2"
                                             Margin="8,0,0,0"
                                             Content="{Binding [UiText.046], Source={x:Static services:LocalizationService.Shared}}"
                                             Click="OnEditSshCipherListClick"/>

                                <TextBlock Grid.Row="6"
                                           Text="MAC:"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:Select Grid.Row="6"
                                             Grid.Column="1"
                                             x:Name="SshMacSelect"
                                             Mode="Single"
                                             MinWidth="420"
                                             OptionsSource="{Binding SshMacOptions}"/>
                                <atom:Button Grid.Row="6"
                                             Grid.Column="2"
                                             Margin="8,0,0,0"
                                             Content="{Binding [UiText.047], Source={x:Static services:LocalizationService.Shared}}"
                                             Click="OnEditSshMacListClick"/>

                                <TextBlock Grid.Row="8"
                                           Text="{Binding [UiText.048], Source={x:Static services:LocalizationService.Shared}}"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:Select Grid.Row="8"
                                             Grid.Column="1"
                                             x:Name="SshKeyExchangeSelect"
                                             Mode="Single"
                                             MinWidth="420"
                                             OptionsSource="{Binding SshKeyExchangeOptions}"/>
                                <atom:Button Grid.Row="8"
                                             Grid.Column="2"
                                             Margin="8,0,0,0"
                                             Content="{Binding [UiText.049], Source={x:Static services:LocalizationService.Shared}}"
                                             Click="OnEditSshKeyExchangeListClick"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="SshTunnelPage" IsVisible="False">
                    <StackPanel Spacing="16">
                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <Grid RowDefinitions="Auto,10,Auto,14,260,14,Auto"
                                  ColumnDefinitions="*,120,120,120,56">
                                <TextBlock Grid.ColumnSpan="5"
                                           Text="{Binding [UiText.050], Source={x:Static services:LocalizationService.Shared}}"
                                           FontWeight="SemiBold"
                                           Foreground="{atom:SharedTokenResource ColorText}"/>
                                <TextBlock Grid.Row="2"
                                           Grid.ColumnSpan="5"
                                           Text="{Binding [UiText.051], Source={x:Static services:LocalizationService.Shared}}"
                                           TextWrapping="Wrap"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>

                                <atom:DataGrid x:Name="SshTunnelRulesGrid"
                                               Grid.Row="4"
                                               Grid.ColumnSpan="5"
                                               ItemsSource="{Binding SshTunnelRules}"
                                               SelectedItem="{Binding SelectedSshTunnelRule, Mode=TwoWay}"
                                               AutoGenerateColumns="False"
                                               IsReadOnly="True"
                                               SelectionMode="Single"
                                               GridLinesVisibility="Horizontal"
                                               CanUserResizeColumns="True">
                                    <atom:DataGrid.Columns>
                                        <atom:DataGridTextColumn Header="{Binding [UiText.052], Source={x:Static services:LocalizationService.Shared}}" Binding="{Binding TypeDisplay}" Width="150"/>
                                        <atom:DataGridTextColumn Header="{Binding [UiText.053], Source={x:Static services:LocalizationService.Shared}}" Binding="{Binding ListenPortDisplay}" Width="120"/>
                                        <atom:DataGridTextColumn Header="{Binding [UiText.054], Source={x:Static services:LocalizationService.Shared}}" Binding="{Binding TargetDisplay}" Width="200"/>
                                        <atom:DataGridTextColumn Header="{Binding [UiText.055], Source={x:Static services:LocalizationService.Shared}}" Binding="{Binding Description}" Width="260"/>
                                    </atom:DataGrid.Columns>
                                </atom:DataGrid>

                                <atom:Button Grid.Row="6"
                                             Grid.Column="1"
                                             Content="{Binding [UiText.022], Source={x:Static services:LocalizationService.Shared}}"
                                             Click="OnAddSshTunnelRuleClick"/>
                                <atom:Button Grid.Row="6"
                                             Grid.Column="2"
                                             Content="{Binding [UiText.023], Source={x:Static services:LocalizationService.Shared}}"
                                             IsEnabled="{Binding HasSelectedSshTunnelRule}"
                                             Click="OnEditSshTunnelRuleClick"/>
                                <atom:Button Grid.Row="6"
                                             Grid.Column="3"
                                             Content="{Binding [UiText.024], Source={x:Static services:LocalizationService.Shared}}"
                                             IsEnabled="{Binding HasSelectedSshTunnelRule}"
                                             Click="OnDeleteSshTunnelRuleClick"/>
                                <atom:Button Grid.Row="6"
                                             Grid.Column="4"
                                             Content="..."
                                             Click="OnAddSshTunnelRuleClick"/>
                            </Grid>
                        </Border>

                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <Grid RowDefinitions="Auto,12,Auto,10,Auto"
                                  ColumnDefinitions="36,120,170,*">
                                <TextBlock Grid.ColumnSpan="4"
                                           Text="{Binding [UiText.056], Source={x:Static services:LocalizationService.Shared}}"
                                           FontWeight="SemiBold"
                                           Foreground="{atom:SharedTokenResource ColorText}"/>
                                <atom:CheckBox Grid.Row="2"
                                               Grid.Column="1"
                                               Grid.ColumnSpan="3"
                                               Content="{Binding [UiText.057], Source={x:Static services:LocalizationService.Shared}}"
                                               IsChecked="{Binding SshForwardX11, Mode=TwoWay}"/>
                                <StackPanel Grid.Row="4"
                                            Grid.Column="1"
                                            Grid.ColumnSpan="3"
                                            Spacing="8">
                                    <atom:RadioButton x:Name="SshX11XmanagerButton"
                                                      Content="Xmanager(M)"
                                                      GroupName="SshX11DisplayMode"
                                                      IsChecked="{Binding SshX11UseXmanager, Mode=TwoWay}"/>
                                    <Grid ColumnDefinitions="Auto,12,*">
                                        <atom:RadioButton x:Name="SshX11DisplayButton"
                                                          Content="X DISPLAY(D):"
                                                          GroupName="SshX11DisplayMode"
                                                          VerticalAlignment="Center"/>
                                        <atom:LineEdit Grid.Column="2"
                                                       x:Name="SshX11DisplayBox"
                                                       MinWidth="260"
                                                       MaxWidth="420"
                                                       HorizontalAlignment="Left"
                                                       Text="{Binding SshX11Display, Mode=TwoWay}"
                                                       PlaceholderText="localhost:0.0"/>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="TelnetPage" IsVisible="False">
                    <StackPanel Spacing="16">
                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <Grid RowDefinitions="Auto,14,Auto,22,Auto,12,Auto,12,Auto"
                                  ColumnDefinitions="140,360">
                                <TextBlock Grid.ColumnSpan="2"
                                           Text="XDISPLOC"
                                           FontWeight="SemiBold"
                                           Foreground="{atom:SharedTokenResource ColorText}"/>
                                <TextBlock Grid.Row="2"
                                           Grid.ColumnSpan="2"
                                           Text="{Binding [UiText.058], Source={x:Static services:LocalizationService.Shared}}"
                                           TextWrapping="Wrap"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:CheckBox Grid.Row="4"
                                               Grid.ColumnSpan="2"
                                               Content="{Binding [UiText.059], Source={x:Static services:LocalizationService.Shared}}"
                                               IsChecked="{Binding TelnetUseXDisplayLocation, Mode=TwoWay}"/>
                                <TextBlock Grid.Row="6" Text="{Binding [UiText.060], Source={x:Static services:LocalizationService.Shared}}"
                                           VerticalAlignment="Center"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:LineEdit Grid.Row="6" Grid.Column="1"
                                              x:Name="TelnetXDisplayLocationBox"
                                              Text="{Binding TelnetXDisplayLocation, Mode=TwoWay}"
                                              PlaceholderText="$PCADDR:0.0"/>
                                <TextBlock Grid.Row="8"
                                           Grid.ColumnSpan="2"
                                           Text="{Binding [UiText.061], Source={x:Static services:LocalizationService.Shared}}"
                                           TextWrapping="Wrap"
                                           Foreground="{atom:SharedTokenResource ColorTextTertiary}"/>
                            </Grid>
                        </Border>

                        <Border Background="{atom:SharedTokenResource ColorBgContainer}"
                                BorderBrush="{atom:SharedTokenResource ColorBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="18">
                            <StackPanel Spacing="12">
                                <TextBlock Text="{Binding [UiText.062], Source={x:Static services:LocalizationService.Shared}}"
                                           FontWeight="SemiBold"
                                           Foreground="{atom:SharedTokenResource ColorText}"/>
                                <TextBlock Text="{Binding [UiText.063], Source={x:Static services:LocalizationService.Shared}}"
                                           Foreground="{atom:SharedTokenResource ColorTextSecondary}"/>
                                <atom:RadioButton x:Name="TelnetPassiveOptionButton"
                                                  Content="Passive"
