                                <TextBlock Grid.ColumnSpan="2"
                                           Text="{Binding [UiText.207], Source={x:Static services:LocalizationService.Shared}}"
                                           FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="2"
                                           Grid.ColumnSpan="2"
                                           Text="{Binding [UiText.208], Source={x:Static services:LocalizationService.Shared}}"
                                           TextWrapping="Wrap"/>
                                <TextBlock Grid.Row="4"
                                           Text="{Binding [UiText.209], Source={x:Static services:LocalizationService.Shared}}"
                                           VerticalAlignment="Center"/>
                                <atom:LineEdit Grid.Row="4"
                                               Grid.Column="1"
                                               Text="{Binding FileTransferXmodemUploadCommand, Mode=TwoWay}"/>
                                <TextBlock Grid.Row="6"
                                           Text="{Binding [UiText.210], Source={x:Static services:LocalizationService.Shared}}"
